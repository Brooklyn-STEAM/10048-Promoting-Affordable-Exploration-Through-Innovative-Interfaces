      row.innerHTML = `<span class="text-[11px] tracking-[.08em] uppercase font-mono">${day.name}</span><span class="text-[11px] font-mono ${day.today?'font-bold':''}" style="${day.today?'color:var(--accent)':''}">${formatHours(day.hours)}</span>`;
      hoursEl.appendChild(row);
    });

    document.getElementById('lb-like-count').textContent = loc.LikeCount||0;
    document.getElementById('lb-heart').textContent = loc.Liked?'♥':'♡';
    document.getElementById('lb-like-btn').style.color = loc.Liked?'var(--accent)':'#e8ded0';

    // Show edit + delete buttons only to owner
    document.getElementById('lb-delete-btn').style.display = loc.IsOwner ? 'flex' : 'none';
    document.getElementById('lb-edit-btn').style.display   = loc.IsOwner ? 'flex' : 'none';

