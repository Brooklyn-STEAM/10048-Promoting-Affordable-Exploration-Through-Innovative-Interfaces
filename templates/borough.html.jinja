  function onAddressInput(val) {
    addrSelected = false; hideEnrichmentCard(); clearTimeout(addrDebounce);
    if (!val || val.length < 2) { hideSuggestions(); return; }
    document.getElementById('addr-spinner').style.display = 'block';
    addrDebounce = setTimeout(() => fetchSuggestions(val), 300);
  }

  async function fetchSuggestions(val) {
    if (window._placesReady && window._placesService) {
      window._placesService.getPlacePredictions(
        { input: val + ' New York', sessionToken: window._sessionToken },
        (preds, status) => {
          document.getElementById('addr-spinner').style.display = 'none';
          if (status === google.maps.places.PlacesServiceStatus.OK && preds) {
            renderSuggestions(preds.map(p => ({
              label: p.structured_formatting?.main_text || p.description,
              sub: p.structured_formatting?.secondary_text || '',
              full: p.description,
              placeId: p.place_id,
              source: 'google'
            })));
          } else { claudeSuggestions(val); }
        }
      );
    } else { claudeSuggestions(val); }
  }

  async function claudeSuggestions(val) {
    try {
      const res = await fetch('/api/address-suggest', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({query:val}) });
      const parsed = await res.json();
      document.getElementById('addr-spinner').style.display = 'none';
      renderSuggestions((parsed||[]).map(p => ({...p, source:'claude'})));
    } catch { document.getElementById('addr-spinner').style.display='none'; hideSuggestions(); }
  }

  function renderSuggestions(items) {
    const box = document.getElementById('addr-suggestions');
    if (!items.length) { hideSuggestions(); return; }
    box.innerHTML = items.map((s, i) => `
      <button type="button" onclick="selectAddress(${i})" data-index="${i}"
        style="width:100%;display:flex;align-items:center;gap:10px;padding:13px 16px;
               background:none;border:none;border-bottom:1px solid rgba(232,222,208,0.06);
               color:#e8ded0;cursor:pointer;text-align:left;transition:background 0.15s;"
        onmouseover="this.style.background='rgba(232,222,208,0.05)'"
        onmouseout="this.style.background='none'">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(232,222,208,0.3)" stroke-width="2" style="flex-shrink:0;"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
        <div style="flex:1;min-width:0;">
          <div style="font-size:0.82rem;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${s.label}</div>
          <div style="font-size:0.65rem;color:rgba(232,222,208,0.35);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${s.sub||''}</div>
        </div>
        <span style="font-size:0.45rem;letter-spacing:0.15em;text-transform:uppercase;padding:2px 7px;border-radius:999px;flex-shrink:0;
          background:${s.source==='google'?'rgba(66,133,244,0.12)':'rgba(232,222,208,0.06)'};
          color:${s.source==='google'?'#4285f4':'rgba(232,222,208,0.3)'};">
          ${s.source==='google'?'Google':'Claude'}
        </span>
      </button>
    `).join('');
    box.dataset.items = JSON.stringify(items);
    showSuggestions();
  }

  function showSuggestions() { const box=document.getElementById('addr-suggestions'); if(box.innerHTML) box.style.display='block'; }
  function hideSuggestions() { document.getElementById('addr-suggestions').style.display='none'; }

  async function selectAddress(index) {
    const items = JSON.parse(document.getElementById('addr-suggestions').dataset.items||'[]');
    const item = items[index]; if(!item) return;
    hideSuggestions(); addrSelected=true;
    document.getElementById('input-address').value = item.full||item.label;
    if (item.placeId && window._placesReady) {
      document.getElementById('addr-spinner').style.display='block';
      const service=new google.maps.places.PlacesService(document.createElement('div'));
      service.getDetails({ placeId:item.placeId, fields:['name','formatted_address','geometry','opening_hours','photos','rating','editorial_summary','types','vicinity','website','formatted_phone_number'], sessionToken:window._sessionToken },
        (place,status)=>{
          document.getElementById('addr-spinner').style.display='none';
          window._sessionToken=new google.maps.places.AutocompleteSessionToken();
          if(status===google.maps.places.PlacesServiceStatus.OK&&place) autoFillFromPlace(place);
        });
    } else if(item.lat) { await enrichAndShow({lat:item.lat,lng:item.lng,formatted:item.full}); }
    else { await enrichAndShow({lat:null,lng:null,formatted:item.full}); }
  }

  function autoFillFromPlace(place) {
    document.getElementById('input-address').value = place.formatted_address||place.vicinity||'';
    const nameEl=document.getElementById('input-name');
    if(nameEl&&!nameEl.value&&place.name) nameEl.value=place.name;
    const descEl=document.getElementById('input-description');
    if(descEl&&!descEl.value) descEl.value=place.editorial_summary?.overview||'';
    if(place.geometry?.location) { document.getElementById('hidden-lat').value=place.geometry.location.lat(); document.getElementById('hidden-lng').value=place.geometry.location.lng(); }

    if (place.types) {
      const freePlaceTypes = ['park','natural_feature','tourist_attraction','point_of_interest'];
      const budgetTypes    = ['cafe','bakery','fast_food','convenience_store','grocery_or_supermarket'];
      const midTypes       = ['restaurant','bar','night_club','museum','art_gallery','spa','gym'];
      const upscaleTypes   = ['lodging','jewelry_store','clothing_store'];
      let suggestedTier = null;
      if (place.types.some(t => freePlaceTypes.includes(t)))   suggestedTier = 'free';
      else if (place.types.some(t => budgetTypes.includes(t))) suggestedTier = '$';
      else if (place.types.some(t => upscaleTypes.includes(t)))suggestedTier = '$$$';
      else if (place.types.some(t => midTypes.includes(t)))    suggestedTier = '$$';
      if (suggestedTier && !document.getElementById('hidden-price-tier').value) {
        const tierBtn = document.querySelector(`.price-tier-btn:not(.edit-price-tier-btn)[data-tier="${suggestedTier}"]`);
        if (tierBtn) selectPriceTier(tierBtn);
      }
    }

    if(place.opening_hours?.periods) {
      const days=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
      ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'].forEach(d=>{
        const cb=document.querySelector(`input[name="hours_${d}_closed"]`), row=document.getElementById(`hours-row-${d}`);
        if(cb) cb.checked=true; if(row) row.style.display='none';
      });
      place.opening_hours.periods.forEach(period=>{
        const dayName=days[period.open.day];
        const openInput=document.querySelector(`input[name="hours_${dayName}_open"]`), closeInput=document.querySelector(`input[name="hours_${dayName}_close"]`), closedCb=document.querySelector(`input[name="hours_${dayName}_closed"]`), row=document.getElementById(`hours-row-${dayName}`);
        if(closedCb) closedCb.checked=false; if(row) row.style.display='flex';
        if(period.close) {
          const oh=String(period.open.hours).padStart(2,'0'), om=String(period.open.minutes||0).padStart(2,'0'), ch=String(period.close.hours).padStart(2,'0'), cm=String(period.close.minutes||0).padStart(2,'0');
          if(openInput) openInput.value=`${oh}:${om}`; if(closeInput) closeInput.value=`${ch}:${cm}`;
        } else { if(openInput) openInput.value='00:00'; if(closeInput) closeInput.value='23:59'; }
      });
      window._hoursAutoFilled=true;
    }
    if(place.photos&&place.photos.length>0) {
      const photoUrl=place.photos[0].getUrl({maxWidth:800,maxHeight:600});
      window._googlePhotoUrl=photoUrl;
      document.getElementById('hidden-photo-url').value=photoUrl;
      showPlaceCard(place,photoUrl);
    } else showPlaceCard(place,null);
  }

  function showPlaceCard(place,photoUrl) {
    const card=document.getElementById('addr-enrichment-card'), inner=document.getElementById('addr-card-inner');
    const typeMap={restaurant:'Restaurant',cafe:'Café',park:'Park',museum:'Museum',bar:'Bar',store:'Shop',lodging:'Hotel',school:'School',hospital:'Hospital',church:'Church',gym:'Gym'};
    const placeType=place.types?.find(t=>typeMap[t])||place.types?.[0]||'location', typeLabel=typeMap[placeType]||placeType.replace(/_/g,' ');
    document.getElementById('addr-type-badge').textContent=typeLabel;
    document.getElementById('addr-street').textContent=place.name||'';
    document.getElementById('addr-city').textContent=place.formatted_address||place.vicinity||'';
    document.getElementById('addr-description').textContent=place.editorial_summary?.overview||'';
    const factEl=document.getElementById('addr-fun-fact');
    if(place.rating){factEl.textContent=`⭐ ${place.rating} Google rating`;factEl.style.display='block';}else factEl.style.display='none';
    if(place.geometry?.location){
      const lat=place.geometry.location.lat(),lng=place.geometry.location.lng();
      document.getElementById('addr-coords').innerHTML=`${lat.toFixed(4)}°N<br>${lng.toFixed(4)}°W`;
      document.getElementById('addr-map-link').href=`https://www.google.com/maps/@${lat},${lng},17z`;
    }
    if(photoUrl){
      window._googlePhotoUrl=photoUrl;
      const previewImg=document.getElementById('photo-preview-img'), previewWrap=document.getElementById('photo-preview-wrap'), placeholder=document.getElementById('photo-placeholder');
      if(previewImg){previewImg.src=photoUrl;previewWrap.style.display='block';placeholder.style.display='none';document.getElementById('photo-filename').textContent='Photo from Google Places';document.getElementById('photo-filename').style.display='block';}
      inner.style.backgroundImage=`linear-gradient(to right, rgba(0,0,0,0.85), rgba(0,0,0,0.6)), url(${photoUrl})`;
      inner.style.backgroundSize='cover'; inner.style.backgroundPosition='center';
    }
    card.style.display='block'; card.style.opacity='0'; card.style.transform='translateY(8px)';
    requestAnimationFrame(()=>{ card.style.transition='opacity 0.4s ease, transform 0.4s cubic-bezier(0.23,1,0.32,1)'; card.style.opacity='1'; card.style.transform='translateY(0)'; });
    showAutoFillBadge();
  }

  function showAutoFillBadge() {
    let badge=document.getElementById('autofill-badge');
    if(!badge){
      badge=document.createElement('div'); badge.id='autofill-badge';
      badge.style.cssText='display:inline-flex;align-items:center;gap:5px;font-size:0.55rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(74,222,128,0.8);margin-bottom:12px;padding:4px 10px;border-radius:999px;background:rgba(74,222,128,0.08);border:1px solid rgba(74,222,128,0.2);';
      badge.innerHTML='<span style="width:5px;height:5px;border-radius:50%;background:rgb(74,222,128);"></span> Auto-filled from Google';
      const step=document.getElementById('step-0'); step.insertBefore(badge,step.firstChild);
    }
  }

  async function enrichAndShow(geo) {
    document.getElementById('addr-spinner').style.display='block';
    try {
      const res=await fetch('/api/address-enrich',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({address:geo.formatted,lat:geo.lat,lng:geo.lng})});
      const info=await res.json(); showEnrichmentCard(geo,info);
      const descEl=document.getElementById('input-description');
      if(descEl&&!descEl.value&&info.description){descEl.value=info.description;descEl.style.borderColor='rgba(232,222,208,0.25)';}
    } catch { showEnrichmentCard(geo,{}); }
    document.getElementById('addr-spinner').style.display='none';
  }

  function showEnrichmentCard(geo,info) {
    const card=document.getElementById('addr-enrichment-card'), parts=(geo.formatted||'').split(',');
    document.getElementById('addr-street').textContent=parts[0]||geo.formatted;
    document.getElementById('addr-city').textContent=parts.slice(1).join(',').trim();
    document.getElementById('addr-type-badge').textContent=info.type||'Location';
    document.getElementById('addr-description').textContent=info.description||'';
    const factEl=document.getElementById('addr-fun-fact');
    if(info.fun_fact){factEl.textContent='✦ '+info.fun_fact;factEl.style.display='block';}else factEl.style.display='none';
    if(geo.lat){
      document.getElementById('hidden-lat').value=geo.lat; document.getElementById('hidden-lng').value=geo.lng;
      document.getElementById('addr-coords').innerHTML=`${geo.lat.toFixed(4)}°N<br>${geo.lng.toFixed(4)}°W`;
      document.getElementById('addr-map-link').href=`https://www.google.com/maps/@${geo.lat},${geo.lng},17z`;
    } else document.getElementById('addr-coords').textContent='';
    if(info.neighborhood) document.getElementById('hidden-neighborhood').value=info.neighborhood;
    card.style.display='block'; card.style.opacity='0'; card.style.transform='translateY(8px)';
    requestAnimationFrame(()=>{ card.style.transition='opacity 0.4s ease, transform 0.4s cubic-bezier(0.23,1,0.32,1)'; card.style.opacity='1'; card.style.transform='translateY(0)'; });
  }

  function hideEnrichmentCard() { document.getElementById('addr-enrichment-card').style.display='none'; }

  let switcherOpen=false;
  function toggleSwitcher() {
    switcherOpen=!switcherOpen;
    const menu=document.getElementById('switcher-menu'), arrow=document.getElementById('switcher-arrow');
    menu.style.opacity=switcherOpen?'1':'0';
    menu.style.transform=switcherOpen?'scale(1) translateY(0)':'scale(0.92) translateY(6px)';
    menu.style.pointerEvents=switcherOpen?'all':'none';
    arrow.style.transform=switcherOpen?'rotate(180deg)':'rotate(0deg)';
  }

  document.addEventListener('click', e => {
    if(switcherOpen&&!document.getElementById('borough-switcher').contains(e.target)){
      switcherOpen=false; toggleSwitcher();
    }
  });
</script>
</body>
</html>