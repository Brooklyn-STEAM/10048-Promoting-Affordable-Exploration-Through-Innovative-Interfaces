<!DOCTYPE html>
<html lang="en">
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{ borough.name | capitalize }} — Borough Selector</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Archivo:wght@300;400;500&display=swap" rel="stylesheet">

  <style>
    :root {
      --accent: {{ borough.accent }};
      --borough-color: {{ borough.color }};
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Archivo', sans-serif;
      background-color: {{ borough.color }};
      color: #e8ded0;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 200;
      opacity: 0.3;
    }

    h1 {
      font-family: 'Archivo', sans-serif;
      font-weight: 500;
      letter-spacing: 0.3em;
      font-size: 0.75rem;
    }

    .borough-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      font-size: clamp(4rem, 12vw, 9rem);
      line-height: 1;
      text-transform: capitalize;
      letter-spacing: -0.02em;
    }

    .back-link {
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(232,222,208,0.4);
      text-decoration: none;
      transition: color 0.2s;
    }
    .back-link:hover { color: #e8ded0; }

    .nav-link {
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(232,222,208,0.35);
      text-decoration: none;
    }

    .divider {
      width: 40px;
      height: 1px;
      background: var(--accent);
      margin: 2rem 0;
      opacity: 0.6;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up  { animation: fadeUp 0.5s ease both; }
    .delay-1  { animation-delay: 0.1s; }
    .delay-2  { animation-delay: 0.2s; }
    .delay-3  { animation-delay: 0.3s; }
  </style>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>{{ borough.name | capitalize }} — Borough Selector</title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Archivo:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --accent: {{ borough.accent }};
  --borough-color: {{ borough.color }};
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'Archivo', sans-serif;
  background-color: {{ borough.color }};
  color: #e8ded0;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}
body::before {
  content: '';
  position: fixed; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 200;
  opacity: 0.3;
}
h1 {
  font-family: 'Archivo', sans-serif;
  font-weight: 500;
  letter-spacing: 0.3em;
  font-size: 0.75rem;
}
.borough-title {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 300;
  font-size: clamp(4rem, 12vw, 9rem);
  line-height: 1;
  text-transform: capitalize;
  letter-spacing: -0.02em;
}
.back-link {
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(232,222,208,0.4);
  text-decoration: none;
  transition: color 0.2s;
}
.back-link:hover { color: #e8ded0; }
.nav-link {
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(232,222,208,0.35);
  text-decoration: none;
}
.divider {
  width: 40px;
  height: 1px;
  background: var(--accent);
  margin: 2rem 0;
  opacity: 0.6;
}
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}
.fade-up  { animation: fadeUp 0.5s ease both; }
.delay-1  { animation-delay: 0.1s; }
.delay-2  { animation-delay: 0.2s; }
.delay-3  { animation-delay: 0.3s; }
</style>
</head>
<body class="p-8" style="height:100vh;">

{% include '_nav.html.jinja' %}

<div class="flex items-center  fade-up">
  <a href="/browse"><h1>Hidden Gems</h1></a>
  <a href="/browse" class="back-link text-lg ml-4">← Back</a>
</div>

<div style="flex:1; display:flex; align-items:center;">
  <div class="fade-up delay-1">
    <p class="borough-title">{{ borough.name }}</p>
    
    <div class="divider"></div>
    
    <p style="font-size:0.65rem; letter-spacing:0.2em; text-transform:uppercase; opacity:0.4;">New York City</p>
  </div>
  <div class="ml-60">
  <button 
  id="open-popup"
  class="group relative inline-flex items-center justify-center 
         px-6 py-3 text-[16px] font-medium 
         bg-[{{ borough.accent_dark }}] text-[#111] border-2 border-[#111]
         rounded-lg cursor-pointer transition-all duration-200
         active:bg-[{{ borough.accent }}]"
>
  <span class="relative z-10">Add Someone's Next Adventure</span>

  <span
    class="absolute inset-0 rounded-lg bg-[#111] 
           translate-x-2 translate-y-2 
           transition-transform duration-200 
           group-hover:translate-x-0 group-hover:translate-y-0
           -z-10"
  ></span>
</button>

</div>
<!-- POPUP -->
<div id="popup"
     class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center
            opacity-0 pointer-events-none transition-opacity duration-300 z-[9999]">

  <div id="popup-content"
       class="relative group w-[420px] scale-95 transition-transform duration-300">

    <!-- Main Card -->
    <div class="relative z-10 bg-[#e8ded0] text-[#111] p-8 rounded-xl border-2 border-[#111]">

      <h2 class="text-2xl font-serif mb-6 tracking-wide"
          style="font-family: 'Cormorant Garamond', serif;">
        Add an Adventure
      </h2>

      <form class="space-y-5">

        <div>
          <label class="block mb-1 text-xs tracking-wider uppercase opacity-70">Business Name</label>
          <input type="text"
                 class="w-full border border-[#111] px-3 py-2 rounded bg-transparent focus:outline-none" />
        </div>

        <div>
          <label class="block mb-1 text-xs tracking-wider uppercase opacity-70">Location</label>
          <textarea class="w-full border border-[#111] px-3 py-2 rounded bg-transparent focus:outline-none"></textarea>
        </div>

        <div>
          <label class="block mb-1 text-xs tracking-wider uppercase opacity-70">Description</label>
          <textarea class="w-full border border-[#111] px-3 py-2 rounded bg-transparent focus:outline-none"></textarea>
        </div>

        <div>
          <label class="block mb-1 text-xs tracking-wider uppercase opacity-70">Place Image</label>
          <input type="file"
                 accept="image/*"
                 class="w-full border border-[#111] px-3 py-2 rounded bg-[#e8ded0]" />
        </div>

        <div>
          <label class="block mb-1 text-xs tracking-wider uppercase opacity-70">
            Business Logo <span class="opacity-50">(optional)</span>
          </label>
          <input type="file"
                 accept="image/*"
                 class="w-full border border-[#111] px-3 py-2 rounded bg-[#e8ded0]" />
        </div>

        <button type="submit"
                class="bg-[{{ borough.accent_dark }}] text-[#111] border-2 border-[#111]
                       px-4 py-2 rounded-lg font-medium tracking-wide
                       hover:bg-[{{ borough.accent }}] transition">
          Submit
        </button>

      </form>

      <button id="close-popup"
              class="mt-6 text-sm underline opacity-70 hover:opacity-100 transition">
        Close
      </button>
    </div>

    <!-- Offset Shadow Block -->
    <span class="absolute inset-0 bg-[#111] rounded-xl translate-x-3 translate-y-3 -z-10"></span>

  </div>
</div>

</div>

</div>



</body>

<script>
const openBtn = document.getElementById("open-popup");
const closeBtn = document.getElementById("close-popup");
const popup = document.getElementById("popup");
const popupContent = document.getElementById("popup-content");

openBtn.addEventListener("click", () => {
  popup.classList.remove("opacity-0", "pointer-events-none");
  popupContent.classList.remove("scale-95");
});

closeBtn.addEventListener("click", () => {
  popup.classList.add("opacity-0", "pointer-events-none");
  popupContent.classList.add("scale-95");
});

popup.addEventListener("click", (e) => {
  if (e.target === popup) {
    popup.classList.add("opacity-0", "pointer-events-none");
    popupContent.classList.add("scale-95");
  }
});
</script>



</html>
