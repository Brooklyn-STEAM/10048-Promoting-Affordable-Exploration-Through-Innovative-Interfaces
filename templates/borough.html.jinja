            {% set days = ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"] %}
            {% for d in days %}
            <div style="padding:10px 12px;background:rgba(232,222,208,0.03);border-bottom:1px solid rgba(232,222,208,0.05);">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
                <span style="font-size:0.65rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(232,222,208,0.35);">{{ d }}</span>
                <label style="display:flex;align-items:center;gap:5px;cursor:pointer;">
                  <input type="checkbox" name="edit_hours_{{ d }}_closed" id="edit-closed-{{ d }}" style="accent-color:var(--accent);width:14px;height:14px;" onchange="toggleEditClosed('{{ d }}')">
                  <span style="font-size:0.6rem;color:rgba(232,222,208,0.25);">Closed</span>
                </label>
              </div>
              <div id="edit-hours-row-{{ d }}" class="hours-row-inner" style="display:flex;align-items:center;gap:6px;">
                <input type="time" name="edit_hours_{{ d }}_open" id="edit-open-{{ d }}" style="
                  flex:1;background:rgba(232,222,208,0.06);border:1px solid rgba(232,222,208,0.1);
                  border-radius:8px;padding:7px 8px;color:rgba(232,222,208,0.7);
                  font-size:0.8rem;font-family:inherit;outline:none;min-width:0;color-scheme:dark;
                ">
                <span style="color:rgba(232,222,208,0.2);font-size:0.7rem;flex-shrink:0;">–</span>
                <input type="time" name="edit_hours_{{ d }}_close" id="edit-close-{{ d }}" style="
                  flex:1;background:rgba(232,222,208,0.06);border:1px solid rgba(232,222,208,0.1);
                  border-radius:8px;padding:7px 8px;color:rgba(232,222,208,0.7);
                  font-size:0.8rem;font-family:inherit;outline:none;min-width:0;color-scheme:dark;
                ">
              </div>
            </div>
            {% endfor %}
          </div>
        </div>

      </div>

      <!-- Footer -->
      <div style="padding:14px 22px;border-top:1px solid rgba(232,222,208,0.06);display:flex;gap:10px;flex-shrink:0;background:rgba(0,0,0,0.2);">
        <button type="button" onclick="closeEditModal()" style="
          padding:12px 18px;border-radius:12px;
          background:rgba(232,222,208,0.06);border:1px solid rgba(232,222,208,0.12);
          color:rgba(232,222,208,0.5);font-size:0.7rem;font-family:inherit;
          cursor:pointer;letter-spacing:0.12em;text-transform:uppercase;
          transition:all 0.2s;-webkit-tap-highlight-color:transparent;
        ">Cancel</button>
        <button type="submit" form="edit-location-form" style="
          flex:1;padding:14px;border-radius:12px;
          background:var(--accent);border:none;
          color:white;font-size:0.8rem;font-family:inherit;
          cursor:pointer;letter-spacing:0.15em;text-transform:uppercase;font-weight:600;
          transition:opacity 0.2s, transform 0.15s;-webkit-tap-highlight-color:transparent;
        ">Save Changes ✦</button>
      </div>

    </form>
  </div>
</div>

<!-- ── Delete Modal ── -->
<div id="delete-modal" style="display:none;position:fixed;inset:0;z-index:500;background:rgba(0,0,0,0.6);backdrop-filter:blur(8px);align-items:center;justify-content:center;padding:24px;">
  <div style="background:#111;border:1px solid rgba(232,222,208,0.12);border-radius:20px;padding:28px 24px;width:100%;max-width:360px;display:flex;flex-direction:column;align-items:center;">
    <div style="width:48px;height:48px;border-radius:50%;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);display:flex;align-items:center;justify-content:center;margin-bottom:20px;">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M8 4h4M3 6h14M5 6l1 10a2 2 0 002 2h4a2 2 0 002-2l1-10" stroke="rgba(239,68,68,0.9)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <p class="serif" style="font-size:1.4rem;font-weight:300;color:#e8ded0;margin-bottom:8px;text-align:center;line-height:1.2;">Remove this location?</p>
    <p style="font-size:0.75rem;color:rgba(232,222,208,0.4);text-align:center;line-height:1.6;margin-bottom:24px;">This can't be undone. The location and all its data will be permanently deleted.</p>
    <div style="display:flex;flex-direction:column;gap:8px;width:100%;">
      <button id="delete-confirm-btn" style="width:100%;padding:13px;border-radius:10px;background:rgba(239,68,68,0.15);border:1px solid rgba(239,68,68,0.3);color:rgb(239,68,68);font-size:0.7rem;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;cursor:pointer;font-family:inherit;">Yes, remove it</button>
      <button onclick="closeDeleteModal()" style="width:100%;padding:13px;border-radius:10px;background:rgba(232,222,208,0.05);border:1px solid rgba(232,222,208,0.12);color:rgba(232,222,208,0.5);font-size:0.7rem;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;cursor:pointer;font-family:inherit;">Cancel</button>
    </div>
  </div>
</div>

<!-- ── Borough Switcher ── -->
<div id="borough-switcher" style="position:fixed;bottom:24px;left:16px;z-index:50;">
  <button onclick="toggleSwitcher()"
    style="display:flex;align-items:center;gap:8px;padding:8px 16px;border-radius:999px;background:rgba(0,0,0,0.35);border:1px solid rgba(232,222,208,0.15);color:rgba(232,222,208,0.5);font-size:0.55rem;letter-spacing:0.25em;text-transform:uppercase;cursor:pointer;backdrop-filter:blur(8px);transition:all 0.2s;font-family:inherit;-webkit-tap-highlight-color:transparent;"
    onmouseover="this.style.color='#e8ded0';this.style.borderColor='rgba(232,222,208,0.3)'"
    onmouseout="this.style.color='rgba(232,222,208,0.5)';this.style.borderColor='rgba(232,222,208,0.15)'">
    <span style="width:5px;height:5px;border-radius:50%;background:var(--accent);flex-shrink:0;"></span>
    {{ borough.name }}
    <span id="switcher-arrow" style="transition:transform 0.25s;opacity:0.4;">▴</span>
  </button>
  <div id="switcher-menu" style="position:absolute;bottom:calc(100% + 8px);left:0;background:rgba(10,10,10,0.92);border:1px solid rgba(232,222,208,0.1);border-radius:14px;overflow:hidden;backdrop-filter:blur(12px);min-width:160px;transform-origin:bottom left;transform:scale(0.92) translateY(6px);opacity:0;pointer-events:none;transition:all 0.2s cubic-bezier(0.23,1,0.32,1);">
    {% set all_boroughs = [
      {"name": "manhattan",     "color": "#1a3a5c", "accent": "#2e6da4"},
      {"name": "brooklyn",      "color": "#5c3a1a", "accent": "#a4642e"},
      {"name": "queens",        "color": "#1a5c3a", "accent": "#2ea464"},
      {"name": "bronx",         "color": "#2a2a2a", "accent": "#555555"},
      {"name": "staten island", "color": "#3a3328", "accent": "#7a6a50"},
    ] %}
    {% for b in all_boroughs %}
    <a href="/borough/{{ b.name | replace(' ', '-') }}"
       style="display:flex;align-items:center;gap:10px;padding:12px 16px;text-decoration:none;font-size:0.6rem;letter-spacing:0.18em;text-transform:uppercase;transition:background 0.15s;color:{{ 'rgba(232,222,208,0.9)' if b.name == borough.name else 'rgba(232,222,208,0.4)' }};background:{{ 'rgba(232,222,208,0.06)' if b.name == borough.name else 'transparent' }};"
       onmouseover="this.style.background='rgba(232,222,208,0.08)';this.style.color='#e8ded0'"
       onmouseout="this.style.background='{{ 'rgba(232,222,208,0.06)' if b.name == borough.name else 'transparent' }}';this.style.color='{{ 'rgba(232,222,208,0.9)' if b.name == borough.name else 'rgba(232,222,208,0.4)' }}'">
      <span style="width:4px;height:4px;border-radius:50%;flex-shrink:0;background:{{ 'var(--accent)' if b.name == borough.name else 'rgba(232,222,208,0.2)' }};"></span>
      {{ b.name }}
      {% if b.name == borough.name %}<span style="margin-left:auto;font-size:0.5rem;opacity:0.4;">current</span>{% endif %}
    </a>
    {% endfor %}
  </div>
</div>

<script>
  const locations = {{ locations_json | safe }};
  const BOROUGH_SLUG = '{{ borough.name | replace(" ", "-") }}';

  // ── Responsive carousel config ──
  function getVisibleCount() {
    if (window.innerWidth < 640)  return 1;
    if (window.innerWidth < 768)  return 2;
    return 3;
  }

  async function toggleLike(btn) {
    const id = btn.dataset.id, borough = btn.dataset.borough;
    const res = await fetch(`/borough/${borough}/like/${id}`, { method: 'POST' });
    const data = await res.json();
    btn.dataset.liked = data.liked ? 'true' : 'false';
    btn.querySelector('.like-heart').textContent = data.liked ? '♥' : '♡';
    btn.querySelector('.like-count').textContent = data.count;
    btn.style.color = data.liked ? 'var(--accent)' : 'rgba(232,222,208,0.3)';
    if (document.getElementById('lightbox').style.display === 'flex') {
      const loc = locations[lbIndex];
      if (loc && String(loc.ID) === String(id)) {
        loc.LikeCount = data.count; loc.Liked = data.liked;
        document.getElementById('lb-like-count').textContent = data.count;
        document.getElementById('lb-heart').textContent = data.liked ? '♥' : '♡';
        document.getElementById('lb-like-btn').style.color = data.liked ? 'var(--accent)' : '#e8ded0';
      }
    }
  }

  async function toggleLikeById() {
    const loc = locations[lbIndex]; if (!loc) return;
    const res = await fetch(`/borough/${BOROUGH_SLUG}/like/${loc.ID}`, { method: 'POST' });
    const data = await res.json();
    loc.Liked = data.liked; loc.LikeCount = data.count;
    document.getElementById('lb-like-count').textContent = data.count;
    document.getElementById('lb-heart').textContent = data.liked ? '♥' : '♡';
    document.getElementById('lb-like-btn').style.color = data.liked ? 'var(--accent)' : '#e8ded0';
    const btn = document.querySelector(`.like-btn[data-id="${loc.ID}"]`);
    if (btn) { btn.dataset.liked = data.liked ? 'true' : 'false'; btn.querySelector('.like-heart').textContent = data.liked ? '♥' : '♡'; btn.querySelector('.like-count').textContent = data.count; btn.style.color = data.liked ? 'var(--accent)' : 'rgba(232,222,208,0.3)'; }
  }

  // ── Category selection (add modal) ──
  function selectCategory(btn) {
    document.querySelectorAll('#category-buttons .category-btn').forEach(b => {
      b.classList.remove('selected');
      b.style.background = 'rgba(232,222,208,0.05)';
      b.style.borderColor = 'rgba(232,222,208,0.12)';
      b.style.color = 'rgba(232,222,208,0.6)';
    });
    btn.classList.add('selected');
    btn.style.background = 'rgba(var(--accent-rgb), 0.15)';
    btn.style.borderColor = 'var(--accent)';
    btn.style.color = '#e8ded0';
    document.getElementById('hidden-category').value = btn.dataset.cat;
  }

  // ── Category selection (edit modal) ──
  function selectEditCategory(btn) {
    document.querySelectorAll('#edit-category-buttons .edit-category-btn').forEach(b => {
      b.classList.remove('selected');
      b.style.background = 'rgba(232,222,208,0.05)';
      b.style.borderColor = 'rgba(232,222,208,0.12)';
      b.style.color = 'rgba(232,222,208,0.6)';
    });
    btn.classList.add('selected');
    btn.style.background = 'rgba(var(--accent-rgb), 0.15)';
    btn.style.borderColor = 'var(--accent)';
    btn.style.color = '#e8ded0';
    document.getElementById('edit-hidden-category').value = btn.dataset.cat;
  }

  // ── Featured carousel ──
  let featIndex = 0;
  const featTotal = locations.length;

  function buildFeatDots() {
    const VISIBLE = getVisibleCount();
    const dotsEl = document.getElementById('feat-dots'); if (!dotsEl) return;
    dotsEl.innerHTML = '';
    const pages = Math.max(1, featTotal - VISIBLE + 1);
    for (let i = 0; i < pages; i++) {
      const d = document.createElement('div');
      d.style.cssText = `width:6px;height:6px;border-radius:50%;cursor:pointer;background:${i===featIndex?'var(--accent)':'rgba(232,222,208,0.2)'};transition:background 0.2s;`;
      d.onclick = () => { featIndex = i; updateFeatSlide(); };
      dotsEl.appendChild(d);
    }
  }

  function updateFeatSlide() {
    const VISIBLE = getVisibleCount();
    const track = document.getElementById('feat-track'); if (!track) return;
    track.style.transform = `translateX(-${(100/VISIBLE)*featIndex}%)`;
    const maxIndex = Math.max(0, featTotal - VISIBLE);
    document.getElementById('feat-prev').style.opacity = featIndex > 0 ? '1' : '0.25';
    document.getElementById('feat-next').style.opacity = featIndex < maxIndex ? '1' : '0.25';
    buildFeatDots();
  }

  function featStep(dir) {
    const VISIBLE = getVisibleCount();
    featIndex = Math.max(0, Math.min(featIndex + dir, Math.max(0, featTotal - VISIBLE)));
    updateFeatSlide();
  }

  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => { featIndex = 0; updateFeatSlide(); }, 150);
  });

  window.addEventListener('load', () => { buildFeatDots(); updateFeatSlide(); });

  // ── Touch swipe for featured carousel ──
  (function() {
    let touchStartX = 0;
    const overflow = document.getElementById('feat-overflow');
    if (!overflow) return;
    overflow.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
    overflow.addEventListener('touchend',   e => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 40) featStep(dx < 0 ? 1 : -1);
    }, { passive: true });
  })();

  // ── Touch swipe for lightbox ──
  (function() {
    let touchStartX = 0;
    const lb = document.getElementById('lightbox');
    lb.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
    lb.addEventListener('touchend', e => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 50) lbStep(dx < 0 ? 1 : -1);
    }, { passive: true });
  })();

  // ── Search ──
  const featuredSection = document.querySelector('.fade-up.d1');

  function filterLocations(val) {
    const q = val.trim().toLowerCase();
    const clearBtn  = document.getElementById('loc-search-clear');
    const countEl   = document.getElementById('loc-search-count');
    const noResults = document.getElementById('no-results');
    clearBtn.style.display = val ? 'block' : 'none';

    if (q) {
      if (featuredSection) {
        featuredSection.style.transition = 'opacity 0.2s ease';
        featuredSection.style.opacity = '0';
        featuredSection.style.pointerEvents = 'none';
        featuredSection.style.height = '0';
        featuredSection.style.overflow = 'hidden';
        featuredSection.style.marginBottom = '0';
      }

      const allSection = document.getElementById('all-locations-section');
      if (allSection) allSection.style.display = 'block';

      const gemGrid = document.getElementById('gem-grid');

      document.querySelectorAll('.search-injected-card').forEach(el => el.remove());

      const featuredCount = Math.min(3, locations.length);
      locations.slice(0, featuredCount).forEach((loc, i) => {
        if (!locMatches(loc, q)) return;
        const div = document.createElement('div');
        div.className = 'gem-card search-injected-card';
        div.dataset.index = i;
        div.onclick = () => openDetail(i);
        const imgSrc = loc.Image
          ? (loc.Image.startsWith('http') ? loc.Image : `/static/uploads/${loc.Image}`)
          : null;
        const imgHtml = imgSrc
          ? `<img src="${imgSrc}" alt="${loc.Name}">`
          : `<div class="no-img"></div>`;
        const tierLabels = { free: '○ Free', '$': '$ Budget', '$$': '$$ Mid-range', '$$$': '$$$ Upscale' };
        const priceHtml = loc.PriceTier
          ? `<p class="gem-meta" style="margin-top:3px;">${tierLabels[loc.PriceTier] || ''}</p>`
          : '';
        div.innerHTML = `
          ${imgHtml}
          <div class="gem-info" style="display:flex;align-items:flex-start;justify-content:space-between;">
            <div style="min-width:0;flex:1;margin-right:8px;">
              <p class="gem-title" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${loc.Name}</p>
              <p class="gem-meta">${loc.DatePosted || ''}</p>
              ${priceHtml}
            </div>
          </div>`;
        if (gemGrid) gemGrid.prepend(div);
      });

      let gemVisible = 0;
      document.querySelectorAll('#gem-grid .gem-card:not(.search-injected-card)').forEach(card => {
        const idx = parseInt(card.dataset.index, 10);
        const loc = locations[idx];
        const match = locMatches(loc, q);
        card.style.display = match ? '' : 'none';
        if (match) gemVisible++;
      });

      const injectedCount = document.querySelectorAll('#gem-grid .search-injected-card').length;
      const total = injectedCount + gemVisible;

      countEl.textContent = `${total} result${total !== 1 ? 's' : ''} for "${val}"`;
      if (noResults) noResults.style.display = total === 0 ? 'block' : 'none';

    } else {
      if (featuredSection) {
        featuredSection.style.height = '';
        featuredSection.style.overflow = '';
        featuredSection.style.marginBottom = '';
        featuredSection.style.pointerEvents = '';
        requestAnimationFrame(() => { featuredSection.style.opacity = '1'; });
      }

      document.querySelectorAll('.search-injected-card').forEach(el => el.remove());

      document.querySelectorAll('#gem-grid .gem-card').forEach(card => {
        card.style.display = '';
      });

      const allSection = document.getElementById('all-locations-section');
      if (allSection && locations.length <= 3) allSection.style.display = 'none';

      countEl.textContent = '';
      if (noResults) noResults.style.display = 'none';
    }
  }

  function locMatches(loc, q) {
    if (!loc) return false;
    return (loc.Name        || '').toLowerCase().includes(q) ||
           (loc.Description || '').toLowerCase().includes(q) ||
           (loc.Category    || '').toLowerCase().includes(q) ||
           (loc.Address     || '').toLowerCase().includes(q) ||
           (loc.Type        || '').toLowerCase().includes(q);
  }

  function clearLocSearch() {
    const input = document.getElementById('loc-search');
    input.value = '';
    filterLocations('');
    input.focus();
  }

  // ── Lightbox ──
  let lbIndex = 0;
  const lbTotal = locations.length;
  let lbAnimating = false;

  function openDetail(index) {
    lbIndex = index; renderLightbox();
    const lb = document.getElementById('lightbox'), card = document.getElementById('lb-card');
    lb.classList.remove('hidden'); lb.style.display = 'flex';
    lb.classList.add('lb-open','lb-animating-in'); card.classList.add('lb-animating-in');
    lb.addEventListener('animationend',   () => lb.classList.remove('lb-animating-in'),   { once: true });
    card.addEventListener('animationend', () => card.classList.remove('lb-animating-in'), { once: true });
    document.body.style.overflow = 'hidden';
    document.addEventListener('keydown', lbKeyHandler);
  }

  function renderLightbox() {
    const loc = locations[lbIndex]; if (!loc) return;
    const openStatus = document.getElementById('lb-open-status');
    let isOpen = false;
    if (loc.Hours && Array.isArray(loc.Hours)) {
      const today = loc.Hours[[6,0,1,2,3,4,5][new Date().getDay()]];
      if (today && today.hours && today.hours !== "Closed") {
        const [os, cs] = today.hours.split(" – ");
        const now = new Date();
        const ot = new Date(); ot.setHours(...os.split(":").map(Number), 0);
        const ct = new Date(); ct.setHours(...cs.split(":").map(Number), 0);
        if (now >= ot && now <= ct) isOpen = true;
      }
    }
    openStatus.style.cssText = isOpen
      ? "display:inline-flex;align-items:center;gap:4px;color:rgb(74,222,128);border-color:rgba(74,222,128,0.3);background:rgba(74,222,128,0.1);border-radius:2px;padding:2px 10px;font-size:9px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;"
      : "display:inline-flex;align-items:center;gap:4px;color:rgb(239,68,68);border-color:rgba(239,68,68,0.3);background:rgba(239,68,68,0.1);border-radius:2px;padding:2px 10px;font-size:9px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;";
    openStatus.innerHTML = isOpen
      ? `<span style="width:6px;height:6px;border-radius:50%;background:rgb(74,222,128);flex-shrink:0;"></span>Open now`
      : `<span style="width:6px;height:6px;border-radius:50%;background:rgb(239,68,68);flex-shrink:0;"></span>Closed`;

    const priceBadge = document.getElementById('lb-price-badge');
    const priceNoteWrap = document.getElementById('lb-price-note-wrap');
    const priceNoteEl = document.getElementById('lb-price-note');
    if (loc.PriceTier) {
      const tierLabels = { free: '○ Free', '$': '$ Budget', '$$': '$$ Mid-range', '$$$': '$$$ Upscale' };
      const tierColors = { free: 'rgba(74,222,128,0.15)', '$': 'rgba(232,222,208,0.08)', '$$': 'rgba(255,183,77,0.12)', '$$$': 'rgba(180,130,255,0.12)' };
      const tierBorder = { free: 'rgba(74,222,128,0.3)', '$': 'rgba(232,222,208,0.2)', '$$': 'rgba(255,183,77,0.3)', '$$$': 'rgba(180,130,255,0.3)' };
      const tierText   = { free: 'rgb(74,222,128)', '$': 'rgba(232,222,208,0.7)', '$$': 'rgb(255,183,77)', '$$$': 'rgb(200,160,255)' };
      priceBadge.textContent = tierLabels[loc.PriceTier] || loc.PriceTier;
      priceBadge.style.display = 'inline-flex';
      priceBadge.style.background = tierColors[loc.PriceTier] || 'rgba(232,222,208,0.06)';
      priceBadge.style.borderColor = tierBorder[loc.PriceTier] || 'rgba(232,222,208,0.15)';
      priceBadge.style.color = tierText[loc.PriceTier] || 'rgba(232,222,208,0.6)';
    } else {
      priceBadge.textContent = '? Price unknown';
      priceBadge.style.display = 'inline-flex';
      priceBadge.style.background = 'rgba(232,222,208,0.04)';
      priceBadge.style.borderColor = 'rgba(232,222,208,0.1)';
      priceBadge.style.color = 'rgba(232,222,208,0.25)';
    }

    if (loc.PriceNote) {
      priceNoteEl.textContent = loc.PriceNote;
      priceNoteWrap.style.display = 'block';
    } else {
      priceNoteWrap.style.display = 'none';
    }

    document.getElementById('lb-counter').textContent = `${lbIndex+1} / ${lbTotal}`;
    document.getElementById('lb-badge').textContent = loc.Type || ['Featured','Hidden gem','Local pick'][lbIndex] || 'Gem';
    
    // Show category with icon
    const categoryIcon = {
      'food': '🍔', 'entertainment': '🎭', 'arts': '🎨',
      'outdoors': '🌿', 'shopping': '🛍️', 'nightlife': '🌙',
      'cafe': '☕', 'wellness': '🧘'
    }[loc.Category] || '📍';
    document.getElementById('lb-type').innerHTML = `${categoryIcon} ${loc.Category || 'Location'}`;
    
    const addrText = document.getElementById('lb-addr-text'), mapLink = document.getElementById('lb-map-link');
    if (loc.Address) {
      addrText.textContent = loc.Address;
      mapLink.href = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(loc.Address+', New York City')}`;
      addrText.style.display = 'block'; mapLink.style.display = 'inline-flex';
    } else { addrText.style.display = 'none'; mapLink.style.display = 'none'; }

    document.getElementById('lb-title').textContent = loc.Name;
    document.getElementById('lb-meta').textContent  = `${loc.Borough||''} · ${loc.DatePosted||''}`;
