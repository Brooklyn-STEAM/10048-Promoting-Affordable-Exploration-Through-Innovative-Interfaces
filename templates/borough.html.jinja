    locations.forEach((_,i) => { const d=document.createElement('div'); d.style.cssText=`width:6px;height:6px;border-radius:50%;cursor:pointer;background:${i===lbIndex?'var(--accent)':'rgba(232,222,208,0.25)'};transition:background 0.2s;`; d.onclick=()=>{lbIndex=i;renderLightbox();}; dotsEl.appendChild(d); });
  }

  function formatHours(s) {
    if(!s||s==="Closed") return "Closed";
    const p=s.split(" – "); return p.length!==2?s:`${to12Hour(p[0])} – ${to12Hour(p[1])}`;
  }
  function to12Hour(t) {
    if (!t||!t.includes(":")) return t;
    let [h,m]=t.split(":").map(Number); const suf=h>=12?"PM":"AM"; h=(h%12)||12;
    return `${h}:${m.toString().padStart(2,"0")} ${suf}`;
  }

  function lbStep(dir) {
    if (lbAnimating) return;
    const next = lbIndex+dir; if (next<0||next>=lbTotal) return;
    lbAnimating = true;
    const card = document.getElementById('lb-card');
    const out = dir>0?'translateX(-60px)':'translateX(60px)', into = dir>0?'translateX(60px)':'translateX(-60px)';
    card.style.transition = 'opacity 0.18s ease, transform 0.18s ease';
    card.style.opacity = '0'; card.style.transform = out;
    setTimeout(() => {
      lbIndex=next; renderLightbox();
      card.style.transition='none'; card.style.transform=into; card.style.opacity='0';
      card.getBoundingClientRect();
      card.style.transition='opacity 0.22s ease, transform 0.22s cubic-bezier(0.23,1,0.32,1)';
      card.style.opacity='1'; card.style.transform='translateX(0)';
      setTimeout(()=>{card.style.pointerEvents='';lbAnimating=false;},220);
    }, 180);
  }

  function closeLightbox() {
    const lb=document.getElementById('lightbox'), card=document.getElementById('lb-card');
    lb.classList.add('lb-animating-out'); card.classList.add('lb-animating-out');
    lb.addEventListener('animationend',()=>{
      lb.classList.remove('lb-open','lb-animating-out'); card.classList.remove('lb-animating-out');
      lb.classList.add('hidden'); lb.style.display='';
      document.body.style.overflow=''; document.removeEventListener('keydown',lbKeyHandler);
    },{once:true});
  }

  function lbKeyHandler(e) { if(e.key==='ArrowRight')lbStep(1); if(e.key==='ArrowLeft')lbStep(-1); if(e.key==='Escape')closeLightbox(); }
  document.getElementById('lightbox').addEventListener('click',function(e){if(e.target===this)closeLightbox();});

