<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>{{ borough.name | capitalize }} — Hidden Gems</title>

<script src="https://cdn.tailwindcss.com"></script>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Archivo:wght@300;400;500&display=swap" rel="stylesheet">

<style>

:root{
  --accent: {{ borough.accent }};
  --borough-color: {{ borough.color }};
}

*{box-sizing:border-box;margin:0;padding:0;}

body{
  font-family:'Archivo',sans-serif;
  background-color:var(--borough-color);
  color:#e8ded0;
  min-height:100vh;
  display:flex;
  flex-direction:column;
  overflow:hidden;
}

h1{
  font-weight:500;
  letter-spacing:0.3em;
  font-size:0.75rem;
}

.borough-title{
  font-family:'Cormorant Garamond',serif;
  font-weight:300;
  font-size:clamp(3rem,8vw,6rem);
  line-height:1;
}

.back-link{
  font-size:0.6rem;
  letter-spacing:0.2em;
  text-transform:uppercase;
  color:rgba(232,222,208,0.4);
  text-decoration:none;
}

.back-link:hover{color:#e8ded0;}

.divider{
  width:40px;
  height:1px;
  background:var(--accent);
  margin:1.2rem 0;
  opacity:0.6;
}

.carousel-wrap{
  width:100%;
  overflow:hidden;
}

.carousel-track{
  display:flex;
  justify-content:center;
  gap:16px;
  padding:20px 0;
}

.card{
  border-radius:16px;
  overflow:hidden;
  cursor:pointer;
  transition:all .35s cubic-bezier(.23,1,.32,1);
  border:1px solid rgba(232,222,208,.15);
  position:relative;
}

.card.side{
  width:110px;
  height:120px;
  opacity:.45;
  transform:scale(.88);
}

.card.center{
  width:240px;
  height:180px;
  opacity:1;
  transform:scale(1);
  border-color:rgba(232,222,208,.3);
  box-shadow:0 20px 50px rgba(0,0,0,.4);
}

.card img{
  width:100%;
  height:100%;
  object-fit:cover;
}

.card-overlay{
  position:absolute;
  bottom:0;
  left:0;
  right:0;
  padding:10px 12px;
  background:linear-gradient(transparent,rgba(0,0,0,.75));
}

.card.side .card-overlay{display:none;}

.card-name{
  font-size:.78rem;
  font-weight:600;
  color:#fff;
}

.card-meta{
  font-size:.58rem;
  color:rgba(255,255,255,.6);
}

.detail-panel{
  max-width:280px;
  margin:0 auto;
  padding:14px 18px;
  background:rgba(0,0,0,.2);
  border-radius:12px;
  border:1px solid rgba(232,222,208,.1);
  display:none;
}

.detail-panel.open{display:block;}

.detail-name{
  font-family:'Cormorant Garamond',serif;
  font-size:1.2rem;
}

.detail-meta{
  font-size:.55rem;
  letter-spacing:.15em;
  text-transform:uppercase;
  opacity:.45;
  margin-bottom:6px;
}

.detail-desc{
  font-size:.72rem;
  opacity:.7;
}

.new-post-btn{
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding:10px 24px;
  border-radius:999px;
  border:1px solid rgba(232,222,208,.4);
  font-size:.6rem;
  letter-spacing:.2em;
  text-transform:uppercase;
  cursor:pointer;
}

.new-post-btn:hover{
  background:rgba(232,222,208,.08);
}

.new-post-btn .dot{
  width:6px;
  height:6px;
  border-radius:50%;
  background:var(--accent);
}

.modal-backdrop{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.5);
  backdrop-filter:blur(6px);
  display:none;
  align-items:center;
  justify-content:center;
}

.modal-backdrop.open{display:flex;}

.modal{
  background:#ece4d8;
  border-radius:20px;
  border:2px solid #1f1f1f;
  padding:28px;
  width:100%;
  max-width:400px;
  color:#2b2b2b;
}

.modal input,
.modal textarea{
  width:100%;
  padding:10px 14px;
  border-radius:12px;
  border:2px solid #1f1f1f;
  background:#f5efe6;
  margin-bottom:14px;
}

.modal-submit{
  width:100%;
  padding:12px;
  border-radius:12px;
  background:#2b2b2b;
  color:white;
  font-weight:600;
  cursor:pointer;
}

</style>
</head>

<body class="p-8">

{% include '_nav.html.jinja' %}

<!-- Header -->
<div class="flex items-center text-lg">
<a href="/browse"><h1>Hidden Gems</h1></a>
<a href="/browse" class="back-link text-lg">← Back</a>
</div>

<!-- Borough title -->
<div class="mt-10">
<p class="borough-title">{{ borough.name|capitalize }}</p>
<div class="divider"></div>
<p class="text-xs opacity-40 tracking-widest uppercase">New York City</p>
</div>


<!-- Carousel -->
<div class="carousel-wrap mt-8">
<div class="carousel-track">

{% for loc in locations %}

<div
class="card {% if loop.index0 == 0 %}center{% else %}side{% endif %}"
data-index="{{ loop.index0 }}"
onclick="selectCard({{ loop.index0 }})">

{% if loc.Image %}
<img src="{{ url_for('static', filename='uploads/' + loc.Image) }}" alt="{{ loc.Name }}">
{% else %}
<div class="flex items-center justify-center h-full text-xs text-white/60">
No Image
</div>
{% endif %}

<div class="card-overlay">
<p class="card-name">{{ loc.Name }}</p>
<p class="card-meta">
{{ loc.DatePosted.strftime('%b %d') if loc.DatePosted else '' }}
</p>
</div>

</div>

{% endfor %}

</div>
</div>

<!-- Detail Panel -->
<div class="detail-panel mt-4" id="detail-panel">
<p class="detail-name" id="detail-name"></p>
<p class="detail-meta" id="detail-meta"></p>
<p class="detail-desc" id="detail-desc"></p>
</div>

<!-- Add button -->
<div class="flex justify-center mt-6">
<button class="new-post-btn" onclick="openModal()">
<span class="dot"></span>
Add a location
</button>
</div>

<!-- Modal -->
<div class="modal-backdrop" id="modal" onclick="closeBackdrop(event)">
<div class="modal">

<h2>Add a location</h2>

<form method="POST"
action="/borough/{{ borough.name | replace(' ', '-') }}/add"
enctype="multipart/form-data">

<input type="text" name="name" placeholder="Location name" required>

<input type="text" name="address" placeholder="Address" required>

<textarea name="description" placeholder="Description"></textarea>

<input type="file" name="image" accept="image/*" required>

<button type="submit" class="modal-submit">Post location</button>

</form>

</div>
</div>

<script>

const locations = {{ locations_json | safe }};

function selectCard(index){

document.querySelectorAll('.card').forEach((card,i)=>{
card.classList.remove('center','side');
card.classList.add(i===index ? 'center':'side');
});

const loc = locations[index];

document.getElementById('detail-name').textContent = loc.Name;
document.getElementById('detail-meta').textContent =
loc.Borough + " · " + loc.DatePosted;
document.getElementById('detail-desc').textContent =
loc.Description || "";

document.getElementById('detail-panel').classList.add('open');

}

if(locations.length) selectCard(0);

function openModal(){
document.getElementById('modal').classList.add('open');
document.body.style.overflow='hidden';
}

function closeBackdrop(e){
if(e.target.id === "modal"){
document.getElementById('modal').classList.remove('open');
document.body.style.overflow='';
}
}

</script>

</body>
</html>