    (loc.Tags||[]).forEach(tag => { const el = document.createElement('span'); el.className="text-[9px] font-semibold tracking-[.14em] uppercase px-2.5 py-1 rounded-sm border border-[#e8ded0]/15 text-[#e8ded0]/50 bg-[#e8ded0]/[.04]"; el.textContent=tag; tagsEl.appendChild(el); });

    const hoursEl = document.getElementById('lb-hours'); hoursEl.innerHTML = '';
