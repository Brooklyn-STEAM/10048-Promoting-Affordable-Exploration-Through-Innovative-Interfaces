  // ── Address Autocomplete ──
  const GOOGLE_API_KEY = 'AIzaSyCoSwmHI-saWpWQuwYxG0D16AVq7-4VrvE';
  let addrDebounce = null;
  let addrSelected = false;

  window.initPlaces = function() {
    window._placesReady = true;
    window._placesService = new google.maps.places.AutocompleteService();
    window._geocoder       = new google.maps.Geocoder();
    window._sessionToken   = new google.maps.places.AutocompleteSessionToken();
  };

  if (GOOGLE_API_KEY && !window._gplacesLoaded) {
    window._gplacesLoaded = true;
    const s = document.createElement('script');
    s.src = `https://maps.googleapis.com/maps/api/js?key=${GOOGLE_API_KEY}&libraries=places&callback=initPlaces`;
    s.async = true;
