<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ borough.name | capitalize }} — Hidden Gems</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>

  {% include 'icon.html.jinja'%}
  <style>
    :root {
      --accent: {{ borough.accent }};
      --accent-rgb: {{ borough.accent_rgb | default('46, 109, 164') }};
      --borough-color: {{ borough.color }};
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Archivo', sans-serif;
      background-color: var(--borough-color);
      color: #e8ded0;
      min-height: 100vh;
      overflow-x: hidden;
    }

    .serif { font-family: 'Cormorant Garamond', serif; }

    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(232,222,208,0.2); border-radius: 2px; }

    /* ── Featured Cards ── */
    .featured-card {
      position: relative; border-radius: 18px; overflow: hidden;
      cursor: pointer; transition: transform 0.3s ease, box-shadow 0.3s ease;
      background: rgba(0,0,0,0.25); border: 1px solid rgba(232,222,208,0.12);
    }
    .featured-card:hover { transform: translateY(-4px); box-shadow: 0 24px 50px rgba(0,0,0,0.5); border-color: rgba(232,222,208,0.3); }
    .featured-card img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .featured-card .overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 55%); }
    .featured-card .info { position: absolute; bottom: 0; left: 0; right: 0; padding: 16px 18px; }
    .featured-card .badge { display: inline-block; font-size: 0.5rem; letter-spacing: 0.2em; text-transform: uppercase; padding: 3px 8px; border-radius: 999px; background: var(--accent); color: #fff; margin-bottom: 6px; opacity: 0.9; }
    .featured-card .card-title { font-family: 'Cormorant Garamond', serif; font-size: 1.25rem; font-weight: 300; line-height: 1.2; color: #fff; }
    .featured-card .card-sub { font-size: 0.6rem; letter-spacing: 0.12em; color: rgba(255,255,255,0.5); margin-top: 4px; }
    .featured-card .no-img { display: flex; align-items: center; justify-content: center; height: 100%; font-size: 0.7rem; opacity: 0.2; }

    /* ── Gem Cards ── */
    .gem-card { border-radius: 14px; overflow: hidden; background: rgba(0,0,0,0.2); border: 1px solid rgba(232,222,208,0.1); transition: all 0.25s ease; cursor: pointer; }
    .gem-card:hover { border-color: rgba(232,222,208,0.25); transform: translateY(-2px); box-shadow: 0 12px 30px rgba(0,0,0,0.3); }
    .gem-card img { width: 100%; height: 140px; object-fit: cover; display: block; }
    .gem-card .gem-info { padding: 12px 14px; }
    .gem-card .gem-title { font-size: 0.85rem; font-weight: 500; }
    .gem-card .gem-meta { font-size: 0.6rem; opacity: 0.4; margin-top: 3px; letter-spacing: 0.08em; }
    .gem-card .no-img { height: 140px; display: flex; align-items: center; justify-content: center; font-size: 0.65rem; opacity: 0.2; }

    /* ── Category buttons ── */
    .category-btn.selected {
      background: rgba(var(--accent-rgb), 0.15) !important;
      border-color: var(--accent) !important;
      color: #e8ded0 !important;
    }

    /* ── Buttons ── */
    .add-btn { display: inline-flex; align-items: center; gap: 8px; padding: 9px 22px; border-radius: 999px; border: 1px solid rgba(232,222,208,0.35); font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; background: transparent; color: #e8ded0; transition: background 0.2s; white-space: nowrap; }
    .add-btn:hover { background: rgba(232,222,208,0.08); }
    .add-btn .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }

    .section-label { font-size: 0.55rem; letter-spacing: 0.3em; text-transform: uppercase; opacity: 0.4; }

    /* ── Search ── */
    .search-wrap { margin-bottom: 32px; }
    .search-box {
      display: flex; align-items: center; gap: 10px;
      background: rgba(0,0,0,0.25); border: 1px solid rgba(232,222,208,0.15);
      border-radius: 999px; padding: 11px 18px; transition: border-color 0.2s;
    }
    .search-box:focus-within { border-color: rgba(232,222,208,0.4); }
    .search-box svg { flex-shrink: 0; opacity: 0.35; }
    #loc-search {
      flex: 1; background: none; border: none; outline: none;
      color: #e8ded0; font-size: 0.88rem; font-family: inherit;
    }
    #loc-search::placeholder { color: rgba(232,222,208,0.3); }
    #loc-search-clear {
      display: none; background: none; border: none;
      color: rgba(232,222,208,0.3); cursor: pointer;
      font-size: 1rem; padding: 0; line-height: 1;
      transition: color 0.15s; -webkit-tap-highlight-color: transparent;
    }
    #loc-search-clear:hover { color: rgba(232,222,208,0.7); }
    #loc-search-count {
      font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: rgba(232,222,208,0.3); margin-top: 8px; padding-left: 18px; min-height: 16px;
    }
    #no-results {
      display: none; text-align: center; padding: 48px 0;
      font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase;
      color: rgba(232,222,208,0.2);
    }

    /* ── Modals ── */
    .modal-backdrop { position: fixed; inset: 0; z-index: 300; background: rgba(0,0,0,0.55); backdrop-filter: blur(8px); display: none; align-items: center; justify-content: center; padding: 24px; }
    .modal-backdrop.open { display: flex; }
    .modal { background: #ece4d8; border-radius: 20px; border: 2px solid #1f1f1f; box-shadow: 6px 6px 0 #1f1f1f; padding: 28px; width: 100%; max-width: 400px; color: #2b2b2b; }
    .modal label { display: block; font-size: 0.6rem; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; color: #4a4a4a; margin-bottom: 5px; }
    .modal input, .modal textarea { width: 100%; padding: 10px 14px; border-radius: 12px; border: 2px solid #1f1f1f; background: #f5efe6; font-size: 0.85rem; outline: none; box-shadow: 3px 3px 0 #1f1f1f; color: #2b2b2b; font-family: inherit; margin-bottom: 14px; }
    .modal textarea { resize: none; height: 75px; }
    .modal input[type="file"] { box-shadow: none; padding: 8px; }
    .modal-submit { width: 100%; padding: 12px; border-radius: 12px; background: #2b2b2b; color: white; font-weight: 600; border: 2px solid #1f1f1f; box-shadow: 4px 4px 0 #1f1f1f; cursor: pointer; font-family: inherit; font-size: 0.85rem; transition: all 0.15s; }
    .modal-submit:hover { transform: translate(2px,2px); box-shadow: none; }
    .modal-cancel { width: 100%; padding: 9px; margin-top: 6px; background: transparent; border: none; color: #4a4a4a; cursor: pointer; font-size: 0.78rem; font-family: inherit; }
    .modal-cancel:hover { color: #2b2b2b; }

    /* ── Price tier buttons ── */
    .price-tier-btn { padding: 10px 4px; border-radius: 10px; border: 1px solid rgba(232,222,208,0.12); background: rgba(232,222,208,0.04); color: rgba(232,222,208,0.5); font-size: 0.75rem; font-family: inherit; cursor: pointer; transition: all 0.2s; -webkit-tap-highlight-color: transparent; display: flex; flex-direction: column; align-items: center; gap: 3px; }
    .price-tier-btn.selected { background: rgba(232,222,208,0.12); border-color: rgba(232,222,208,0.4); color: #e8ded0; }
    .price-tier-btn .tier-symbol { font-size: 0.9rem; }
    .price-tier-btn .tier-label { font-size: 0.55rem; letter-spacing: 0.12em; text-transform: uppercase; }

    /* ── Animations ── */
    @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    .fade-up { animation: fadeUp 0.5s ease both; }
    .d1 { animation-delay: 0.05s; } .d2 { animation-delay: 0.12s; } .d3 { animation-delay: 0.2s; } .d4 { animation-delay: 0.28s; }

    @keyframes lbBackdropIn  { from { opacity: 0; } to { opacity: 1; } }
    @keyframes lbBackdropOut { from { opacity: 1; } to { opacity: 0; } }
    @keyframes lbCardIn  { from { opacity: 0; transform: translateY(24px) scale(0.96); } to { opacity: 1; transform: translateY(0) scale(1); } }
    @keyframes lbCardOut { from { opacity: 1; transform: translateY(0) scale(1); } to { opacity: 0; transform: translateY(24px) scale(0.96); } }

    #lightbox { pointer-events: none; }
    #lightbox.lb-open { pointer-events: all; }
    #lightbox.lb-animating-in  { animation: lbBackdropIn  0.25s ease forwards; }
    #lightbox.lb-animating-out { animation: lbBackdropOut 0.25s ease forwards; }
    #lb-card.lb-animating-in  { animation: lbCardIn  0.3s cubic-bezier(0.23,1,0.32,1) forwards; }
    #lb-card.lb-animating-out { animation: lbCardOut 0.22s ease forwards; }

    /* ── Add modal dark inputs ── */
    #add-modal input[type="text"], #add-modal input[type="time"], #add-modal textarea, #add-modal select,
    #edit-modal input[type="text"], #edit-modal input[type="time"], #edit-modal textarea, #edit-modal select {
      background-color: rgba(101,75,55,0.25) !important; color: #e8ded0 !important;
      border-color: rgba(232,222,208,0.15) !important; color-scheme: dark;
    }
    #add-modal input::placeholder, #add-modal textarea::placeholder,
    #edit-modal input::placeholder, #edit-modal textarea::placeholder { color: rgba(232,222,208,0.25) !important; }
    #add-modal input[type="text"]:focus, #add-modal input[type="time"]:focus, #add-modal textarea:focus, #add-modal select:focus,
    #edit-modal input[type="text"]:focus, #edit-modal input[type="time"]:focus, #edit-modal textarea:focus, #edit-modal select:focus {
      background-color: rgba(101,75,55,0.35) !important; border-color: rgba(232,222,208,0.35) !important; outline: none;
    }
    #add-modal select option, #edit-modal select option { background-color: #2a1f18; color: #e8ded0; }

    /* ── Chat ── */
    #chat-messages { scrollbar-width: thin; }
    #chat-messages::-webkit-scrollbar { width: 3px; }
    #chat-messages::-webkit-scrollbar-thumb { background: rgba(232,222,208,0.1); border-radius: 2px; }

    .chat-msg { opacity: 0; transform: translateY(6px); animation: chatIn 0.25s ease forwards; }
    @keyframes chatIn { to { opacity: 1; transform: translateY(0); } }

    /* ── Lightbox mobile: full-screen card ── */
    @media (max-width: 767px) {
      #lb-card {
        padding: 0 !important;
        max-width: 100% !important;
        width: 100% !important;
        max-height: 85vh;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
      }
      #lb-prev, #lb-next {
        top: auto !important;
        bottom: 16px !important;
        transform: none !important;
        width: 44px !important;
        height: 44px !important;
      }
      #lb-prev { left: 16px !important; }
      #lb-next { right: 16px !important; }
      #lightbox { padding: 12px !important; align-items: flex-end !important; }
      #lb-map-area { height: 140px !important; }
      #lb-dots { margin-bottom: 60px; }

      #borough-switcher {
        bottom: 16px !important;
        left: 16px !important;
        right: auto !important;
      }
      #switcher-menu {
        left: 0 !important;
        right: auto !important;
      }

      #add-modal > div, #edit-modal > div {
        max-height: 100vh !important;
        border-radius: 20px 20px 0 0 !important;
        margin-top: auto !important;
      }
      #add-modal, #edit-modal {
        align-items: flex-end !important;
        padding: 0 !important;
      }

      .hours-row-inner {
        flex-direction: column !important;
        gap: 4px !important;
      }
      .hours-row-inner input[type="time"] {
        width: 100% !important;
      }

      .chat-container {
        height: 420px !important;
        border-radius: 16px !important;
      }

      #price-tier-grid, #edit-price-tier-grid {
        grid-template-columns: repeat(4, 1fr) !important;
      }
    }

    /* ── iPad (768–1023px) ── */
    @media (min-width: 768px) and (max-width: 1023px) {
      #lb-card {
        padding: 0 32px !important;
      }
      #borough-switcher {
        bottom: 20px !important;
        left: 20px !important;
      }
    }

    /* ── Spin keyframe for address spinner ── */
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>

<body>
  <p id="transition-sub" style="font-size:0.6rem;letter-spacing:0.35em;text-transform:uppercase;color:rgba(232,222,208,0.4);opacity:0;transition:opacity 0.5s ease 0.35s;">Finding your next NYC adventure</p>

{% include '_nav.html.jinja' %}

{% with messages = get_flashed_messages() %}
  {% if messages %}
    <div class="fixed top-4 left-1/2 -translate-x-1/2 z-50 flex flex-col gap-2 w-[calc(100%-2rem)] max-w-sm">
      {% for message in messages %}
        <div class="px-5 py-3 rounded-xl text-white text-sm border border-white/20 shadow-lg text-center" style="background:var(--accent);">{{ message }}</div>
      {% endfor %}
    </div>
  {% endif %}
{% endwith %}

<div class="max-w-5xl mx-auto px-4 sm:px-6 md:px-8 py-8 sm:py-10">

  <!-- ── Header ── -->
  <div class="flex items-end justify-between mb-8 sm:mb-10 fade-up gap-4">
    <div class="min-w-0">
      <a href="/browse" class="text-xs tracking-widest uppercase opacity-30 hover:opacity-60 transition-opacity">← Back</a>
      <h1 class="serif text-4xl sm:text-5xl md:text-6xl font-light mt-2 leading-none truncate">{{ borough.name | capitalize }}</h1>
      <div class="w-10 h-px mt-4 opacity-50" style="background:var(--accent);"></div>
      <p class="text-xs opacity-30 tracking-widest uppercase mt-3">New York City</p>
    </div>
    <button class="add-btn flex-shrink-0" onclick="openModal()">
      <span class="dot"></span>
      <span class="hidden xs:inline sm:inline">Add a location</span>
      <span class="xs:hidden sm:hidden inline">Add</span>
    </button>
  </div>

  {% if locations %}

  <!-- ── Search ── -->
  <div class="search-wrap fade-up">
    <div class="search-box">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#e8ded0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input id="loc-search" type="text" placeholder="Search locations…" autocomplete="off" oninput="filterLocations(this.value)">
      <button id="loc-search-clear" onclick="clearLocSearch()">✕</button>
    </div>
    <p id="loc-search-count"></p>
  </div>

  <!-- ── Featured carousel ── -->
  <div class="fade-up d1">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <p class="section-label">Featured</p>
      <div style="display:flex;gap:8px;">
        <button onclick="featStep(-1)" id="feat-prev" style="width:36px;height:36px;border-radius:50%;background:rgba(232,222,208,0.08);border:1px solid rgba(232,222,208,0.2);color:#e8ded0;font-size:1rem;cursor:pointer;transition:background 0.2s;display:flex;align-items:center;justify-content:center;-webkit-tap-highlight-color:transparent;">‹</button>
        <button onclick="featStep(1)"  id="feat-next" style="width:36px;height:36px;border-radius:50%;background:rgba(232,222,208,0.08);border:1px solid rgba(232,222,208,0.2);color:#e8ded0;font-size:1rem;cursor:pointer;transition:background 0.2s;display:flex;align-items:center;justify-content:center;-webkit-tap-highlight-color:transparent;">›</button>
      </div>
    </div>
    <div style="overflow:hidden;border-radius:18px;" id="feat-overflow">
      <div id="feat-track" class="flex gap-4 transition-transform duration-500 ease-[cubic-bezier(0.23,1,0.32,1)]">
        {% for loc in locations %}
        <div class="featured-card shrink-0 basis-full sm:basis-1/2 md:basis-1/3 h-[280px] sm:h-[310px] md:h-[340px]" onclick="openDetail({{ loop.index0 }})" data-index="{{ loop.index0 }}">
          {% if loc.Image %}
            {% if loc.Image.startswith('http') %}
              <img src="{{ loc.Image }}" alt="{{ loc.Name }}">
            {% else %}
              <img src="{{ url_for('static', filename='uploads/' + loc.Image) }}" alt="{{ loc.Name }}">
            {% endif %}
          {% else %}<div class="no-img">No image</div>{% endif %}
          <div class="overlay"></div>
          <div class="info">
            <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
  <span class="badge">{% if loop.index0 == 0 %}Featured{% elif loop.index0 == 1 %}Hidden gem{% else %}Local pick{% endif %}</span>
  {% if loc.PriceTier %}
  <span style="display:inline-block;font-size:0.5rem;letter-spacing:0.15em;text-transform:uppercase;padding:3px 8px;border-radius:999px;background:rgba(0,0,0,0.45);border:1px solid rgba(232,222,208,0.25);color:rgba(232,222,208,0.8);">{% if loc.PriceTier == 'free' %}○ Free{% elif loc.PriceTier == '$' %}$ Budget{% elif loc.PriceTier == '$$' %}$$ Mid{% elif loc.PriceTier == '$$$' %}$$$ Upscale{% endif %}</span>
  {% endif %}
</div>
            <p class="card-title">{{ loc.Name }}</p>
            <p class="card-sub">{{ loc.DatePosted.strftime('%b %d, %Y') if loc.DatePosted else '' }}</p>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
    <div id="feat-dots" style="display:flex;gap:6px;margin-top:14px;justify-content:center;"></div>
  </div>

  {% if locations | length > 3 %}
  <!-- ── All Locations grid ── -->
  <div class="mt-10 sm:mt-12 fade-up d2" id="all-locations-section">
    <p class="section-label mb-4">All Locations</p>
    <div class="grid grid-cols-1 xs:grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4" id="gem-grid">
      {% for loc in locations[3:] %}
      <div class="gem-card" onclick="openDetail({{ loop.index0 + 3 }})" data-index="{{ loop.index0 + 3 }}">
        {% if loc.Image %}
          {% if loc.Image.startswith('http') %}
            <img src="{{ loc.Image }}" alt="{{ loc.Name }}">
          {% else %}
            <img src="{{ url_for('static', filename='uploads/' + loc.Image) }}" alt="{{ loc.Name }}">
          {% endif %}
        {% else %}<div class="no-img"></div>{% endif %}
        <div class="gem-info" style="display:flex;align-items:flex-start;justify-content:space-between;">
          <div style="min-width:0;flex:1;margin-right:8px;">
            <p class="gem-title" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ loc.Name }}</p>
            <p class="gem-meta">{{ loc.DatePosted.strftime('%b %d, %Y') if loc.DatePosted else '' }}</p>
            {% if loc.PriceTier %}
            <p class="gem-meta" style="margin-top:3px;">
              {% if loc.PriceTier == 'free' %}○ Free
              {% elif loc.PriceTier == '$' %}$ Budget
              {% elif loc.PriceTier == '$$' %}$$ Mid-range
              {% elif loc.PriceTier == '$$$' %}$$$ Upscale
              {% endif %}
            </p>
            {% endif %}
          </div>
          <button class="like-btn"
            data-id="{{ loc.ID }}"
            data-borough="{{ borough.name | replace(' ', '-') }}"
            data-liked="{{ 'true' if loc.ID in liked_ids else 'false' }}"
            onclick="event.stopPropagation(); toggleLike(this)"
            style="background:none;border:none;cursor:pointer;display:flex;align-items:center;gap:4px;color:{{ 'var(--accent)' if loc.ID in liked_ids else 'rgba(232,222,208,0.3)' }};font-size:0.7rem;padding:6px 0;flex-shrink:0;min-width:36px;justify-content:flex-end;-webkit-tap-highlight-color:transparent;">
            <span class="like-heart">{{ '♥' if loc.ID in liked_ids else '♡' }}</span>
            <span class="like-count">{{ loc.LikeCount or 0 }}</span>
          </button>
        </div>
      </div>
      {% endfor %}
    </div>
    <p id="no-results">No locations match your search</p>
  </div>
  {% else %}
  <!-- ── All Locations grid for <= 3 locations (hidden by default, shown during search) ── -->
  <div class="mt-10 sm:mt-12 fade-up d2" id="all-locations-section" style="display:none;">
    <p class="section-label mb-4">All Locations</p>
    <div class="grid grid-cols-1 xs:grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4" id="gem-grid"></div>
    <p id="no-results">No locations match your search</p>
  </div>
  {% endif %}

  {% else %}
  <div class="fade-up d1 flex flex-col items-center justify-center py-24 sm:py-32 opacity-30">
    <p class="serif text-3xl font-light mb-2">No gems yet</p>
    <p class="text-xs tracking-widest uppercase">Be the first to add a location</p>
  </div>
  {% endif %}

</div>

<!-- ── Community Chat ── -->
<div class="max-w-5xl mx-auto px-4 sm:px-6 md:px-8 pb-16 mt-10 sm:mt-12 fade-up">
  <div class="chat-container" style="background:rgba(0,0,0,0.25);border:1px solid rgba(232,222,208,0.1);border-radius:24px;overflow:hidden;display:flex;flex-direction:column;height:500px;">
    <div style="padding:14px 18px;border-bottom:1px solid rgba(232,222,208,0.08);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:8px;height:8px;border-radius:50%;background:var(--accent);box-shadow:0 0 8px var(--accent);flex-shrink:0;"></div>
        <p style="font-size:0.65rem;font-weight:500;color:#e8ded0;letter-spacing:0.05em;">{{ borough.name | capitalize }} Community Chat</p>
      </div>
      <div style="display:flex;align-items:center;gap:8px;">
        <span id="online-count" style="font-size:0.6rem;color:rgba(232,222,208,0.4);letter-spacing:0.1em;">0 online</span>
        <div style="width:7px;height:7px;border-radius:50%;background:#4ade80;box-shadow:0 0 6px #4ade80;flex-shrink:0;"></div>
      </div>
    </div>
    <div id="chat-messages" style="flex:1;overflow-y:auto;overflow-x:hidden;padding:14px 16px;display:flex;flex-direction:column;gap:4px;min-height:0;-webkit-overflow-scrolling:touch;"></div>
    <div style="padding:12px 14px;border-top:1px solid rgba(232,222,208,0.08);display:flex;align-items:center;gap:8px;background:rgba(0,0,0,0.15);flex-shrink:0;">
      <input id="chat-input" type="text" placeholder="Type a message…" maxlength="300"
        onkeydown="if(event.key==='Enter') sendMessage()"
        style="flex:1;background:rgba(232,222,208,0.06);border:1px solid rgba(232,222,208,0.12);border-radius:999px;padding:11px 16px;color:#e8ded0;font-size:0.82rem;font-family:inherit;outline:none;transition:border-color 0.2s;min-width:0;"
        onfocus="this.style.borderColor='rgba(232,222,208,0.3)'"
        onblur="this.style.borderColor='rgba(232,222,208,0.12)'">
      <button onclick="sendMessage()" style="width:42px;height:42px;border-radius:50%;background:var(--accent);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:opacity 0.2s, transform 0.15s;font-size:1rem;-webkit-tap-highlight-color:transparent;"
        onmousedown="this.style.transform='scale(0.93)'" onmouseup="this.style.transform='scale(1)'">➤</button>
    </div>
  </div>
</div>

<!-- ── Lightbox ── -->
<div id="lightbox" class="fixed inset-0 z-[400] flex-col items-center justify-center bg-black/50 backdrop-blur-2xl" style="display:none;padding:16px;">
  <button onclick="closeLightbox()" style="position:absolute;top:16px;right:16px;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:#e8ded0;font-size:1.1rem;width:42px;height:42px;border-radius:50%;cursor:pointer;line-height:1;z-index:10;display:flex;align-items:center;justify-content:center;-webkit-tap-highlight-color:transparent;">✕</button>
  <p id="lb-counter" style="position:absolute;top:22px;left:50%;transform:translateX(-50%);font-size:0.55rem;letter-spacing:0.3em;text-transform:uppercase;color:rgba(232,222,208,0.35);"></p>

  <div style="display:flex;align-items:center;width:100%;max-width:960px;padding:0;box-sizing:border-box;justify-content:center;">
    <button id="lb-prev" onclick="lbStep(-1)" style="position:absolute;left:8px;top:50%;transform:translateY(-50%);width:40px;height:40px;border-radius:50%;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);color:#e8ded0;font-size:1.3rem;cursor:pointer;z-index:10;display:flex;align-items:center;justify-content:center;transition:background 0.2s;-webkit-tap-highlight-color:transparent;">‹</button>
    <button id="lb-next" onclick="lbStep(1)"  style="position:absolute;right:8px;top:50%;transform:translateY(-50%);width:40px;height:40px;border-radius:50%;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);color:#e8ded0;font-size:1.3rem;cursor:pointer;z-index:10;display:flex;align-items:center;justify-content:center;transition:background 0.2s;-webkit-tap-highlight-color:transparent;">›</button>

    <div id="lb-card" style="width:100%;max-width:780px;padding:0 56px;box-sizing:border-box;margin:auto;">
      <div id="lb-map-area" class="relative h-[220px] bg-black/40 flex items-end justify-between p-4 gap-2">
        <div class="absolute inset-0 opacity-[0.06]" style="background-image:linear-gradient(rgba(232,222,208,.8) 1px,transparent 1px),linear-gradient(90deg,rgba(232,222,208,.8) 1px,transparent 1px);background-size:30px 30px"></div>
        <div class="absolute top-4 left-4 z-10 flex items-center gap-2 rounded-full px-3 py-1" style="background:var(--accent)">
          <span class="w-1.5 h-1.5 rounded-full bg-white"></span>
          <span id="lb-badge" class="text-[10px] font-bold tracking-[.2em] uppercase text-white"></span>
        </div>
        <span id="lb-coords" class="z-10 text-[9px] tracking-[.1em] uppercase text-[#e8ded0]/25 font-mono hidden sm:block"></span>
        <a id="lb-map-link" href="#" target="_blank" class="z-10 inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 bg-[#e8ded0]/[.08] border border-[#e8ded0]/20 text-[#e8ded0] text-[10px] font-bold tracking-[.18em] uppercase no-underline hover:bg-[#e8ded0]/[.15] transition-colors">Maps ↗</a>
      </div>
      <div class="h-[3px] w-full" style="background:var(--accent)"></div>
      <div class="px-4 sm:px-6 pt-4 sm:pt-5">
        <div class="flex items-center gap-2 mb-3 flex-wrap">
          <span id="lb-type" class="text-[9px] font-bold tracking-[.22em] uppercase px-2.5 py-0.5 rounded-sm text-white" style="background:var(--accent)"></span>
          <span id="lb-open-status" class="inline-flex items-center gap-1 text-[9px] font-bold tracking-[.16em] uppercase text-green-400 bg-green-400/10 border border-green-400/20 rounded-sm px-2.5 py-0.5">
            <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>Open now
          </span>
          <span id="lb-price-badge" style="display:none;" class="inline-flex items-center gap-1 text-[9px] font-bold tracking-[.16em] uppercase rounded-sm px-2.5 py-0.5 border border-[#e8ded0]/15 text-[#e8ded0]/60 bg-[#e8ded0]/[.05]"></span>
        </div>
        <h2 id="lb-title" class="font-['Cormorant_Garamond'] font-light text-[1.6rem] sm:text-[2rem] leading-none text-[#e8ded0] mb-1"></h2>
        <p id="lb-meta" class="text-[10px] tracking-[.18em] uppercase text-[#e8ded0]/35 mb-3"></p>
        <p id="lb-desc" class="text-[13px] text-[#e8ded0]/60 leading-relaxed mb-4"></p>
        <div id="lb-price-note-wrap" style="display:none;margin-bottom:16px;padding:10px 14px;border-radius:10px;background:rgba(232,222,208,0.04);border:1px solid rgba(232,222,208,0.08);">
          <p style="font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(232,222,208,0.3);margin-bottom:4px;">Pricing note</p>
          <p id="lb-price-note" style="font-size:0.8rem;color:rgba(232,222,208,0.55);line-height:1.5;"></p>
        </div>
        <div id="lb-tags" class="flex flex-wrap gap-1.5 mb-4 sm:mb-5"></div>
      </div>
      <div class="border-t border-[#e8ded0]/[.08] bg-black/15 px-4 sm:px-6 py-4">
        <p class="text-[9px] font-bold tracking-[.24em] uppercase text-[#e8ded0]/35 mb-3">Hours</p>
        <div id="lb-hours" class="grid grid-cols-2 gap-x-4 gap-y-0"></div>
      </div>
      <div class="flex items-center justify-between border-t border-[#e8ded0]/[.08] px-4 sm:px-6 py-4 gap-3">
        <p id="lb-addr-text" class="text-[10px] text-[#e8ded0]/30 tracking-wide leading-relaxed flex-1 min-w-0"></p>
        <button id="lb-like-btn" onclick="toggleLikeById()" class="flex items-center gap-1.5 px-3 sm:px-4 py-2 rounded-sm border border-[#e8ded0]/15 bg-[#e8ded0]/[.06] text-[#e8ded0] font-bold text-[11px] tracking-[.14em] uppercase hover:bg-[#e8ded0]/10 transition-colors cursor-pointer flex-shrink-0" style="-webkit-tap-highlight-color:transparent;">
          <span id="lb-heart">♡</span><span id="lb-like-count">0</span>
          <span class="text-[8px] opacity-50 tracking-[.15em]">likes</span>
        </button>
      </div>
      <!-- ── Owner actions: Edit + Delete ── -->
      <div class="px-4 sm:px-6 pb-4 flex flex-col gap-2">
        <button id="lb-edit-btn" onclick="openEditModal()" style="display:none;" class="w-full flex items-center justify-center gap-2 px-4 py-2 rounded-sm border border-[#e8ded0]/20 bg-[#e8ded0]/[.06] text-[#e8ded0]/70 font-bold text-[11px] tracking-[.14em] uppercase hover:bg-[#e8ded0]/10 transition-colors cursor-pointer">✎ Edit location</button>
        <button id="lb-delete-btn" onclick="openDeleteModal()" style="display:none;" class="w-full flex items-center justify-center gap-2 px-4 py-2 rounded-sm border border-red-400/20 bg-red-400/10 text-red-400 font-bold text-[11px] tracking-[.14em] uppercase hover:bg-red-400/20 transition-colors cursor-pointer">Remove location</button>
      </div>
    </div>
  </div>
  <div id="lb-dots" style="display:flex;gap:8px;margin-top:20px;flex-wrap:wrap;justify-content:center;padding:0 60px;"></div>
</div>

<!-- ── ADD LOCATION MODAL ── -->
<div id="add-modal" onclick="if(event.target===this)closeAddModal()" style="
  display:none; position:fixed; inset:0; z-index:500;
  background:rgba(0,0,0,0.7); backdrop-filter:blur(16px);
  align-items:flex-end; justify-content:center; padding:0;
">
  <div style="
    width:100%; max-width:520px; max-height:92vh;
    background:linear-gradient(145deg,#1a1410 0%,#120e0a 100%);
    border:1px solid rgba(232,222,208,0.12);
    border-radius:24px 24px 0 0;
    overflow:hidden;
    display:flex; flex-direction:column;
    box-shadow:0 32px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(232,222,208,0.05);
  " onclick="event.stopPropagation()" id="add-modal-inner">

    <div style="display:flex;justify-content:center;padding:10px 0 0;flex-shrink:0;">
      <div style="width:36px;height:3px;border-radius:999px;background:rgba(232,222,208,0.15);"></div>
    </div>

    <div style="position:relative; overflow:hidden; flex-shrink:0;">
      <div style="height:3px; background:linear-gradient(90deg, var(--accent), transparent);"></div>
      <div style="padding:18px 22px 14px; display:flex; align-items:flex-start; justify-content:space-between;">
        <div>
          <div style="display:flex; align-items:center; gap:8px; margin-bottom:4px;">
            <div style="width:6px;height:6px;border-radius:50%;background:var(--accent);box-shadow:0 0 8px var(--accent);"></div>
            <p style="font-size:0.5rem;letter-spacing:0.3em;text-transform:uppercase;color:rgba(232,222,208,0.3);">{{ borough.name | capitalize }}</p>
          </div>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:300;color:#e8ded0;line-height:1.1;">Add a Hidden Gem</h2>
        </div>
        <button onclick="closeAddModal()" style="
          width:32px;height:32px;border-radius:50%;flex-shrink:0;margin-top:4px;
          background:rgba(232,222,208,0.06);border:1px solid rgba(232,222,208,0.12);
          color:rgba(232,222,208,0.4);cursor:pointer;font-size:0.9rem;
          display:flex;align-items:center;justify-content:center;transition:all 0.2s;
          -webkit-tap-highlight-color:transparent;
        ">✕</button>
      </div>
    </div>

    <div style="padding:0 22px 14px; display:flex; gap:6px; flex-shrink:0;" id="step-indicators">
      <div class="step-dot active" data-step="0" style="flex:1;height:2px;border-radius:999px;background:var(--accent);transition:background 0.3s;"></div>
      <div class="step-dot" data-step="1" style="flex:1;height:2px;border-radius:999px;background:rgba(232,222,208,0.15);transition:background 0.3s;"></div>
      <div class="step-dot" data-step="2" style="flex:1;height:2px;border-radius:999px;background:rgba(232,222,208,0.15);transition:background 0.3s;"></div>
    </div>

    <form id="add-location-form" method="POST" action="/borough/{{ borough.name | replace(' ', '-') }}/add" enctype="multipart/form-data" style="flex:1;overflow:hidden;display:flex;flex-direction:column;">

      <div style="flex:1;overflow-y:auto;padding:0 22px;-webkit-overflow-scrolling:touch;">

        <!-- STEP 1 -->
        <div id="step-0" class="form-step">
          <p style="font-size:0.55rem;letter-spacing:0.25em;text-transform:uppercase;color:rgba(232,222,208,0.3);margin-bottom:18px;">Step 1 — Basic Info</p>

          <div style="margin-bottom:16px;">
            <label style="display:block;font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(232,222,208,0.4);margin-bottom:8px;">Location Name <span style="color:var(--accent);">*</span></label>
            <input type="text" name="name" required placeholder="e.g. Domino Park" id="input-name" style="
              width:100%;padding:12px 16px;border-radius:12px;
              background:rgba(232,222,208,0.05);border:1px solid rgba(232,222,208,0.12);
              color:#e8ded0;font-size:0.9rem;font-family:inherit;outline:none;transition:all 0.2s;
            " onfocus="this.style.borderColor='rgba(232,222,208,0.35)';this.style.background='rgba(232,222,208,0.08)'"
               onblur="this.style.borderColor='rgba(232,222,208,0.12)';this.style.background='rgba(232,222,208,0.05)'">
          </div>

          <div style="margin-bottom:8px;">
            <label style="display:block;font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(232,222,208,0.4);margin-bottom:8px;">Address <span style="color:var(--accent);">*</span></label>
            <div style="position:relative;">
              <input type="text" name="address" required placeholder="Start typing an address…" id="input-address"
                autocomplete="off"
                oninput="onAddressInput(this.value)"
                onfocus="this.style.borderColor='rgba(232,222,208,0.35)';this.style.background='rgba(232,222,208,0.08)';showSuggestions()"
                onblur="this.style.borderColor='rgba(232,222,208,0.12)';this.style.background='rgba(232,222,208,0.05)';setTimeout(hideSuggestions,200)"
                style="width:100%;padding:12px 40px 12px 16px;border-radius:12px;background:rgba(232,222,208,0.05);border:1px solid rgba(232,222,208,0.12);color:#e8ded0;font-size:0.9rem;font-family:inherit;outline:none;transition:all 0.2s;">
              <div id="addr-spinner" style="display:none;position:absolute;right:14px;top:50%;transform:translateY(-50%);">
                <div style="width:14px;height:14px;border:2px solid rgba(232,222,208,0.1);border-top-color:var(--accent);border-radius:50%;animation:spin 0.7s linear infinite;"></div>
              </div>
              <div id="addr-suggestions" style="
                display:none;position:absolute;top:calc(100% + 6px);left:0;right:0;z-index:999;
                background:#1a1410;border:1px solid rgba(232,222,208,0.12);border-radius:14px;
                overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.5);
                max-height:220px;overflow-y:auto;-webkit-overflow-scrolling:touch;
              "></div>
            </div>
          </div>

          <div id="addr-enrichment-card" style="display:none;margin-bottom:16px;border-radius:14px;overflow:hidden;border:1px solid rgba(232,222,208,0.1);">
            <div id="addr-card-inner" style="padding:16px 18px;background:linear-gradient(135deg,rgba(0,0,0,0.4),rgba(0,0,0,0.2));position:relative;">
              <div style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),transparent);"></div>
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                <div style="flex:1;min-width:0;">
                  <div style="display:flex;align-items:center;gap:6px;margin-bottom:6px;flex-wrap:wrap;">
                    <div id="addr-type-badge" style="font-size:0.45rem;letter-spacing:0.2em;text-transform:uppercase;padding:2px 8px;border-radius:999px;background:var(--accent);color:#fff;opacity:0.85;"></div>
                    <div style="font-size:0.45rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(232,222,208,0.3);display:flex;align-items:center;gap:3px;">
                      <svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.2L22 12l-7.6 2.8L12 22l-2.4-7.2L2 12l7.6-2.8z"/></svg>
                      AI enriched
                    </div>
                  </div>
                  <p id="addr-street" style="font-size:0.9rem;font-weight:600;color:#e8ded0;margin-bottom:2px;"></p>
                  <p id="addr-city" style="font-size:0.75rem;color:rgba(232,222,208,0.5);margin-bottom:10px;"></p>
                  <p id="addr-description" style="font-size:0.72rem;color:rgba(232,222,208,0.55);line-height:1.5;font-style:italic;"></p>
                  <div id="addr-fun-fact" style="display:none;margin-top:8px;padding:8px 10px;background:rgba(232,222,208,0.04);border:1px solid rgba(232,222,208,0.08);border-radius:8px;font-size:0.65rem;color:rgba(232,222,208,0.45);line-height:1.5;"></div>
                </div>
                <div style="flex-shrink:0;text-align:right;">
                  <p id="addr-coords" style="font-size:0.6rem;color:rgba(232,222,208,0.3);font-family:monospace;line-height:1.8;"></p>
                  <a id="addr-map-link" href="#" target="_blank" style="font-size:0.55rem;color:var(--accent);text-decoration:none;letter-spacing:0.1em;text-transform:uppercase;opacity:0.7;">Maps ↗</a>
                </div>
              </div>
            </div>
          </div>

          <input type="hidden" name="latitude"     id="hidden-lat">
          <input type="hidden" name="longitude"    id="hidden-lng">
          <input type="hidden" name="photo_url"    id="hidden-photo-url">
          <input type="hidden" name="neighborhood" id="hidden-neighborhood">

          <div style="margin-bottom:16px;">
            <label style="display:block;font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(232,222,208,0.4);margin-bottom:8px;">Description</label>
            <textarea name="description" id="input-description" placeholder="What makes this place special?" rows="3" style="
              width:100%;padding:12px 16px;border-radius:12px;
              background:rgba(232,222,208,0.05);border:1px solid rgba(232,222,208,0.12);
              color:#e8ded0;font-size:0.9rem;font-family:inherit;outline:none;resize:none;transition:all 0.2s;
            " onfocus="this.style.borderColor='rgba(232,222,208,0.35)';this.style.background='rgba(232,222,208,0.08)'"
               onblur="this.style.borderColor='rgba(232,222,208,0.12)';this.style.background='rgba(232,222,208,0.05)'"></textarea>
          </div>

          <div style="margin-bottom:20px;">
            <label style="display:block;font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(232,222,208,0.4);margin-bottom:8px;">Pricing</label>
            <div id="price-tier-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:10px;">
              <button type="button" class="price-tier-btn" data-tier="free" onclick="selectPriceTier(this)">
                <span class="tier-symbol">○</span>
                <span class="tier-label">Free</span>
              </button>
              <button type="button" class="price-tier-btn" data-tier="$" onclick="selectPriceTier(this)">
                <span class="tier-symbol">$</span>
                <span class="tier-label">Budget</span>
              </button>
              <button type="button" class="price-tier-btn" data-tier="$$" onclick="selectPriceTier(this)">
                <span class="tier-symbol">$$</span>
                <span class="tier-label">Mid</span>
              </button>
              <button type="button" class="price-tier-btn" data-tier="$$$" onclick="selectPriceTier(this)">
                <span class="tier-symbol">$$$</span>
                <span class="tier-label">Upscale</span>
              </button>
            </div>
            <input type="hidden" name="price_tier" id="hidden-price-tier">
            <input type="text" name="price_note" id="input-price-note"
              placeholder='Optional note, e.g. "Free entry on Tuesdays"'
              style="width:100%;padding:10px 16px;border-radius:12px;
                background:rgba(232,222,208,0.05);border:1px solid rgba(232,222,208,0.12);
                color:#e8ded0;font-size:0.85rem;font-family:inherit;outline:none;transition:all 0.2s;"
              onfocus="this.style.borderColor='rgba(232,222,208,0.35)';this.style.background='rgba(232,222,208,0.08)'"
              onblur="this.style.borderColor='rgba(232,222,208,0.12)';this.style.background='rgba(232,222,208,0.05)'">
          </div>

          <!-- ── CATEGORY SELECTOR (ADDED RIGHT HERE) ── -->
          <div style="margin-bottom:20px;">
            <label style="display:block;font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(232,222,208,0.4);margin-bottom:8px;">Category</label>
            <div style="display:flex;flex-wrap:wrap;gap:8px;" id="category-buttons">
              <button type="button" class="category-btn" data-cat="food" onclick="selectCategory(this)" style="padding:7px 14px;border-radius:999px;background:rgba(232,222,208,0.05);border:1px solid rgba(232,222,208,0.12);color:rgba(232,222,208,0.6);font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;transition:all 0.2s;cursor:pointer;">🍔 Food</button>
              <button type="button" class="category-btn" data-cat="entertainment" onclick="selectCategory(this)" style="padding:7px 14px;border-radius:999px;background:rgba(232,222,208,0.05);border:1px solid rgba(232,222,208,0.12);color:rgba(232,222,208,0.6);font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;transition:all 0.2s;cursor:pointer;">🎭 Entertainment</button>
              <button type="button" class="category-btn" data-cat="arts" onclick="selectCategory(this)" style="padding:7px 14px;border-radius:999px;background:rgba(232,222,208,0.05);border:1px solid rgba(232,222,208,0.12);color:rgba(232,222,208,0.6);font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;transition:all 0.2s;cursor:pointer;">🎨 Arts</button>
              <button type="button" class="category-btn" data-cat="outdoors" onclick="selectCategory(this)" style="padding:7px 14px;border-radius:999px;background:rgba(232,222,208,0.05);border:1px solid rgba(232,222,208,0.12);color:rgba(232,222,208,0.6);font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;transition:all 0.2s;cursor:pointer;">🌿 Outdoors</button>
              <button type="button" class="category-btn" data-cat="shopping" onclick="selectCategory(this)" style="padding:7px 14px;border-radius:999px;background:rgba(232,222,208,0.05);border:1px solid rgba(232,222,208,0.12);color:rgba(232,222,208,0.6);font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;transition:all 0.2s;cursor:pointer;">🛍️ Shopping</button>
              <button type="button" class="category-btn" data-cat="nightlife" onclick="selectCategory(this)" style="padding:7px 14px;border-radius:999px;background:rgba(232,222,208,0.05);border:1px solid rgba(232,222,208,0.12);color:rgba(232,222,208,0.6);font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;transition:all 0.2s;cursor:pointer;">🌙 Nightlife</button>
