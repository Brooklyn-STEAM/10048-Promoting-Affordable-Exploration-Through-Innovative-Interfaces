  function getLocalTime() {
    const now=new Date(); let h=now.getHours(); const m=now.getMinutes().toString().padStart(2,'0'), ampm=h>=12?'PM':'AM'; h=h%12||12; return `${h}:${m} ${ampm}`;
  }

  function appendMessage(data, isHistory=false) {
    const wrap=document.getElementById('chat-messages'); if(!wrap) return;
    const isSystem=data.user==='system', isMe=data.user===USERNAME;
    const time = data.time || getLocalTime();
    const div=document.createElement('div');
    div.className = 'chat-msg';
    div.style.cssText=`display:flex;flex-direction:column;align-items:${isMe?'flex-end':isSystem?'center':'flex-start'};margin-bottom:4px;flex-shrink:0;`;
    if(isSystem){
      div.innerHTML=`<p style="font-size:0.6rem;color:rgba(232,222,208,0.2);text-align:center;padding:4px 0;">${data.text}</p>`;
    } else {
      div.innerHTML=`
        ${!isMe?`<p style="font-size:0.6rem;color:rgba(232,222,208,0.4);margin-bottom:3px;padding-left:4px;">${data.user}</p>`:''}
        <div style="max-width:75%;padding:10px 14px;border-radius:${isMe?'18px 18px 4px 18px':'18px 18px 18px 4px'};background:${isMe?'var(--accent)':'rgba(232,222,208,0.1)'};color:#e8ded0;font-size:0.82rem;line-height:1.5;word-break:break-word;">${data.text}</div>
        <p style="font-size:0.55rem;color:rgba(232,222,208,0.2);margin-top:3px;padding:0 4px;">${time}</p>`;
    }
    wrap.appendChild(div);
    requestAnimationFrame(() => { wrap.scrollTop = wrap.scrollHeight; });
  }

