<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{ borough.name | capitalize }} — Borough Selector</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Archivo:wght@300;400;500&display=swap" rel="stylesheet">

  <style>
    :root {
      --accent: {{ borough.accent }};
      --borough-color: {{ borough.color }};
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Archivo', sans-serif;
      background-color: {{ borough.color }};
      color: #e8ded0;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 200;
      opacity: 0.3;
    }

    h1 {
      font-family: 'Archivo', sans-serif;
      font-weight: 500;
      letter-spacing: 0.3em;
      font-size: 0.75rem;
    }

    .borough-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      font-size: clamp(4rem, 12vw, 9rem);
      line-height: 1;
      text-transform: capitalize;
      letter-spacing: -0.02em;
    }

    .back-link {
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(232,222,208,0.4);
      text-decoration: none;
      transition: color 0.2s;
    }
    .back-link:hover { color: #e8ded0; }

    .nav-link {
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(232,222,208,0.35);
      text-decoration: none;
    }

    .divider {
      width: 40px;
      height: 1px;
      background: var(--accent);
      margin: 2rem 0;
      opacity: 0.6;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up  { animation: fadeUp 0.5s ease both; }
    .delay-1  { animation-delay: 0.1s; }
    .delay-2  { animation-delay: 0.2s; }
    .delay-3  { animation-delay: 0.3s; }
  </style>
</head>

<body class="p-8" style="height:100vh;">

<!-- TOP NAV -->
<div class="flex items-center justify-between fade-up">
  <h1>Borough Selector</h1>
  <a href="/browse" class="back-link">← Back</a>
</div>

<!-- BOROUGH TITLE -->
<div style="flex:1; display:flex; align-items:center;">
  <div class="fade-up delay-1">
    <p class="borough-title">{{ borough.name }}</p>
    <div class="divider"></div>
    <p style="font-size:0.65rem; letter-spacing:0.2em; text-transform:uppercase; opacity:0.4;">New York City</p>
  </div>
</div>

<!-- BOTTOM NAV -->
<div class="flex justify-between fade-up delay-3">
  <div class="flex gap-6">
    <a href="#" class="nav-link">About</a>
    <a href="#" class="nav-link">Contact</a>
  </div>
  <a href="#" class="nav-link">Privacy</a>
</div>
<!-- Floating Account Button -->
<div class="fixed bottom-6 left-6 z-50">
  <div class="relative">
    
    <!-- Toggle Button -->
    <button id="accountToggle"
      class="w-12 h-12 rounded-full flex items-center justify-center text-xs tracking-widest uppercase transition"
      style="background: var(--accent); color: #1a1a1a;">
      •••
    </button>

    <!-- Dropdown Menu -->
    <div id="accountMenu"
      class="absolute bottom-16 left-0 w-40 rounded shadow-lg hidden"
      style="background: rgba(0,0,0,0.85); backdrop-filter: blur(6px);">
      
      <a href="/logout"
        class="block px-4 py-3 text-xs uppercase tracking-widest hover:opacity-60 transition"
        style="color: #e8ded0;">
        Logout
      </a>
      
    </div>
  </div>
</div>
</body>
<script>
  const toggle = document.getElementById('accountToggle');
  const menu = document.getElementById('accountMenu');

  toggle.addEventListener('click', () => {
    menu.classList.toggle('hidden');
  });

  document.addEventListener('click', (e) => {
    if (!toggle.contains(e.target) && !menu.contains(e.target)) {
      menu.classList.add('hidden');
    }
  });
</script>
</html>
