<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ borough.name | capitalize }} — Hidden Gems</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>

  {% include 'icon.html.jinja'%}
  <style>
    :root {
      --accent: {{ borough.accent }};
      --borough-color: {{ borough.color }};
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Archivo', sans-serif;
      background-color: var(--borough-color);
      color: #e8ded0;
      min-height: 100vh;
      overflow-x: hidden;
    }

    .serif { font-family: 'Cormorant Garamond', serif; }

    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(232,222,208,0.2); border-radius: 2px; }

    .featured-card {
      position: relative; border-radius: 18px; overflow: hidden;
      cursor: pointer; transition: transform 0.3s ease, box-shadow 0.3s ease;
      background: rgba(0,0,0,0.25); border: 1px solid rgba(232,222,208,0.12);
    }
    .featured-card:hover { transform: translateY(-4px); box-shadow: 0 24px 50px rgba(0,0,0,0.5); border-color: rgba(232,222,208,0.3); }
    .featured-card img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .featured-card .overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 55%); }
    .featured-card .info { position: absolute; bottom: 0; left: 0; right: 0; padding: 16px 18px; }
    .featured-card .badge { display: inline-block; font-size: 0.5rem; letter-spacing: 0.2em; text-transform: uppercase; padding: 3px 8px; border-radius: 999px; background: var(--accent); color: #fff; margin-bottom: 6px; opacity: 0.9; }
    .featured-card .card-title { font-family: 'Cormorant Garamond', serif; font-size: 1.25rem; font-weight: 300; line-height: 1.2; color: #fff; }
    .featured-card .card-sub { font-size: 0.6rem; letter-spacing: 0.12em; color: rgba(255,255,255,0.5); margin-top: 4px; }
    .featured-card .no-img { display: flex; align-items: center; justify-content: center; height: 100%; font-size: 0.7rem; opacity: 0.2; }

    .gem-card { border-radius: 14px; overflow: hidden; background: rgba(0,0,0,0.2); border: 1px solid rgba(232,222,208,0.1); transition: all 0.25s ease; cursor: pointer; }
    .gem-card:hover { border-color: rgba(232,222,208,0.25); transform: translateY(-2px); box-shadow: 0 12px 30px rgba(0,0,0,0.3); }
    .gem-card img { width: 100%; height: 140px; object-fit: cover; display: block; }
    .gem-card .gem-info { padding: 12px 14px; }
    .gem-card .gem-title { font-size: 0.85rem; font-weight: 500; }
    .gem-card .gem-meta { font-size: 0.6rem; opacity: 0.4; margin-top: 3px; letter-spacing: 0.08em; }
    .gem-card .no-img { height: 140px; display: flex; align-items: center; justify-content: center; font-size: 0.65rem; opacity: 0.2; }

    .add-btn { display: inline-flex; align-items: center; gap: 8px; padding: 9px 22px; border-radius: 999px; border: 1px solid rgba(232,222,208,0.35); font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; background: transparent; color: #e8ded0; transition: background 0.2s; }
    .add-btn:hover { background: rgba(232,222,208,0.08); }
    .add-btn .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }

    .section-label { font-size: 0.55rem; letter-spacing: 0.3em; text-transform: uppercase; opacity: 0.4; }

    .modal-backdrop { position: fixed; inset: 0; z-index: 300; background: rgba(0,0,0,0.55); backdrop-filter: blur(8px); display: none; align-items: center; justify-content: center; padding: 24px; }
    .modal-backdrop.open { display: flex; }
    .modal { background: #ece4d8; border-radius: 20px; border: 2px solid #1f1f1f; box-shadow: 6px 6px 0 #1f1f1f; padding: 28px; width: 100%; max-width: 400px; color: #2b2b2b; }
    .modal label { display: block; font-size: 0.6rem; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; color: #4a4a4a; margin-bottom: 5px; }
    .modal input, .modal textarea { width: 100%; padding: 10px 14px; border-radius: 12px; border: 2px solid #1f1f1f; background: #f5efe6; font-size: 0.85rem; outline: none; box-shadow: 3px 3px 0 #1f1f1f; color: #2b2b2b; font-family: inherit; margin-bottom: 14px; }
    .modal textarea { resize: none; height: 75px; }
    .modal input[type="file"] { box-shadow: none; padding: 8px; }
    .modal-submit { width: 100%; padding: 12px; border-radius: 12px; background: #2b2b2b; color: white; font-weight: 600; border: 2px solid #1f1f1f; box-shadow: 4px 4px 0 #1f1f1f; cursor: pointer; font-family: inherit; font-size: 0.85rem; transition: all 0.15s; }
    .modal-submit:hover { transform: translate(2px,2px); box-shadow: none; }
    .modal-cancel { width: 100%; padding: 9px; margin-top: 6px; background: transparent; border: none; color: #4a4a4a; cursor: pointer; font-size: 0.78rem; font-family: inherit; }
    .modal-cancel:hover { color: #2b2b2b; }

    @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    .fade-up { animation: fadeUp 0.5s ease both; }
    .d1 { animation-delay: 0.05s; } .d2 { animation-delay: 0.12s; } .d3 { animation-delay: 0.2s; } .d4 { animation-delay: 0.28s; }

    @keyframes lbBackdropIn  { from { opacity: 0; } to { opacity: 1; } }
    @keyframes lbBackdropOut { from { opacity: 1; } to { opacity: 0; } }
    @keyframes lbCardIn  { from { opacity: 0; transform: translateY(24px) scale(0.96); } to { opacity: 1; transform: translateY(0) scale(1); } }
    @keyframes lbCardOut { from { opacity: 1; transform: translateY(0) scale(1); } to { opacity: 0; transform: translateY(24px) scale(0.96); } }

    #lightbox { pointer-events: none; }
    #lightbox.lb-open { pointer-events: all; }
    #lightbox.lb-animating-in  { animation: lbBackdropIn  0.25s ease forwards; }
    #lightbox.lb-animating-out { animation: lbBackdropOut 0.25s ease forwards; }
    #lb-card.lb-animating-in  { animation: lbCardIn  0.3s cubic-bezier(0.23,1,0.32,1) forwards; }
    #lb-card.lb-animating-out { animation: lbCardOut 0.22s ease forwards; }

    #add-modal input[type="text"], #add-modal input[type="time"], #add-modal textarea, #add-modal select {
      background-color: rgba(101,75,55,0.25) !important; color: #e8ded0 !important;
      border-color: rgba(232,222,208,0.15) !important; color-scheme: dark;
    }
    #add-modal input::placeholder, #add-modal textarea::placeholder { color: rgba(232,222,208,0.25) !important; }
    #add-modal input[type="text"]:focus, #add-modal input[type="time"]:focus, #add-modal textarea:focus, #add-modal select:focus {
      background-color: rgba(101,75,55,0.35) !important; border-color: rgba(232,222,208,0.35) !important; outline: none;
    }
    #add-modal select option { background-color: #2a1f18; color: #e8ded0; }

    #chat-messages { scrollbar-width: thin; }
    #chat-messages::-webkit-scrollbar { width: 3px; }
    #chat-messages::-webkit-scrollbar-thumb { background: rgba(232,222,208,0.1); border-radius: 2px; }

    .chat-msg { opacity: 0; transform: translateY(6px); animation: chatIn 0.25s ease forwards; }
    @keyframes chatIn { to { opacity: 1; transform: translateY(0); } }
  </style>
</head>

<body>
  <p id="transition-sub" style="font-size:0.6rem;letter-spacing:0.35em;text-transform:uppercase;color:rgba(232,222,208,0.4);opacity:0;transition:opacity 0.5s ease 0.35s;">Finding your next NYC adventure</p>
</div>

{% include '_nav.html.jinja' %}

{% with messages = get_flashed_messages() %}
  {% if messages %}
    <div class="fixed top-4 left-1/2 -translate-x-1/2 z-50 flex flex-col gap-2">
      {% for message in messages %}
        <div class="px-5 py-3 rounded-xl text-white text-sm border border-white/20 shadow-lg" style="background:var(--accent);">{{ message }}</div>
      {% endfor %}
    </div>
  {% endif %}
{% endwith %}

<div class="max-w-5xl mx-auto px-8 py-10">

  <div class="flex items-end justify-between mb-10 fade-up">
    <div>
      <a href="/browse" class="text-xs tracking-widest uppercase opacity-30 hover:opacity-60 transition-opacity">← Back</a>
      <h1 class="serif text-6xl font-light mt-2 leading-none">{{ borough.name | capitalize }}</h1>
      <div class="w-10 h-px mt-4 opacity-50" style="background:var(--accent);"></div>
      <p class="text-xs opacity-30 tracking-widest uppercase mt-3">New York City</p>
    </div>
    <button class="add-btn" onclick="openModal()">
      <span class="dot"></span>
      Add a location
    </button>
  </div>

  {% if locations %}
  <div class="fade-up d1">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <p class="section-label">Featured</p>
      <div style="display:flex;gap:8px;">
        <button onclick="featStep(-1)" id="feat-prev" style="width:32px;height:32px;border-radius:50%;background:rgba(232,222,208,0.08);border:1px solid rgba(232,222,208,0.2);color:#e8ded0;font-size:1rem;cursor:pointer;transition:background 0.2s;display:flex;align-items:center;justify-content:center;">‹</button>
        <button onclick="featStep(1)"  id="feat-next" style="width:32px;height:32px;border-radius:50%;background:rgba(232,222,208,0.08);border:1px solid rgba(232,222,208,0.2);color:#e8ded0;font-size:1rem;cursor:pointer;transition:background 0.2s;display:flex;align-items:center;justify-content:center;">›</button>
      </div>
    </div>
    <div style="overflow:hidden;border-radius:18px;">
      <div id="feat-track" class="flex gap-4 transition-transform duration-500 ease-[cubic-bezier(0.23,1,0.32,1)]">
        {% for loc in locations %}
        <div class="featured-card shrink-0 basis-1/3 h-[340px]" onclick="openDetail({{ loop.index0 }})">
          {% if loc.Image %}
            {% if loc.Image.startswith('http') %}
              <img src="{{ loc.Image }}" alt="{{ loc.Name }}">
            {% else %}
              <img src="{{ url_for('static', filename='uploads/' + loc.Image) }}" alt="{{ loc.Name }}">
            {% endif %}
          {% else %}<div class="no-img">No image</div>{% endif %}
          <div class="overlay"></div>
          <div class="info">
            <span class="badge">{% if loop.index0 == 0 %}Featured{% elif loop.index0 == 1 %}Hidden gem{% else %}Local pick{% endif %}</span>
            <p class="card-title">{{ loc.Name }}</p>
            <p class="card-sub">{{ loc.DatePosted.strftime('%b %d, %Y') if loc.DatePosted else '' }}</p>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
    <div id="feat-dots" style="display:flex;gap:6px;margin-top:14px;justify-content:center;"></div>
  </div>

  {% if locations | length > 3 %}
  <div class="mt-12 fade-up d2">
    <p class="section-label mb-4">All Locations</p>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
      {% for loc in locations[3:] %}
      <div class="gem-card" onclick="openDetail({{ loop.index0 + 3 }})">
        {% if loc.Image %}
          {% if loc.Image.startswith('http') %}
            <img src="{{ loc.Image }}" alt="{{ loc.Name }}">
          {% else %}
            <img src="{{ url_for('static', filename='uploads/' + loc.Image) }}" alt="{{ loc.Name }}">
          {% endif %}
        {% else %}<div class="no-img"></div>{% endif %}
        <div class="gem-info" style="display:flex;align-items:flex-start;justify-content:space-between;">
          <div>
            <p class="gem-title">{{ loc.Name }}</p>
            <p class="gem-meta">{{ loc.DatePosted.strftime('%b %d, %Y') if loc.DatePosted else '' }}</p>
          </div>
          <button class="like-btn"
            data-id="{{ loc.ID }}"
            data-borough="{{ borough.name | replace(' ', '-') }}"
            data-liked="{{ 'true' if loc.ID in liked_ids else 'false' }}"
            onclick="event.stopPropagation(); toggleLike(this)"
            style="background:none;border:none;cursor:pointer;display:flex;align-items:center;gap:4px;color:{{ 'var(--accent)' if loc.ID in liked_ids else 'rgba(232,222,208,0.3)' }};font-size:0.7rem;padding:2px 0;flex-shrink:0;">
            <span class="like-heart">{{ '♥' if loc.ID in liked_ids else '♡' }}</span>
            <span class="like-count">{{ loc.LikeCount or 0 }}</span>
          </button>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {% else %}
  <div class="fade-up d1 flex flex-col items-center justify-center py-32 opacity-30">
    <p class="serif text-3xl font-light mb-2">No gems yet</p>
    <p class="text-xs tracking-widest uppercase">Be the first to add a location</p>
  </div>
  {% endif %}

</div>

<div class="max-w-5xl mx-auto px-8 pb-16 mt-12 fade-up">
  <div style="background:rgba(0,0,0,0.25);border:1px solid rgba(232,222,208,0.1);border-radius:24px;overflow:hidden;display:flex;flex-direction:column;height:500px;">
    <div style="padding:16px 22px;border-bottom:1px solid rgba(232,222,208,0.08);display:flex;align-items:center;justify-content:space-between;">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:8px;height:8px;border-radius:50%;background:var(--accent);box-shadow:0 0 8px var(--accent);"></div>
        <p style="font-size:0.7rem;font-weight:500;color:#e8ded0;letter-spacing:0.05em;">{{ borough.name | capitalize }} Community Chat</p>
      </div>
      <div style="display:flex;align-items:center;gap:8px;">
        <span id="online-count" style="font-size:0.6rem;color:rgba(232,222,208,0.4);letter-spacing:0.1em;">0 online</span>
        <div style="width:7px;height:7px;border-radius:50%;background:#4ade80;box-shadow:0 0 6px #4ade80;"></div>
      </div>
    </div>
    <div id="chat-messages" style="flex:1;overflow-y:auto;overflow-x:hidden;padding:16px 20px;display:flex;flex-direction:column;gap:4px;min-height:0;"></div>
    <div style="padding:14px 16px;border-top:1px solid rgba(232,222,208,0.08);display:flex;align-items:center;gap:10px;background:rgba(0,0,0,0.15);">
      <input id="chat-input" type="text" placeholder="Type your message here..." maxlength="300"
        onkeydown="if(event.key==='Enter') sendMessage()"
        style="flex:1;background:rgba(232,222,208,0.06);border:1px solid rgba(232,222,208,0.12);border-radius:999px;padding:11px 18px;color:#e8ded0;font-size:0.82rem;font-family:inherit;outline:none;transition:border-color 0.2s;"
        onfocus="this.style.borderColor='rgba(232,222,208,0.3)'"
        onblur="this.style.borderColor='rgba(232,222,208,0.12)'">
      <button onclick="sendMessage()" style="width:42px;height:42px;border-radius:50%;background:var(--accent);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:opacity 0.2s, transform 0.15s;font-size:1rem;"
        onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'"
        onmousedown="this.style.transform='scale(0.93)'" onmouseup="this.style.transform='scale(1)'">➤</button>
    </div>
  </div>
</div>

<div id="lightbox" class="fixed inset-0 z-[400] flex-col items-center justify-center bg-black/50 backdrop-blur-2xl" style="display:none;">
  <button onclick="closeLightbox()" style="position:absolute;top:24px;right:28px;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:#e8ded0;font-size:1.1rem;width:38px;height:38px;border-radius:50%;cursor:pointer;line-height:1;">✕</button>
  <p id="lb-counter" style="position:absolute;top:28px;left:50%;transform:translateX(-50%);font-size:0.55rem;letter-spacing:0.3em;text-transform:uppercase;color:rgba(232,222,208,0.35);"></p>

  <div style="display:flex;align-items:center;gap:16px;width:100%;max-width:960px;padding:0 24px;box-sizing:border-box;">
    <button id="lb-prev" onclick="lbStep(-1)" style="position:absolute;left:16px;top:50%;transform:translateY(-50%);width:40px;height:40px;border-radius:50%;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);color:#e8ded0;font-size:1.3rem;cursor:pointer;z-index:10;display:flex;align-items:center;justify-content:center;transition:background 0.2s;">‹</button>
    <button id="lb-next" onclick="lbStep(1)"  style="position:absolute;right:16px;top:50%;transform:translateY(-50%);width:40px;height:40px;border-radius:50%;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);color:#e8ded0;font-size:1.3rem;cursor:pointer;z-index:10;display:flex;align-items:center;justify-content:center;transition:background 0.2s;">›</button>

    <div id="lb-card" style="width:100%;max-width:780px;padding:0 64px;box-sizing:border-box;margin:auto;">
      <div id="lb-map-area" class="relative h-[220px] bg-black/40 flex items-end justify-between p-4 gap-2">
        <div class="absolute inset-0 opacity-[0.06]" style="background-image:linear-gradient(rgba(232,222,208,.8) 1px,transparent 1px),linear-gradient(90deg,rgba(232,222,208,.8) 1px,transparent 1px);background-size:30px 30px"></div>
        <div class="absolute top-4 left-4 z-10 flex items-center gap-2 rounded-full px-3 py-1" style="background:var(--accent)">
          <span class="w-1.5 h-1.5 rounded-full bg-white"></span>
          <span id="lb-badge" class="text-[10px] font-bold tracking-[.2em] uppercase text-white"></span>
        </div>
        <span id="lb-coords" class="z-10 text-[10px] tracking-[.12em] uppercase text-[#e8ded0]/25 font-mono"></span>
        <a id="lb-map-link" href="#" target="_blank" class="z-10 inline-flex items-center gap-1.5 rounded-full px-4 py-1.5 bg-[#e8ded0]/[.08] border border-[#e8ded0]/20 text-[#e8ded0] text-[10px] font-bold tracking-[.18em] uppercase no-underline hover:bg-[#e8ded0]/[.15] transition-colors">Open in Maps ↗</a>
      </div>
      <div class="h-[3px] w-full" style="background:var(--accent)"></div>
      <div class="px-6 pt-5">
        <div class="flex items-center gap-2 mb-3">
          <span id="lb-type" class="text-[9px] font-bold tracking-[.22em] uppercase px-2.5 py-0.5 rounded-sm text-white" style="background:var(--accent)"></span>
          <span id="lb-open-status" class="inline-flex items-center gap-1 text-[9px] font-bold tracking-[.16em] uppercase text-green-400 bg-green-400/10 border border-green-400/20 rounded-sm px-2.5 py-0.5">
            <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>Open now
          </span>
        </div>
        <h2 id="lb-title" class="font-['Cormorant_Garamond'] font-light text-[2rem] leading-none text-[#e8ded0] mb-1"></h2>
        <p id="lb-meta" class="text-[10px] tracking-[.18em] uppercase text-[#e8ded0]/35 mb-3"></p>
        <p id="lb-desc" class="text-[13px] text-[#e8ded0]/60 leading-relaxed mb-4"></p>
        <div id="lb-tags" class="flex flex-wrap gap-1.5 mb-5"></div>
      </div>
      <div class="border-t border-[#e8ded0]/[.08] bg-black/15 px-6 py-4">
        <p class="text-[9px] font-bold tracking-[.24em] uppercase text-[#e8ded0]/35 mb-3">Hours</p>
        <div id="lb-hours" class="grid grid-cols-2 gap-x-4 gap-y-0"></div>
      </div>
      <div class="flex items-center justify-between border-t border-[#e8ded0]/[.08] px-6 py-4">
        <p id="lb-addr-text" class="text-[10px] text-[#e8ded0]/30 tracking-wide leading-relaxed"></p>
        <button id="lb-like-btn" onclick="toggleLikeById()" class="flex items-center gap-1.5 px-4 py-2 rounded-sm border border-[#e8ded0]/15 bg-[#e8ded0]/[.06] text-[#e8ded0] font-bold text-[11px] tracking-[.14em] uppercase hover:bg-[#e8ded0]/10 transition-colors cursor-pointer">
          <span id="lb-heart">♡</span><span id="lb-like-count">0</span>
          <span class="text-[8px] opacity-50 tracking-[.15em]">likes</span>
        </button>
      </div>
      <button id="lb-delete-btn" onclick="openDeleteModal()" class="mt-3 w-full flex items-center justify-center gap-2 px-4 py-2 rounded-sm border border-red-400/20 bg-red-400/10 text-red-400 font-bold text-[11px] tracking-[.14em] uppercase hover:bg-red-400/20 transition-colors cursor-pointer hidden">Remove location</button>
    </div>
  </div>
  <div id="lb-dots" style="display:flex;gap:8px;margin-top:28px;"></div>
</div>

<!-- ADD LOCATION MODAL -->
<div id="add-modal" onclick="if(event.target===this)closeAddModal()" style="
  display:none; position:fixed; inset:0; z-index:500;
  background:rgba(0,0,0,0.7); backdrop-filter:blur(16px);
  align-items:center; justify-content:center; padding:20px;
">
  <div style="
    width:100%; max-width:520px; max-height:92vh;
    background:linear-gradient(145deg,#1a1410 0%,#120e0a 100%);
    border:1px solid rgba(232,222,208,0.12);
    border-radius:24px; overflow:hidden;
    display:flex; flex-direction:column;
    box-shadow:0 32px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(232,222,208,0.05);
  " onclick="event.stopPropagation()">

    <!-- Header with accent bar -->
    <div style="position:relative; overflow:hidden; flex-shrink:0;">
      <div style="height:3px; background:linear-gradient(90deg, var(--accent), transparent);"></div>
      <div style="padding:22px 26px 18px; display:flex; align-items:flex-start; justify-content:space-between;">
        <div>
          <div style="display:flex; align-items:center; gap:8px; margin-bottom:4px;">
            <div style="width:6px;height:6px;border-radius:50%;background:var(--accent);box-shadow:0 0 8px var(--accent);"></div>
            <p style="font-size:0.5rem;letter-spacing:0.3em;text-transform:uppercase;color:rgba(232,222,208,0.3);">{{ borough.name | capitalize }}</p>
          </div>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:1.7rem;font-weight:300;color:#e8ded0;line-height:1.1;">Add a Hidden Gem</h2>
        </div>
        <button onclick="closeAddModal()" style="
          width:32px;height:32px;border-radius:50%;flex-shrink:0;margin-top:4px;
          background:rgba(232,222,208,0.06);border:1px solid rgba(232,222,208,0.12);
          color:rgba(232,222,208,0.4);cursor:pointer;font-size:0.9rem;
          display:flex;align-items:center;justify-content:center;
          transition:all 0.2s;
        " onmouseover="this.style.background='rgba(232,222,208,0.12)';this.style.color='#e8ded0'"
           onmouseout="this.style.background='rgba(232,222,208,0.06)';this.style.color='rgba(232,222,208,0.4)'">✕</button>
      </div>
    </div>

    <!-- Step indicator -->
    <div style="padding:0 26px 16px; display:flex; gap:6px; flex-shrink:0;" id="step-indicators">
      <div class="step-dot active" data-step="0" style="flex:1;height:2px;border-radius:999px;background:var(--accent);transition:background 0.3s;"></div>
      <div class="step-dot" data-step="1" style="flex:1;height:2px;border-radius:999px;background:rgba(232,222,208,0.15);transition:background 0.3s;"></div>
      <div class="step-dot" data-step="2" style="flex:1;height:2px;border-radius:999px;background:rgba(232,222,208,0.15);transition:background 0.3s;"></div>
    </div>

    <!-- Form -->
    <form id="add-location-form" method="POST" action="/borough/{{ borough.name | replace(' ', '-') }}/add" enctype="multipart/form-data" style="flex:1;overflow:hidden;display:flex;flex-direction:column;">

      <div style="flex:1;overflow-y:auto;padding:0 26px;">

        <!-- STEP 1: Basic Info + Address Autocomplete -->
        <div id="step-0" class="form-step">
          <p style="font-size:0.55rem;letter-spacing:0.25em;text-transform:uppercase;color:rgba(232,222,208,0.3);margin-bottom:18px;">Step 1 — Basic Info</p>

          <!-- Location Name -->
          <div style="margin-bottom:16px;">
            <label style="display:block;font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(232,222,208,0.4);margin-bottom:8px;">Location Name <span style="color:var(--accent);">*</span></label>
            <input type="text" name="name" required placeholder="e.g. Domino Park" id="input-name" style="
              width:100%;padding:12px 16px;border-radius:12px;
              background:rgba(232,222,208,0.05);border:1px solid rgba(232,222,208,0.12);
              color:#e8ded0;font-size:0.9rem;font-family:inherit;outline:none;transition:all 0.2s;
            " onfocus="this.style.borderColor='rgba(232,222,208,0.35)';this.style.background='rgba(232,222,208,0.08)'"
               onblur="this.style.borderColor='rgba(232,222,208,0.12)';this.style.background='rgba(232,222,208,0.05)'">
          </div>

          <!-- Address with autocomplete -->
          <div style="margin-bottom:8px;">
            <label style="display:block;font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(232,222,208,0.4);margin-bottom:8px;">Address <span style="color:var(--accent);">*</span></label>
            <div style="position:relative;">
              <input type="text" name="address" required placeholder="Start typing an address…" id="input-address"
                autocomplete="off"
                oninput="onAddressInput(this.value)"
                onfocus="this.style.borderColor='rgba(232,222,208,0.35)';this.style.background='rgba(232,222,208,0.08)';showSuggestions()"
                onblur="this.style.borderColor='rgba(232,222,208,0.12)';this.style.background='rgba(232,222,208,0.05)';setTimeout(hideSuggestions,200)"
                style="width:100%;padding:12px 40px 12px 16px;border-radius:12px;background:rgba(232,222,208,0.05);border:1px solid rgba(232,222,208,0.12);color:#e8ded0;font-size:0.9rem;font-family:inherit;outline:none;transition:all 0.2s;">

              <!-- Loading spinner -->
              <div id="addr-spinner" style="display:none;position:absolute;right:14px;top:50%;transform:translateY(-50%);">
                <div style="width:14px;height:14px;border:2px solid rgba(232,222,208,0.1);border-top-color:var(--accent);border-radius:50%;animation:spin 0.7s linear infinite;"></div>
              </div>

              <!-- Suggestions dropdown -->
              <div id="addr-suggestions" style="
                display:none;position:absolute;top:calc(100% + 6px);left:0;right:0;z-index:999;
                background:#1a1410;border:1px solid rgba(232,222,208,0.12);border-radius:14px;
                overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.5);
              "></div>
            </div>
          </div>

          <!-- AI enrichment card -->
          <div id="addr-enrichment-card" style="display:none;margin-bottom:16px;border-radius:14px;overflow:hidden;border:1px solid rgba(232,222,208,0.1);">
            <div id="addr-card-inner" style="padding:16px 18px;background:linear-gradient(135deg,rgba(0,0,0,0.4),rgba(0,0,0,0.2));position:relative;">
              <div style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),transparent);"></div>
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                <div style="flex:1;">
                  <div style="display:flex;align-items:center;gap:6px;margin-bottom:6px;">
                    <div id="addr-type-badge" style="font-size:0.45rem;letter-spacing:0.2em;text-transform:uppercase;padding:2px 8px;border-radius:999px;background:var(--accent);color:#fff;opacity:0.85;"></div>
                    <div style="font-size:0.45rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(232,222,208,0.3);display:flex;align-items:center;gap:3px;">
                      <svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.2L22 12l-7.6 2.8L12 22l-2.4-7.2L2 12l7.6-2.8z"/></svg>
                      AI enriched
                    </div>
                  </div>
                  <p id="addr-street" style="font-size:0.9rem;font-weight:600;color:#e8ded0;margin-bottom:2px;"></p>
                  <p id="addr-city" style="font-size:0.75rem;color:rgba(232,222,208,0.5);margin-bottom:10px;"></p>
                  <p id="addr-description" style="font-size:0.72rem;color:rgba(232,222,208,0.55);line-height:1.5;font-style:italic;"></p>
                  <div id="addr-fun-fact" style="display:none;margin-top:8px;padding:8px 10px;background:rgba(232,222,208,0.04);border:1px solid rgba(232,222,208,0.08);border-radius:8px;font-size:0.65rem;color:rgba(232,222,208,0.45);line-height:1.5;"></div>
                </div>
                <div style="flex-shrink:0;text-align:right;">
                  <p id="addr-coords" style="font-size:0.6rem;color:rgba(232,222,208,0.3);font-family:monospace;line-height:1.8;"></p>
                  <a id="addr-map-link" href="#" target="_blank" style="font-size:0.55rem;color:var(--accent);text-decoration:none;letter-spacing:0.1em;text-transform:uppercase;opacity:0.7;">Maps ↗</a>
                </div>
              </div>
            </div>
          </div>

          <!-- Description -->
          <div style="margin-bottom:20px;">
            <label style="display:block;font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(232,222,208,0.4);margin-bottom:8px;">Description</label>
            <textarea name="description" id="input-description" placeholder="What makes this place special?" rows="3" style="
              width:100%;padding:12px 16px;border-radius:12px;
              background:rgba(232,222,208,0.05);border:1px solid rgba(232,222,208,0.12);
              color:#e8ded0;font-size:0.9rem;font-family:inherit;outline:none;resize:none;transition:all 0.2s;
            " onfocus="this.style.borderColor='rgba(232,222,208,0.35)';this.style.background='rgba(232,222,208,0.08)'"
               onblur="this.style.borderColor='rgba(232,222,208,0.12)';this.style.background='rgba(232,222,208,0.05)'"></textarea>
          </div>
        </div>

        <!-- STEP 2: Photo -->
        <div id="step-1" class="form-step" style="display:none;">
          <p style="font-size:0.55rem;letter-spacing:0.25em;text-transform:uppercase;color:rgba(232,222,208,0.3);margin-bottom:18px;">Step 2 — Photo</p>

          <label id="photo-drop-zone" style="
            display:flex;flex-direction:column;align-items:center;justify-content:center;
            gap:12px;padding:40px 20px;border-radius:16px;cursor:pointer;
            border:2px dashed rgba(232,222,208,0.15);
            background:rgba(232,222,208,0.03);
            transition:all 0.2s;text-align:center;margin-bottom:16px;
          " onmouseover="this.style.borderColor='rgba(232,222,208,0.3)';this.style.background='rgba(232,222,208,0.06)'"
             onmouseout="this.style.borderColor='rgba(232,222,208,0.15)';this.style.background='rgba(232,222,208,0.03)'">
            <div id="photo-preview-wrap" style="display:none;width:100%;border-radius:10px;overflow:hidden;max-height:180px;">
              <img id="photo-preview-img" src="" style="width:100%;height:180px;object-fit:cover;display:block;">
            </div>
            <div id="photo-placeholder">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" style="margin:0 auto 8px;opacity:0.3;">
                <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12" stroke="#e8ded0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <p style="font-size:0.8rem;color:rgba(232,222,208,0.5);">Click to upload a photo</p>
              <p style="font-size:0.65rem;color:rgba(232,222,208,0.25);margin-top:4px;">PNG, JPG, GIF up to 10MB</p>
            </div>
            <input type="file" name="image" accept="image/*" class="hidden" id="photo-input"
              onchange="previewPhoto(this)">
          </label>

          <p id="photo-filename" style="font-size:0.65rem;color:rgba(232,222,208,0.3);text-align:center;display:none;"></p>
        </div>

        <!-- STEP 3: Hours -->
        <div id="step-2" class="form-step" style="display:none;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
            <p style="font-size:0.55rem;letter-spacing:0.25em;text-transform:uppercase;color:rgba(232,222,208,0.3);">Step 3 — Hours</p>
            <div id="hours-autofill-badge" style="display:none;font-size:0.5rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(74,222,128,0.7);padding:3px 8px;border-radius:999px;background:rgba(74,222,128,0.08);border:1px solid rgba(74,222,128,0.15);">
              ✓ Auto-filled from Google
            </div>
          </div>

          <div style="display:flex;gap:8px;margin-bottom:16px;">
            <select id="hours-preset" style="
              flex:1;background:rgba(232,222,208,0.05);border:1px solid rgba(232,222,208,0.12);
              color:rgba(232,222,208,0.5);padding:8px 12px;border-radius:10px;
              font-size:0.75rem;font-family:inherit;outline:none;
            ">
              <option value="">Apply a preset…</option>
              <option value="9-5">Weekdays 9am–5pm</option>
              <option value="24-7">Open 24/7</option>
              <option value="closed">Closed all week</option>
            </select>
            <button type="button" onclick="applyPreset()" style="
              padding:8px 16px;border-radius:10px;
              background:var(--accent);border:none;
              color:white;font-size:0.7rem;font-family:inherit;
              cursor:pointer;white-space:nowrap;
              letter-spacing:0.1em;text-transform:uppercase;
              transition:opacity 0.2s;
            " onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">Apply</button>
          </div>

          <div style="display:flex;flex-direction:column;gap:2px;border-radius:14px;overflow:hidden;border:1px solid rgba(232,222,208,0.08);">
            {% set days = ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"] %}
            {% for d in days %}
            <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:rgba(232,222,208,0.03);border-bottom:1px solid rgba(232,222,208,0.05);">
              <span style="width:28px;font-size:0.65rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(232,222,208,0.35);flex-shrink:0;">{{ d }}</span>
              <div id="hours-row-{{ d }}" style="display:flex;align-items:center;gap:6px;flex:1;">
                <input type="time" name="hours_{{ d }}_open" style="
                  flex:1;background:rgba(232,222,208,0.06);border:1px solid rgba(232,222,208,0.1);
                  border-radius:8px;padding:6px 8px;color:rgba(232,222,208,0.7);
                  font-size:0.75rem;font-family:inherit;outline:none;min-width:0;
                  color-scheme:dark;
                ">
                <span style="color:rgba(232,222,208,0.2);font-size:0.7rem;">–</span>
                <input type="time" name="hours_{{ d }}_close" style="
                  flex:1;background:rgba(232,222,208,0.06);border:1px solid rgba(232,222,208,0.1);
                  border-radius:8px;padding:6px 8px;color:rgba(232,222,208,0.7);
                  font-size:0.75rem;font-family:inherit;outline:none;min-width:0;
                  color-scheme:dark;
                ">
              </div>
              <label style="display:flex;align-items:center;gap:5px;cursor:pointer;flex-shrink:0;">
                <input type="checkbox" name="hours_{{ d }}_closed" style="accent-color:var(--accent);width:12px;height:12px;" onchange="toggleClosed('{{ d }}')">
                <span style="font-size:0.6rem;color:rgba(232,222,208,0.25);">Closed</span>
              </label>
            </div>
            {% endfor %}
          </div>
        </div>

      </div>

      <!-- Footer navigation -->
      <div style="padding:16px 26px;border-top:1px solid rgba(232,222,208,0.06);display:flex;gap:10px;flex-shrink:0;background:rgba(0,0,0,0.2);">
        <button type="button" id="step-back-btn" onclick="modalStep(-1)" style="
          display:none;padding:11px 20px;border-radius:12px;
          background:rgba(232,222,208,0.06);border:1px solid rgba(232,222,208,0.12);
          color:rgba(232,222,208,0.5);font-size:0.7rem;font-family:inherit;
          cursor:pointer;letter-spacing:0.12em;text-transform:uppercase;
          transition:all 0.2s;
        " onmouseover="this.style.color='#e8ded0'" onmouseout="this.style.color='rgba(232,222,208,0.5)'">← Back</button>

        <button type="button" id="step-next-btn" onclick="modalStep(1)" style="
          flex:1;padding:12px;border-radius:12px;
          background:var(--accent);border:none;
          color:white;font-size:0.75rem;font-family:inherit;
          cursor:pointer;letter-spacing:0.15em;text-transform:uppercase;font-weight:600;
          transition:opacity 0.2s, transform 0.15s;
        " onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'"
           onmousedown="this.style.transform='scale(0.98)'" onmouseup="this.style.transform='scale(1)'">
          Continue →
        </button>

        <button type="submit" form="add-location-form" id="step-submit-btn" style="
          display:none;flex:1;padding:12px;border-radius:12px;
          background:var(--accent);border:none;
          color:white;font-size:0.75rem;font-family:inherit;
          cursor:pointer;letter-spacing:0.15em;text-transform:uppercase;font-weight:600;
          transition:opacity 0.2s, transform 0.15s;
        " onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
          Post Location ✦
        </button>
      </div>

    </form>
  </div>
</div>

<div id="delete-modal" style="display:none;position:fixed;inset:0;z-index:500;background:rgba(0,0,0,0.6);backdrop-filter:blur(8px);align-items:center;justify-content:center;padding:24px;">
  <div style="background:#111;border:1px solid rgba(232,222,208,0.12);border-radius:20px;padding:32px 28px;width:100%;max-width:360px;display:flex;flex-direction:column;align-items:center;">
    <div style="width:48px;height:48px;border-radius:50%;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);display:flex;align-items:center;justify-content:center;margin-bottom:20px;">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M8 4h4M3 6h14M5 6l1 10a2 2 0 002 2h4a2 2 0 002-2l1-10" stroke="rgba(239,68,68,0.9)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <p class="serif" style="font-size:1.4rem;font-weight:300;color:#e8ded0;margin-bottom:8px;text-align:center;line-height:1.2;">Remove this location?</p>
    <p style="font-size:0.75rem;color:rgba(232,222,208,0.4);text-align:center;line-height:1.6;margin-bottom:28px;">This can't be undone. The location and all its data will be permanently deleted.</p>
    <div style="display:flex;flex-direction:column;gap:8px;width:100%;">
      <button id="delete-confirm-btn" style="width:100%;padding:11px;border-radius:10px;background:rgba(239,68,68,0.15);border:1px solid rgba(239,68,68,0.3);color:rgb(239,68,68);font-size:0.7rem;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;cursor:pointer;font-family:inherit;">Yes, remove it</button>
      <button onclick="closeDeleteModal()" style="width:100%;padding:11px;border-radius:10px;background:rgba(232,222,208,0.05);border:1px solid rgba(232,222,208,0.12);color:rgba(232,222,208,0.5);font-size:0.7rem;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;cursor:pointer;font-family:inherit;">Cancel</button>
    </div>
  </div>
</div>

<div id="borough-switcher" style="position:fixed;bottom:24px;left:32px;z-index:50;">
  <button onclick="toggleSwitcher()"
    style="display:flex;align-items:center;gap:8px;padding:8px 16px;border-radius:999px;background:rgba(0,0,0,0.35);border:1px solid rgba(232,222,208,0.15);color:rgba(232,222,208,0.5);font-size:0.55rem;letter-spacing:0.25em;text-transform:uppercase;cursor:pointer;backdrop-filter:blur(8px);transition:all 0.2s;font-family:inherit;"
    onmouseover="this.style.color='#e8ded0';this.style.borderColor='rgba(232,222,208,0.3)'"
    onmouseout="this.style.color='rgba(232,222,208,0.5)';this.style.borderColor='rgba(232,222,208,0.15)'">
    <span style="width:5px;height:5px;border-radius:50%;background:var(--accent);flex-shrink:0;"></span>
    {{ borough.name }}
    <span id="switcher-arrow" style="transition:transform 0.25s;opacity:0.4;">▴</span>
  </button>
  <div id="switcher-menu" style="position:absolute;bottom:calc(100% + 8px);left:0;background:rgba(10,10,10,0.85);border:1px solid rgba(232,222,208,0.1);border-radius:14px;overflow:hidden;backdrop-filter:blur(12px);min-width:160px;transform-origin:bottom left;transform:scale(0.92) translateY(6px);opacity:0;pointer-events:none;transition:all 0.2s cubic-bezier(0.23,1,0.32,1);">
    {% set all_boroughs = [
      {"name": "manhattan",     "color": "#1a3a5c", "accent": "#2e6da4"},
      {"name": "brooklyn",      "color": "#5c3a1a", "accent": "#a4642e"},
      {"name": "queens",        "color": "#1a5c3a", "accent": "#2ea464"},
      {"name": "bronx",         "color": "#2a2a2a", "accent": "#555555"},
      {"name": "staten island", "color": "#3a3328", "accent": "#7a6a50"},
    ] %}
    {% for b in all_boroughs %}
    <a href="/borough/{{ b.name | replace(' ', '-') }}"
       style="display:flex;align-items:center;gap:10px;padding:10px 16px;text-decoration:none;font-size:0.6rem;letter-spacing:0.18em;text-transform:uppercase;transition:background 0.15s;color:{{ 'rgba(232,222,208,0.9)' if b.name == borough.name else 'rgba(232,222,208,0.4)' }};background:{{ 'rgba(232,222,208,0.06)' if b.name == borough.name else 'transparent' }};"
       onmouseover="this.style.background='rgba(232,222,208,0.08)';this.style.color='#e8ded0'"
       onmouseout="this.style.background='{{ 'rgba(232,222,208,0.06)' if b.name == borough.name else 'transparent' }}';this.style.color='{{ 'rgba(232,222,208,0.9)' if b.name == borough.name else 'rgba(232,222,208,0.4)' }}'">
      <span style="width:4px;height:4px;border-radius:50%;flex-shrink:0;background:{{ 'var(--accent)' if b.name == borough.name else 'rgba(232,222,208,0.2)' }};"></span>
      {{ b.name }}
      {% if b.name == borough.name %}<span style="margin-left:auto;font-size:0.5rem;opacity:0.4;">current</span>{% endif %}
    </a>
    {% endfor %}
  </div>
</div>

<script>
  const locations = {{ locations_json | safe }};

  async function toggleLike(btn) {
    const id = btn.dataset.id, borough = btn.dataset.borough;
    const res = await fetch(`/borough/${borough}/like/${id}`, { method: 'POST' });
    const data = await res.json();
    btn.dataset.liked = data.liked ? 'true' : 'false';
    btn.querySelector('.like-heart').textContent = data.liked ? '♥' : '♡';
    btn.querySelector('.like-count').textContent = data.count;
    btn.style.color = data.liked ? 'var(--accent)' : 'rgba(232,222,208,0.3)';
    if (document.getElementById('lightbox').style.display === 'flex') {
      const loc = locations[lbIndex];
      if (loc && String(loc.ID) === String(id)) {
        loc.LikeCount = data.count; loc.Liked = data.liked;
        document.getElementById('lb-like-count').textContent = data.count;
        document.getElementById('lb-heart').textContent = data.liked ? '♥' : '♡';
        document.getElementById('lb-like-btn').style.color = data.liked ? 'var(--accent)' : '#e8ded0';
      }
    }
  }

  async function toggleLikeById() {
    const loc = locations[lbIndex]; if (!loc) return;
    const boroughSlug = '{{ borough.name | replace(" ", "-") }}';
    const res = await fetch(`/borough/${boroughSlug}/like/${loc.ID}`, { method: 'POST' });
    const data = await res.json();
    loc.Liked = data.liked; loc.LikeCount = data.count;
    document.getElementById('lb-like-count').textContent = data.count;
    document.getElementById('lb-heart').textContent = data.liked ? '♥' : '♡';
    document.getElementById('lb-like-btn').style.color = data.liked ? 'var(--accent)' : '#e8ded0';
    const btn = document.querySelector(`.like-btn[data-id="${loc.ID}"]`);
    if (btn) { btn.dataset.liked = data.liked ? 'true' : 'false'; btn.querySelector('.like-heart').textContent = data.liked ? '♥' : '♡'; btn.querySelector('.like-count').textContent = data.count; btn.style.color = data.liked ? 'var(--accent)' : 'rgba(232,222,208,0.3)'; }
  }

  let featIndex = 0;
  const featTotal = locations.length;
  const VISIBLE = 3;

  function buildFeatDots() {
    const dotsEl = document.getElementById('feat-dots'); if (!dotsEl) return;
    dotsEl.innerHTML = '';
    const pages = Math.max(1, featTotal - VISIBLE + 1);
    for (let i = 0; i < pages; i++) {
      const d = document.createElement('div');
      d.style.cssText = `width:5px;height:5px;border-radius:50%;cursor:pointer;background:${i===featIndex?'var(--accent)':'rgba(232,222,208,0.2)'};transition:background 0.2s;`;
      d.onclick = () => { featIndex = i; updateFeatSlide(); };
      dotsEl.appendChild(d);
    }
  }

  function updateFeatSlide() {
    const track = document.getElementById('feat-track'); if (!track) return;
    track.style.transform = `translateX(-${(100/VISIBLE)*featIndex}%)`;
    const maxIndex = Math.max(0, featTotal - VISIBLE);
    document.getElementById('feat-prev').style.opacity = featIndex > 0 ? '1' : '0.25';
    document.getElementById('feat-next').style.opacity = featIndex < maxIndex ? '1' : '0.25';
    buildFeatDots();
  }

  function featStep(dir) {
    featIndex = Math.max(0, Math.min(featIndex + dir, Math.max(0, featTotal - VISIBLE)));
    updateFeatSlide();
  }

  window.addEventListener('load', () => { buildFeatDots(); updateFeatSlide(); });

  let lbIndex = 0;
  const lbTotal = locations.length;
  let lbAnimating = false;

  function openDetail(index) {
    lbIndex = index; renderLightbox();
    const lb = document.getElementById('lightbox'), card = document.getElementById('lb-card');
    lb.classList.remove('hidden'); lb.style.display = 'flex';
    lb.classList.add('lb-open','lb-animating-in'); card.classList.add('lb-animating-in');
    lb.addEventListener('animationend',   () => lb.classList.remove('lb-animating-in'),   { once: true });
    card.addEventListener('animationend', () => card.classList.remove('lb-animating-in'), { once: true });
    document.body.style.overflow = 'hidden';
    document.addEventListener('keydown', lbKeyHandler);
  }

  function renderLightbox() {
    const loc = locations[lbIndex]; if (!loc) return;
    const openStatus = document.getElementById('lb-open-status');
    let isOpen = false;
    if (loc.Hours && Array.isArray(loc.Hours)) {
      const today = loc.Hours[[6,0,1,2,3,4,5][new Date().getDay()]];
      if (today && today.hours && today.hours !== "Closed") {
        const [os, cs] = today.hours.split(" – ");
        const now = new Date();
        const ot = new Date(); ot.setHours(...os.split(":").map(Number), 0);
        const ct = new Date(); ct.setHours(...cs.split(":").map(Number), 0);
        if (now >= ot && now <= ct) isOpen = true;
      }
    }
    openStatus.style.cssText = isOpen
      ? "display:inline-flex;align-items:center;gap:4px;color:rgb(74,222,128);border-color:rgba(74,222,128,0.3);background:rgba(74,222,128,0.1);border-radius:2px;padding:2px 10px;font-size:9px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;"
      : "display:inline-flex;align-items:center;gap:4px;color:rgb(239,68,68);border-color:rgba(239,68,68,0.3);background:rgba(239,68,68,0.1);border-radius:2px;padding:2px 10px;font-size:9px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;";
    openStatus.innerHTML = isOpen
      ? `<span style="width:6px;height:6px;border-radius:50%;background:rgb(74,222,128);flex-shrink:0;"></span>Open now`
      : `<span style="width:6px;height:6px;border-radius:50%;background:rgb(239,68,68);flex-shrink:0;"></span>Closed`;

    document.getElementById('lb-counter').textContent = `${lbIndex+1} / ${lbTotal}`;
    document.getElementById('lb-badge').textContent = loc.Type || ['Featured','Hidden gem','Local pick'][lbIndex] || 'Gem';
    document.getElementById('lb-type').textContent  = loc.Category || 'Location';
    document.getElementById('lb-coords').textContent = (loc.Latitude && loc.Longitude) ? `${loc.Latitude}° N · ${loc.Longitude}° W` : '';

    const addrText = document.getElementById('lb-addr-text'), mapLink = document.getElementById('lb-map-link');
    if (loc.Address) {
      addrText.textContent = loc.Address;
      mapLink.href = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(loc.Address+', New York City')}`;
      addrText.style.display = 'block'; mapLink.style.display = 'inline-flex';
    } else { addrText.style.display = 'none'; mapLink.style.display = 'none'; }

    document.getElementById('lb-title').textContent = loc.Name;
    document.getElementById('lb-meta').textContent  = `${loc.Borough||''} · ${loc.DatePosted||''}`;
    document.getElementById('lb-desc').textContent  = loc.Description || 'No description provided.';

    const tagsEl = document.getElementById('lb-tags'); tagsEl.innerHTML = '';
    (loc.Tags||[]).forEach(tag => { const el = document.createElement('span'); el.className="text-[9px] font-semibold tracking-[.14em] uppercase px-2.5 py-1 rounded-sm border border-[#e8ded0]/15 text-[#e8ded0]/50 bg-[#e8ded0]/[.04]"; el.textContent=tag; tagsEl.appendChild(el); });

    const hoursEl = document.getElementById('lb-hours'); hoursEl.innerHTML = '';
    (loc.Hours||[]).forEach(day => {
      const row = document.createElement('div');
      row.className = `flex justify-between py-1 border-b border-[#e8ded0]/[.05] ${day.today?'text-[#e8ded0]':'text-[#e8ded0]/40'}`;
      row.innerHTML = `<span class="text-[11px] tracking-[.08em] uppercase font-mono">${day.name}</span><span class="text-[11px] font-mono ${day.today?'font-bold':''}" style="${day.today?'color:var(--accent)':''}">${formatHours(day.hours)}</span>`;
      hoursEl.appendChild(row);
    });

    document.getElementById('lb-like-count').textContent = loc.LikeCount||0;
    document.getElementById('lb-heart').textContent = loc.Liked?'♥':'♡';
    document.getElementById('lb-like-btn').style.color = loc.Liked?'var(--accent)':'#e8ded0';
    document.getElementById('lb-delete-btn').style.display = loc.IsOwner?'flex':'none';
    document.getElementById('lb-prev').style.visibility = lbIndex>0?'visible':'hidden';
    document.getElementById('lb-next').style.visibility = lbIndex<lbTotal-1?'visible':'hidden';

    const dotsEl = document.getElementById('lb-dots'); dotsEl.innerHTML = '';
    locations.forEach((_,i) => { const d=document.createElement('div'); d.style.cssText=`width:6px;height:6px;border-radius:50%;cursor:pointer;background:${i===lbIndex?'var(--accent)':'rgba(232,222,208,0.25)'};transition:background 0.2s;`; d.onclick=()=>{lbIndex=i;renderLightbox();}; dotsEl.appendChild(d); });
  }

  function formatHours(s) {
    if (!s||s==="Closed") return "Closed";
    const p=s.split(" – "); return p.length!==2?s:`${to12Hour(p[0])} – ${to12Hour(p[1])}`;
  }
  function to12Hour(t) {
    if (!t||!t.includes(":")) return t;
    let [h,m]=t.split(":").map(Number); const suf=h>=12?"PM":"AM"; h=(h%12)||12;
    return `${h}:${m.toString().padStart(2,"0")} ${suf}`;
  }

  function lbStep(dir) {
    if (lbAnimating) return;
    const next = lbIndex+dir; if (next<0||next>=lbTotal) return;
    lbAnimating = true;
    const card = document.getElementById('lb-card');
    const out = dir>0?'translateX(-60px)':'translateX(60px)', into = dir>0?'translateX(60px)':'translateX(-60px)';
    card.style.transition = 'opacity 0.18s ease, transform 0.18s ease';
    card.style.opacity = '0'; card.style.transform = out;
    setTimeout(() => {
      lbIndex=next; renderLightbox();
      card.style.transition='none'; card.style.transform=into; card.style.opacity='0';
      card.getBoundingClientRect();
      card.style.transition='opacity 0.22s ease, transform 0.22s cubic-bezier(0.23,1,0.32,1)';
      card.style.opacity='1'; card.style.transform='translateX(0)';
      setTimeout(()=>{card.style.pointerEvents='';lbAnimating=false;},220);
    }, 180);
  }

  function closeLightbox() {
    const lb=document.getElementById('lightbox'), card=document.getElementById('lb-card');
    lb.classList.add('lb-animating-out'); card.classList.add('lb-animating-out');
    lb.addEventListener('animationend',()=>{
      lb.classList.remove('lb-open','lb-animating-out'); card.classList.remove('lb-animating-out');
      lb.classList.add('hidden'); lb.style.display='';
      document.body.style.overflow=''; document.removeEventListener('keydown',lbKeyHandler);
    },{once:true});
  }

  function lbKeyHandler(e) { if(e.key==='ArrowRight')lbStep(1); if(e.key==='ArrowLeft')lbStep(-1); if(e.key==='Escape')closeLightbox(); }
  document.getElementById('lightbox').addEventListener('click',function(e){if(e.target===this)closeLightbox();});

