<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ borough.name | capitalize }} — Hidden Gems</title>
  <script src="https://cdn.tailwindcss.com"></script>
  {% include 'icon.html.jinja'%}
  <style>
    :root {
      --accent: {{ borough.accent }};
      --borough-color: {{ borough.color }};
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Archivo', sans-serif;
      background-color: var(--borough-color);
      color: #e8ded0;
      min-height: 100vh;
      overflow-x: hidden;
    }

    .serif { font-family: 'Cormorant Garamond', serif; }

    
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(232,222,208,0.2); border-radius: 2px; }

    
    .featured-card {
      position: relative;
      border-radius: 18px;
      overflow: hidden;
      cursor: pointer;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      background: rgba(0,0,0,0.25);
      border: 1px solid rgba(232,222,208,0.12);
    }
    .featured-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 24px 50px rgba(0,0,0,0.5);
      border-color: rgba(232,222,208,0.3);
    }
    .featured-card img {
      width: 100%; height: 100%; object-fit: cover;
      display: block;
    }
    .featured-card .overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 55%);
    }
    .featured-card .info {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 16px 18px;
    }
    .featured-card .badge {
      display: inline-block;
      font-size: 0.5rem; letter-spacing: 0.2em; text-transform: uppercase;
      padding: 3px 8px; border-radius: 999px;
      background: var(--accent); color: #fff;
      margin-bottom: 6px; opacity: 0.9;
    }
    .featured-card .card-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.25rem; font-weight: 300; line-height: 1.2;
      color: #fff;
    }
    .featured-card .card-sub {
      font-size: 0.6rem; letter-spacing: 0.12em;
      color: rgba(255,255,255,0.5); margin-top: 4px;
    }
    .featured-card .no-img {
      display: flex; align-items: center; justify-content: center;
      height: 100%; font-size: 0.7rem; opacity: 0.2;
    }

    
    .gem-card {
      border-radius: 14px; overflow: hidden;
      background: rgba(0,0,0,0.2);
      border: 1px solid rgba(232,222,208,0.1);
      transition: all 0.25s ease;
      cursor: pointer;
    }
    .gem-card:hover {
      border-color: rgba(232,222,208,0.25);
      transform: translateY(-2px);
      box-shadow: 0 12px 30px rgba(0,0,0,0.3);
    }
    .gem-card img { width: 100%; height: 140px; object-fit: cover; display: block; }
    .gem-card .gem-info { padding: 12px 14px; }
    .gem-card .gem-title { font-size: 0.85rem; font-weight: 500; }
    .gem-card .gem-meta { font-size: 0.6rem; opacity: 0.4; margin-top: 3px; letter-spacing: 0.08em; }
    .gem-card .no-img { height: 140px; display: flex; align-items: center; justify-content: center; font-size: 0.65rem; opacity: 0.2; }

    
    .add-btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 9px 22px; border-radius: 999px;
      border: 1px solid rgba(232,222,208,0.35);
      font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
      cursor: pointer; background: transparent; color: #e8ded0;
      transition: background 0.2s;
    }
    .add-btn:hover { background: rgba(232,222,208,0.08); }
    .add-btn .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }

    .section-label {
      font-size: 0.55rem; letter-spacing: 0.3em;
      text-transform: uppercase; opacity: 0.4;
    }

    
    .modal-backdrop {
      position: fixed; inset: 0; z-index: 300;
      background: rgba(0,0,0,0.55); backdrop-filter: blur(8px);
      display: none; align-items: center; justify-content: center; padding: 24px;
    }
    .modal-backdrop.open { display: flex; }
    .modal {
      background: #ece4d8; border-radius: 20px;
      border: 2px solid #1f1f1f; box-shadow: 6px 6px 0 #1f1f1f;
      padding: 28px; width: 100%; max-width: 400px; color: #2b2b2b;
    }
    .modal label {
      display: block; font-size: 0.6rem; font-weight: 500;
      letter-spacing: 0.15em; text-transform: uppercase; color: #4a4a4a; margin-bottom: 5px;
    }
    .modal input, .modal textarea {
      width: 100%; padding: 10px 14px; border-radius: 12px;
      border: 2px solid #1f1f1f; background: #f5efe6;
      font-size: 0.85rem; outline: none; box-shadow: 3px 3px 0 #1f1f1f;
      color: #2b2b2b; font-family: inherit; margin-bottom: 14px;
    }
    .modal textarea { resize: none; height: 75px; }
    .modal input[type="file"] { box-shadow: none; padding: 8px; }
    .modal-submit {
      width: 100%; padding: 12px; border-radius: 12px;
      background: #2b2b2b; color: white; font-weight: 600;
      border: 2px solid #1f1f1f; box-shadow: 4px 4px 0 #1f1f1f;
      cursor: pointer; font-family: inherit; font-size: 0.85rem; transition: all 0.15s;
    }
    .modal-submit:hover { transform: translate(2px,2px); box-shadow: none; }
    .modal-cancel {
      width: 100%; padding: 9px; margin-top: 6px;
      background: transparent; border: none;
      color: #4a4a4a; cursor: pointer; font-size: 0.78rem; font-family: inherit;
    }
    .modal-cancel:hover { color: #2b2b2b; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp 0.5s ease both; }
    .d1 { animation-delay: 0.05s; }
    .d2 { animation-delay: 0.12s; }
    .d3 { animation-delay: 0.2s; }
    .d4 { animation-delay: 0.28s; }
  </style>
</head>

<body>

{% include '_nav.html.jinja' %}


{% with messages = get_flashed_messages() %}
  {% if messages %}
    <div class="fixed top-4 left-1/2 -translate-x-1/2 z-50 flex flex-col gap-2">
      {% for message in messages %}
        <div class="px-5 py-3 rounded-xl text-white text-sm border border-white/20 shadow-lg"
             style="background:var(--accent);">{{ message }}</div>
      {% endfor %}
    </div>
  {% endif %}
{% endwith %}

<div class="max-w-5xl mx-auto px-8 py-10">


  <div class="flex items-end justify-between mb-10 fade-up">
    <div>
      <a href="/browse" class="text-xs tracking-widest uppercase opacity-30 hover:opacity-60 transition-opacity">← Back</a>
      <h1 class="serif text-6xl font-light mt-2 leading-none">{{ borough.name | capitalize }}</h1>
      <div class="w-10 h-px mt-4 opacity-50" style="background:var(--accent);"></div>
      <p class="text-xs opacity-30 tracking-widest uppercase mt-3">New York City</p>
    </div>
    <button class="add-btn" onclick="openModal()">
      <span class="dot"></span>
      Add a location
    </button>
  </div>


 
  {% if locations %}
  <div class="fade-up d1">

    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
      <p class="section-label">Featured</p>
      <!-- Slideshow arrows -->
      <div style="display:flex; gap:8px;">
        <button onclick="featStep(-1)" id="feat-prev" style="
          width:32px; height:32px; border-radius:50%;
          background:rgba(232,222,208,0.08); border:1px solid rgba(232,222,208,0.2);
          color:#e8ded0; font-size:1rem; cursor:pointer; transition:background 0.2s;
          display:flex; align-items:center; justify-content:center;
        ">‹</button>
        <button onclick="featStep(1)" id="feat-next" style="
          width:32px; height:32px; border-radius:50%;
          background:rgba(232,222,208,0.08); border:1px solid rgba(232,222,208,0.2);
          color:#e8ded0; font-size:1rem; cursor:pointer; transition:background 0.2s;
          display:flex; align-items:center; justify-content:center;
        ">›</button>
      </div>
    </div>

    <!-- Slide container — shows 3 at a time -->
    <!-- Slide container — shows 3 at a time -->
<div style="overflow:hidden; border-radius:18px;">
  
  <div id="feat-track"
       class="flex gap-4 transition-transform duration-500 ease-[cubic-bezier(0.23,1,0.32,1)]">

    {% for loc in locations %}
    <div class="featured-card shrink-0 basis-1/3 h-[340px]"
         onclick="openDetail({{ loop.index0 }})">

      {% if loc.Image %}
        <img src="{{ url_for('static', filename='uploads/' + loc.Image) }}" alt="{{ loc.Name }}">
      {% else %}
        <div class="no-img">No image</div>
      {% endif %}

      <div class="overlay"></div>

      <div class="info">
        <span class="badge">
          {% if loop.index0 == 0 %}Featured
          {% elif loop.index0 == 1 %}Hidden gem
          {% else %}Local pick{% endif %}
        </span>

        <p class="card-title">{{ loc.Name }}</p>
        <p class="card-sub">
          {{ loc.DatePosted.strftime('%b %d, %Y') if loc.DatePosted else '' }}
        </p>
      </div>

    </div>
    {% endfor %}

  </div>
</div>

    <!-- Dot indicators -->
    <div id="feat-dots" style="display:flex; gap:6px; margin-top:14px; justify-content:center;"></div>

  </div>


  {% if locations | length > 3 %}
  <div class="mt-12 fade-up d2">
    <p class="section-label mb-4">All Locations</p>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
      {% for loc in locations[3:] %}
      <div class="gem-card" onclick="openDetail({{ loop.index0 + 3 }})">
        {% if loc.Image %}
          <img src="{{ url_for('static', filename='uploads/' + loc.Image) }}" alt="{{ loc.Name }}">
        {% else %}
          <div class="no-img"></div>
        {% endif %}
        <div class="gem-info" style="display:flex; align-items:flex-start; justify-content:space-between;">
          <div>
            <p class="gem-title">{{ loc.Name }}</p>
            <p class="gem-meta">{{ loc.DatePosted.strftime('%b %d, %Y') if loc.DatePosted else '' }}</p>
          </div>
          <button
            class="like-btn"
            data-id="{{ loc.ID }}"
            data-borough="{{ borough.name | replace(' ', '-') }}"
            data-liked="{{ 'true' if loc.ID in liked_ids else 'false' }}"
            onclick="event.stopPropagation(); toggleLike(this)"
            style="
              background:none; border:none; cursor:pointer;
              display:flex; align-items:center; gap:4px;
              color:{{ 'var(--accent)' if loc.ID in liked_ids else 'rgba(232,222,208,0.3)' }};
              font-size:0.7rem; padding:2px 0; flex-shrink:0;
            ">
            <span class="like-heart">{{ '♥' if loc.ID in liked_ids else '♡' }}</span>
            <span class="like-count">{{ loc.LikeCount or 0 }}</span>
          </button>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {% else %}

  <div class="fade-up d1 flex flex-col items-center justify-center py-32 opacity-30">
    <p class="serif text-3xl font-light mb-2">No gems yet</p>
    <p class="text-xs tracking-widest uppercase">Be the first to add a location</p>
  </div>
  {% endif %}

</div>



<div id="lightbox" 
     class="hidden fixed inset-0 z-[400] flex flex-col items-center justify-center 
            bg-black/50 backdrop-blur-2xl">

  <!-- Close -->
  <button onclick="closeLightbox()" style="
    position:absolute; top:24px; right:28px;
    background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15);
    color:#e8ded0; font-size:1.1rem; width:38px; height:38px;
    border-radius:50%; cursor:pointer; line-height:1;
  ">✕</button>

  <!-- Counter -->
  <p id="lb-counter" style="
    position:absolute; top:28px; left:50%; transform:translateX(-50%);
    font-size:0.55rem; letter-spacing:0.3em; text-transform:uppercase;
    color:rgba(232,222,208,0.35);
  "></p>

  <!-- Main content row -->
  <div style="display:flex; align-items:center; gap:24px; width:100%; max-width:860px; padding:0 20px;">

    <!-- Prev arrow -->
    <button id="lb-prev" onclick="lbStep(-1)" style="
      flex-shrink:0; width:44px; height:44px; border-radius:50%;
      background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.15);
      color:#e8ded0; font-size:1.3rem; cursor:pointer;
    ">‹</button>

    <!-- Card -->
<div class="rounded-[20px] overflow-hidden bg-black/30 border border-white/10 w-full">

  <!-- Map area -->
  <div id="lb-map-area"
       class="relative h-[220px] bg-black/40 flex items-end justify-between p-4 gap-2">

    <div class="absolute inset-0 opacity-[0.06]"
         style="background-image: linear-gradient(rgba(232,222,208,.8) 1px,transparent 1px),
                                  linear-gradient(90deg,rgba(232,222,208,.8) 1px,transparent 1px);
                background-size:30px 30px"></div>

    <!-- Type badge -->
    <div class="absolute top-4 left-4 z-10 flex items-center gap-2 rounded-full px-3 py-1"
         style="background: var(--accent)">
      <span class="w-1.5 h-1.5 rounded-full bg-white"></span>
      <span id="lb-badge"
            class="text-[10px] font-bold tracking-[.2em] uppercase text-white"></span>
    </div>

    <!-- Coordinates -->
    <span id="lb-coords"
          class="z-10 text-[10px] tracking-[.12em] uppercase text-[#e8ded0]/25 font-mono"></span>

    <!-- Maps button -->
    <a id="lb-map-link"
       href="#"
       target="_blank"
       class="z-10 inline-flex items-center gap-1.5 rounded-full px-4 py-1.5
              bg-[#e8ded0]/[.08] border border-[#e8ded0]/20 text-[#e8ded0]
              text-[10px] font-bold tracking-[.18em] uppercase no-underline
              hover:bg-[#e8ded0]/[.15] transition-colors">
      Open in Maps ↗
    </a>
  </div>

  <!-- Accent bar -->
  <div class="h-[3px] w-full" style="background: var(--accent)"></div>

  <!-- Body -->
  <div class="px-6 pt-5">

    <div class="flex items-center gap-2 mb-3">
      <span id="lb-type"
            class="text-[9px] font-bold tracking-[.22em] uppercase px-2.5 py-0.5
                   rounded-sm text-white"
            style="background: var(--accent)"></span>

      <span id="lb-open-status"
            class="inline-flex items-center gap-1 text-[9px] font-bold tracking-[.16em]
                   uppercase text-green-400 bg-green-400/10 border border-green-400/20
                   rounded-sm px-2.5 py-0.5">
        <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>
        Open now
      </span>
    </div>

    <h2 id="lb-title"
        class="font-['Cormorant_Garamond'] font-light text-[2rem] leading-none
               text-[#e8ded0] mb-1"></h2>

    <p id="lb-meta"
       class="text-[10px] tracking-[.18em] uppercase text-[#e8ded0]/35 mb-3"></p>

    <p id="lb-desc"
       class="text-[13px] text-[#e8ded0]/60 leading-relaxed mb-4"></p>

    <!-- Tags -->
    <div id="lb-tags" class="flex flex-wrap gap-1.5 mb-5"></div>
  </div>

  <!-- Hours -->
  <div class="border-t border-[#e8ded0]/[.08] bg-black/15 px-6 py-4">
    <p class="text-[9px] font-bold tracking-[.24em] uppercase text-[#e8ded0]/35 mb-3">Hours</p>
    <div id="lb-hours" class="grid grid-cols-2 gap-x-4 gap-y-0"></div>
  </div>

  <!-- Footer -->
  <div class="flex items-center justify-between border-t border-[#e8ded0]/[.08] px-6 py-4">
    <p id="lb-addr-text"
       class="text-[10px] text-[#e8ded0]/30 tracking-wide leading-relaxed"></p>

    <button id="lb-like-btn"
            onclick="toggleLikeById()"
            class="flex items-center gap-1.5 px-4 py-2 rounded-sm border border-[#e8ded0]/15
                   bg-[#e8ded0]/[.06] text-[#e8ded0] font-bold text-[11px]
                   tracking-[.14em] uppercase hover:bg-[#e8ded0]/10 transition-colors
                   cursor-pointer">
      <span id="lb-heart">♡</span>
      <span id="lb-like-count">0</span>
      <span class="text-[8px] opacity-50 tracking-[.15em]">likes</span>
    </button>
  </div>

  <button id="lb-delete-btn"
        onclick="openDeleteModal()"
        class="mt-3 w-full flex items-center justify-center gap-2 px-4 py-2 rounded-sm border border-red-400/20 bg-red-400/10 text-red-400 font-bold text-[11px] tracking-[.14em] uppercase hover:bg-red-400/20 transition-colors cursor-pointer hidden">
  Remove location
</button>

  


</div>

    </div>

    
    <button id="lb-next" onclick="lbStep(1)" style="
      flex-shrink:0; width:44px; height:44px; border-radius:50%;
      background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.15);
      color:#e8ded0; font-size:1.3rem; cursor:pointer;
    ">›</button>

  </div>

  
  <div id="lb-dots" style="display:flex; gap:8px; margin-top:28px;"></div>
</div>



<div id="add-modal"
     class="modal-backdrop fixed inset-0 z-[500] bg-black/50 backdrop-blur-xl
            flex items-center justify-center p-6 hidden"
     onclick="closeAddBackdrop(event)">

  <!-- MODAL PANEL -->
  <div class="modal w-full max-w-lg max-h-[85vh] overflow-hidden flex flex-col
              bg-gradient-to-b from-[#3b2f2f]/90 via-[#2a2422]/90 to-[#1c1c1c]/90
              border border-[#f5efe6]/20 rounded-2xl shadow-2xl"
       onclick="event.stopPropagation()">

    <!-- HEADER -->
    <div class="px-6 pt-6 pb-3 flex-shrink-0">
      <h2 class="serif text-2xl font-light text-[#f5efe6]">Add a location</h2>
    </div>

    <!-- SCROLLABLE CONTENT -->
    <div class="flex-1 overflow-y-auto px-6 pb-6 space-y-4">

      <form method="POST"
            action="/borough/{{ borough.name | replace(' ', '-') }}/add"
            enctype="multipart/form-data"
            class="space-y-4">

        <!-- NAME -->
        <div>
          <label class="block text-xs tracking-widest uppercase text-[#f5efe6]/70 mb-1">
            Location name
          </label>
          <input type="text" name="name" required
                 placeholder="e.g. Domino Park"
                 class="w-full bg-[#6b5b4d]/20 border border-[#f5efe6]/30 rounded px-3 py-2
                        text-sm text-[#f5efe6] placeholder-[#f5efe6]/50
                        focus:outline-none focus:border-[#f5efe6]/50">
        </div>

        <!-- ADDRESS -->
        <div>
          <label class="block text-xs tracking-widest uppercase text-[#f5efe6]/70 mb-1">
            Address
          </label>
          <input type="text" name="address" required
                 placeholder="e.g. 15 River St, Brooklyn"
                 class="w-full bg-[#6b5b4d]/20 border border-[#f5efe6]/30 rounded px-3 py-2
                        text-sm text-[#f5efe6] placeholder-[#f5efe6]/50
                        focus:outline-none focus:border-[#f5efe6]/50">
        </div>

        <!-- DESCRIPTION -->
        <div>
          <label class="block text-xs tracking-widest uppercase text-[#f5efe6]/70 mb-1">
            Description
          </label>
          <textarea name="description"
                    placeholder="What makes this place special?"
                    class="w-full bg-[#6b5b4d]/20 border border-[#f5efe6]/30 rounded px-3 py-2
                           text-sm text-[#f5efe6] placeholder-[#f5efe6]/50 h-24
                           focus:outline-none focus:border-[#f5efe6]/50"></textarea>
        </div>

        <!-- PHOTO -->
        <div>
          <label class="block text-xs tracking-widest uppercase text-[#f5efe6]/70 mb-1">
            Photo
          </label>
          <input type="file" name="image" accept="image/*"
                 class="w-full text-sm text-[#f5efe6]/80">
        </div>

        <!-- HOURS TITLE -->
        <label class="block text-xs tracking-widest uppercase text-[#f5efe6]/70 mb-1">
          Hours
        </label>

        <!-- PRESETS -->
        <div class="flex items-center gap-2 mb-2">
          <select id="hours-preset"
                  class="bg-[#6b5b4d]/20 border border-[#f5efe6]/30 text-xs text-[#f5efe6]
                         px-2 py-1 rounded focus:outline-none focus:border-[#f5efe6]/50">
            <option value="">Choose preset…</option>
            <option value="9-5">Weekdays 9–5, Weekends Closed</option>
            <option value="24-7">Open 24/7</option>
            <option value="closed">Closed All Week</option>
          </select>

          <button type="button"
                  onclick="applyPreset()"
                  class="text-[10px] tracking-widest uppercase px-3 py-1 rounded
                         bg-[#6b5b4d]/20 border border-[#f5efe6]/30 text-[#f5efe6]">
            Apply
          </button>
        </div>

        <!-- HOURS GRID -->
        <div class="space-y-1.5 mb-4">
          {% set days = ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"] %}
          {% for d in days %}
          <div class="flex items-center gap-2 bg-[#6b5b4d]/15 border border-[#f5efe6]/20
                      rounded px-3 py-1.5">

            <!-- Day -->
            <span class="w-10 text-[10px] tracking-widest uppercase text-[#f5efe6]/70">
              {{ d }}
            </span>

            <!-- Closed toggle -->
            <label class="flex items-center gap-1 text-[10px] text-[#f5efe6]/80">
              <input type="checkbox"
                     name="hours_{{ d }}_closed"
                     class="accent-[var(--accent)]"
                     onchange="toggleClosed('{{ d }}')">
              Closed
            </label>

            <!-- Time inputs -->
            <div id="hours-row-{{ d }}" class="flex items-center gap-2 flex-1">
              <input type="time"
                     name="hours_{{ d }}_open"
                     class="flex-1 bg-transparent text-xs text-[#f5efe6]
                            focus:outline-none">
              <span class="text-[#f5efe6]/40 text-xs">–</span>
              <input type="time"
                     name="hours_{{ d }}_close"
                     class="flex-1 bg-transparent text-xs text-[#f5efe6]
                            focus:outline-none">
            </div>

          </div>
          {% endfor %}
        </div>

      </form>
    </div>

    <!-- FOOTER BUTTONS -->
    <div class="flex-shrink-0 px-6 pb-6 flex gap-3">
      <button type="submit"
              form="add-location-form"
              class="modal-submit flex-1">
        Post location
      </button>

      <button type="button"
              onclick="closeAddModal()"
              class="modal-cancel flex-1">
        Cancel
      </button>
    </div>

  </div>
</div>







<script>
  const locations = {{ locations_json | safe }};


  async function toggleLike(btn) {
    const id      = btn.dataset.id;
    const borough = btn.dataset.borough;
    const res     = await fetch(`/borough/${borough}/like/${id}`, { method: 'POST' });
    const data    = await res.json();
    btn.dataset.liked = data.liked ? 'true' : 'false';
    btn.querySelector('.like-heart').textContent = data.liked ? '♥' : '♡';
    btn.querySelector('.like-count').textContent = data.count;
    btn.style.color = data.liked ? 'var(--accent)' : 'rgba(232,222,208,0.3)';
    // sync lightbox if open
    if (document.getElementById('lightbox').style.display === 'flex') {
      const loc = locations[lbIndex];
      if (loc && String(loc.ID) === String(id)) {
        loc.LikeCount = data.count;
        loc.Liked = data.liked;
        document.getElementById('lb-like-count').textContent = data.count;
        document.getElementById('lb-heart').textContent = data.liked ? '♥' : '♡';
        document.getElementById('lb-like-btn').style.color = data.liked ? 'var(--accent)' : '#e8ded0';
      }
    }
  }
  

  async function toggleLikeById() {
    const loc     = locations[lbIndex];
    if (!loc) return;
    const boroughSlug = '{{ borough.name | replace(" ", "-") }}';
    const res  = await fetch(`/borough/${boroughSlug}/like/${loc.ID}`, { method: 'POST' });
    const data = await res.json();
    loc.Liked = data.liked;
    loc.LikeCount = data.count;
    document.getElementById('lb-like-count').textContent = data.count;
    document.getElementById('lb-heart').textContent = data.liked ? '♥' : '♡';
    document.getElementById('lb-like-btn').style.color = data.liked ? 'var(--accent)' : '#e8ded0';
   
    const btn = document.querySelector(`.like-btn[data-id="${loc.ID}"]`);
    if (btn) {
      btn.dataset.liked = data.liked ? 'true' : 'false';
      btn.querySelector('.like-heart').textContent = data.liked ? '♥' : '♡';
      btn.querySelector('.like-count').textContent = data.count;
      btn.style.color = data.liked ? 'var(--accent)' : 'rgba(232,222,208,0.3)';
    }
  }

  let featIndex = 0;
  const featTotal = locations.length;
  const VISIBLE = 3;


  function openDeleteModal() {
  const modal = document.getElementById('delete-modal');
  modal.style.display = 'flex';
  document.getElementById('delete-confirm-btn').onclick = confirmDelete;
}

function closeDeleteModal() {
  document.getElementById('delete-modal').style.display = 'none';
}

async function confirmDelete() {
  const loc = locations[lbIndex];
  if (!loc) return;

  closeDeleteModal();

  const boroughSlug = '{{ borough.name | replace(" ", "-") }}';
  const res = await fetch(`/borough/${boroughSlug}/delete/${loc.ID}`, { method: 'POST' });
  const data = await res.json();

  if (data.success) {
    locations.splice(lbIndex, 1);
    closeLightbox();
    location.reload();
  } else {
    alert("Failed to delete location.");
  }
}



  function buildFeatDots() {
    const dotsEl = document.getElementById('feat-dots');
    if (!dotsEl) return;
    dotsEl.innerHTML = '';
    const pages = Math.max(1, featTotal - VISIBLE + 1);
    for (let i = 0; i < pages; i++) {
      const d = document.createElement('div');
      d.style.cssText = `width:5px;height:5px;border-radius:50%;cursor:pointer;
        background:${i === featIndex ? 'var(--accent)' : 'rgba(232,222,208,0.2)'};
        transition:background 0.2s;`;
      d.onclick = () => { featIndex = i; updateFeatSlide(); };
      dotsEl.appendChild(d);
    }
  }

  function updateFeatSlide() {
  const track = document.getElementById('feat-track');
  if (!track) return;

  const shiftPercent = (100 / VISIBLE) * featIndex;
  track.style.transform = `translateX(-${shiftPercent}%)`;

  const maxIndex = Math.max(0, featTotal - VISIBLE);
  document.getElementById('feat-prev').style.opacity = featIndex > 0 ? '1' : '0.25';
  document.getElementById('feat-next').style.opacity = featIndex < maxIndex ? '1' : '0.25';

  buildFeatDots();
}

  function featStep(dir) {
    const maxIndex = Math.max(0, featTotal - VISIBLE);
    featIndex = Math.max(0, Math.min(featIndex + dir, maxIndex));
    updateFeatSlide();
  }

 
  window.addEventListener('load', () => { buildFeatDots(); updateFeatSlide(); });

  
  let lbIndex = 0;
  const lbTotal = locations.length;

  function openDetail(index) {
    lbIndex = index;
    renderLightbox();
    const lb = document.getElementById('lightbox');
    lb.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    document.addEventListener('keydown', lbKeyHandler);
  }

  function renderLightbox() {
  const loc = locations[lbIndex];
  if (!loc) return;

  // Counter
  document.getElementById('lb-counter').textContent =
    `${lbIndex + 1} / ${lbTotal}`;

  // Badge (Featured / Hidden Gem / Local Pick)
  const badges = ['Featured', 'Hidden gem', 'Local pick'];
  document.getElementById('lb-badge').textContent =
    loc.Type || badges[lbIndex] || 'Gem';

  // Category / Type
  document.getElementById('lb-type').textContent =
    loc.Category || 'Location';

  // Coordinates
  const coordsEl = document.getElementById('lb-coords');
  if (loc.Latitude && loc.Longitude) {
    coordsEl.textContent = `${loc.Latitude}° N · ${loc.Longitude}° W`;
  } else {
    coordsEl.textContent = '';
  }

  // Address + Maps link
  const addrText = document.getElementById('lb-addr-text');
  const mapLink = document.getElementById('lb-map-link');
  const noAddr = document.getElementById('lb-no-addr');

  if (loc.Address) {
    addrText.textContent = loc.Address;
    const q = encodeURIComponent(loc.Address + ', New York City');
    mapLink.href = `https://www.google.com/maps/search/?api=1&query=${q}`;
    addrText.style.display = 'block';
    mapLink.style.display = 'inline-flex';
    if (noAddr) noAddr.style.display = 'none';
  } else {
    addrText.style.display = 'none';
    mapLink.style.display = 'none';
    if (noAddr) noAddr.style.display = 'block';
  }

  // Title
  document.getElementById('lb-title').textContent = loc.Name;

  // Meta (borough + date)
  document.getElementById('lb-meta').textContent =
    `${loc.Borough || ''} · ${loc.DatePosted || ''}`;

  // Description
  document.getElementById('lb-desc').textContent =
    loc.Description || 'No description provided.';

  // Tags
  const tagsEl = document.getElementById('lb-tags');
  tagsEl.innerHTML = '';
  if (loc.Tags && Array.isArray(loc.Tags)) {
    loc.Tags.forEach(tag => {
      const el = document.createElement('span');
      el.className =
        "text-[9px] font-semibold tracking-[.14em] uppercase px-2.5 py-1 rounded-sm border border-[#e8ded0]/15 text-[#e8ded0]/50 bg-[#e8ded0]/[.04]";
      el.textContent = tag;
      tagsEl.appendChild(el);
    });
  }

  // Hours
  const hoursEl = document.getElementById('lb-hours');
  hoursEl.innerHTML = '';
  if (loc.Hours && Array.isArray(loc.Hours)) {
    loc.Hours.forEach(day => {
      const row = document.createElement('div');
      row.className =
        `flex justify-between py-1 border-b border-[#e8ded0]/[.05] ${
          day.today ? 'text-[#e8ded0]' : 'text-[#e8ded0]/40'
        }`;

      row.innerHTML = `
        <span class="text-[11px] tracking-[.08em] uppercase font-mono">${day.name}</span>
        <span class="text-[11px] font-mono ${day.today ? 'font-bold' : ''}"
              style="${day.today ? 'color: var(--accent)' : ''}">
          ${day.hours}
        </span>
      `;

      hoursEl.appendChild(row);
    });
  }

  // Likes
  document.getElementById('lb-like-count').textContent =
    loc.LikeCount || 0;
  document.getElementById('lb-heart').textContent =
    loc.Liked ? '♥' : '♡';
  document.getElementById('lb-like-btn').style.color =
    loc.Liked ? 'var(--accent)' : '#e8ded0';

  // Delete button visibility
const delBtn = document.getElementById('lb-delete-btn');
delBtn.style.display = loc.IsOwner ? 'flex' : 'none';


  // Prev / Next visibility
  document.getElementById('lb-prev').style.visibility =
    lbIndex > 0 ? 'visible' : 'hidden';
  document.getElementById('lb-next').style.visibility =
    lbIndex < lbTotal - 1 ? 'visible' : 'hidden';

  // Dots
  const dotsEl = document.getElementById('lb-dots');
  dotsEl.innerHTML = '';
  locations.forEach((_, i) => {
    const d = document.createElement('div');
    d.style.cssText = `
      width:6px; height:6px; border-radius:50%; cursor:pointer;
      background: ${i === lbIndex ? 'var(--accent)' : 'rgba(232,222,208,0.25)'};
      transition: background 0.2s;
    `;
    d.onclick = () => { lbIndex = i; renderLightbox(); };
    dotsEl.appendChild(d);
  });
}


  function lbStep(dir) {
    const next = lbIndex + dir;
    if (next >= 0 && next < lbTotal) { lbIndex = next; renderLightbox(); }
  }

  function closeLightbox() {
    document.getElementById('lightbox').style.display = 'none';
    document.body.style.overflow = '';
    document.removeEventListener('keydown', lbKeyHandler);
  }

  function lbKeyHandler(e) {
    if (e.key === 'ArrowRight') lbStep(1);
    if (e.key === 'ArrowLeft')  lbStep(-1);
    if (e.key === 'Escape')     closeLightbox();
  }

  document.getElementById('lightbox').addEventListener('click', function(e) {
    if (e.target === this) closeLightbox();
  });

  
  function openModal() {
    document.getElementById('add-modal').classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeAddModal() {
    document.getElementById('add-modal').classList.remove('open');
    document.body.style.overflow = '';
  }
  function closeAddBackdrop(e) { if (e.target.id === 'add-modal') closeAddModal(); }


  function toggleClosed(day) {
  const row = document.getElementById(`hours-row-${day}`);
  const checkbox = document.querySelector(`input[name="hours_${day}_closed"]`);

  if (checkbox.checked) {
    row.style.display = "none";
  } else {
    row.style.display = "flex";
  }
}

function applyPreset() {
  const preset = document.getElementById("hours-preset").value;

  const days = ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"];

  if (preset === "9-5") {
    days.forEach(d => {
      const closed = document.querySelector(`input[name="hours_${d}_closed"]`);
      const open = document.querySelector(`input[name="hours_${d}_open"]`);
      const close = document.querySelector(`input[name="hours_${d}_close"]`);

      if (["Sat","Sun"].includes(d)) {
        closed.checked = true;
        toggleClosed(d);
      } else {
        closed.checked = false;
        toggleClosed(d);
        open.value = "09:00";
        close.value = "17:00";
      }
    });
  }

  if (preset === "24-7") {
    days.forEach(d => {
      const closed = document.querySelector(`input[name="hours_${d}_closed"]`);
      const open = document.querySelector(`input[name="hours_${d}_open"]`);
      const close = document.querySelector(`input[name="hours_${d}_close"]`);

      closed.checked = false;
      toggleClosed(d);
      open.value = "00:00";
      close.value = "23:59";
    });
  }

  if (preset === "closed") {
    days.forEach(d => {
      const closed = document.querySelector(`input[name="hours_${d}_closed"]`);
      closed.checked = true;
      toggleClosed(d);
    });
  }
}


  
</script>
<div id="delete-modal" style="display:none; position:fixed; inset:0; z-index:500; background:rgba(0,0,0,0.6); backdrop-filter:blur(8px); align-items:center; justify-content:center; padding:24px;">
  <div style="background:#111; border:1px solid rgba(232,222,208,0.12); border-radius:20px; padding:32px 28px; width:100%; max-width:360px; display:flex; flex-direction:column; align-items:center;">
    <div style="width:48px;height:48px;border-radius:50%;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);display:flex;align-items:center;justify-content:center;margin-bottom:20px;">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M8 4h4M3 6h14M5 6l1 10a2 2 0 002 2h4a2 2 0 002-2l1-10" stroke="rgba(239,68,68,0.9)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <p class="serif" style="font-size:1.4rem;font-weight:300;color:#e8ded0;margin-bottom:8px;text-align:center;line-height:1.2;">Remove this location?</p>
    <p style="font-size:0.75rem;color:rgba(232,222,208,0.4);text-align:center;line-height:1.6;margin-bottom:28px;">This can't be undone. The location and all its data will be permanently deleted.</p>
    <div style="display:flex;flex-direction:column;gap:8px;width:100%;">
      <button id="delete-confirm-btn" style="width:100%;padding:11px;border-radius:10px;background:rgba(239,68,68,0.15);border:1px solid rgba(239,68,68,0.3);color:rgb(239,68,68);font-size:0.7rem;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;cursor:pointer;font-family:inherit;">Yes, remove it</button>
      <button onclick="closeDeleteModal()" style="width:100%;padding:11px;border-radius:10px;background:rgba(232,222,208,0.05);border:1px solid rgba(232,222,208,0.12);color:rgba(232,222,208,0.5);font-size:0.7rem;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;cursor:pointer;font-family:inherit;">Cancel</button>
    </div>
  </div>
</div>
</body>
</html>
