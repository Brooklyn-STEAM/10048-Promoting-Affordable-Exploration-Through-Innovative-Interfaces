  function modalStep(dir) {
    const nameVal = document.getElementById('input-name')?.value.trim();
    const addrVal = document.getElementById('input-address')?.value.trim();
    if (dir === 1 && currentStep === 0 && (!nameVal || !addrVal)) {
      const missing = !nameVal ? document.getElementById('input-name') : document.getElementById('input-address');
      missing.style.borderColor = 'rgba(239,68,68,0.6)';
      missing.focus();
      setTimeout(() => missing.style.borderColor = 'rgba(232,222,208,0.12)', 1500);
      return;
    }
    currentStep = Math.max(0, Math.min(currentStep + dir, totalSteps - 1));
    renderModalStep();
  }

  function renderModalStep() {
    document.querySelectorAll('.form-step').forEach((el, i) => {
      el.style.display = i === currentStep ? 'block' : 'none';
    });
    // Show auto-fill badge on hours step
    const hoursBadge = document.getElementById('hours-autofill-badge');
    if (hoursBadge) hoursBadge.style.display = (currentStep === 2 && window._hoursAutoFilled) ? 'block' : 'none';
    document.querySelectorAll('.step-dot').forEach((dot, i) => {
      dot.style.background = i <= currentStep ? 'var(--accent)' : 'rgba(232,222,208,0.15)';
    });
    const backBtn   = document.getElementById('step-back-btn');
    const nextBtn   = document.getElementById('step-next-btn');
    const submitBtn = document.getElementById('step-submit-btn');
    backBtn.style.display   = currentStep > 0 ? 'block' : 'none';
    nextBtn.style.display   = currentStep < totalSteps - 1 ? 'block' : 'none';
    submitBtn.style.display = currentStep === totalSteps - 1 ? 'block' : 'none';
  }

  function previewPhoto(input) {
    const file = input.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = e => {
      document.getElementById('photo-preview-img').src = e.target.result;
      document.getElementById('photo-preview-wrap').style.display = 'block';
      document.getElementById('photo-placeholder').style.display = 'none';
      document.getElementById('photo-filename').textContent = file.name;
      document.getElementById('photo-filename').style.display = 'block';
    };
    reader.readAsDataURL(file);
  }

  function toggleClosed(day) { const row=document.getElementById(`hours-row-${day}`), cb=document.querySelector(`input[name="hours_${day}_closed"]`); row.style.display=cb.checked?'none':'flex'; }
  function applyPreset() {
    const preset=document.getElementById("hours-preset").value, days=["Mon","Tue","Wed","Thu","Fri","Sat","Sun"];
    days.forEach(d=>{
      const cl=document.querySelector(`input[name="hours_${d}_closed"]`), op=document.querySelector(`input[name="hours_${d}_open"]`), cl2=document.querySelector(`input[name="hours_${d}_close"]`);
      if(preset==="9-5"){if(["Sat","Sun"].includes(d)){cl.checked=true;toggleClosed(d);}else{cl.checked=false;toggleClosed(d);op.value="09:00";cl2.value="17:00";}}
      if(preset==="24-7"){cl.checked=false;toggleClosed(d);op.value="00:00";cl2.value="23:59";}
      if(preset==="closed"){cl.checked=true;toggleClosed(d);}
    });
  }

