<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Borough Selector</title>
  {% include 'icon.html.jinja' %}
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Archivo:wght@300;400;500&display=swap" rel="stylesheet">

  <style>
    :root {
      --accent: {{ selected.accent }};
      --borough-color: {{ selected.color }};
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Archivo', sans-serif;
      background-color: {{ selected.color }};
      color: #e8ded0;
      min-height: 100vh;
      overflow: hidden;
      position: relative;
      transition: background-color 0.6s ease;
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 100;
      opacity: 0.3;
    }

    h1 {
      font-family: 'Archivo', sans-serif;
      font-weight: 500;
      letter-spacing: 0.3em;
      font-size: 0.75rem;
    }

    .radial-container {
      position: absolute;
      bottom: -10%;
      left: 50%;
      transform: translateX(-50%);
      width: 700px;
      height: 700px;
    }

    .arc-ring {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      border: 1px solid rgba(232, 222, 208, 0.1);
    }
    .arc-ring:nth-child(1) { inset: 10%; }
    .arc-ring:nth-child(2) { inset: 22%; }
    .arc-ring:nth-child(3) { inset: 34%; }

    .borough-img-wrap {
      position: absolute;
      inset: 30%;
      border-radius: 50%;
      overflow: hidden;
      box-shadow: 0 30px 80px rgba(0,0,0,0.6);
      transition: transform 0.6s cubic-bezier(.23,1,.32,1);
    }
    .borough-img-wrap:hover { transform: scale(1.03); }

    .borough-label {
      font-size: 0.6rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(232,222,208,0.45);
      transition: color 0.3s;
      white-space: nowrap;
      cursor: pointer;
      background: none;
      border: none;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .borough-label.active { color: #e8ded0; }

    .borough-label .dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: rgba(232,222,208,0.3);
      transition: background 0.3s;
      flex-shrink: 0;
    }
    .borough-label.active .dot {
      background: var(--accent);
      box-shadow: 0 0 8px var(--accent);
    }

    .borough-panel {
      position: absolute;
      left: 40px;
      top: 50%;
      transform: translateY(-50%);
      z-index: 10;
    }
    .borough-panel .name {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      font-size: 2.5rem;
      line-height: 1.1;
      text-transform: capitalize;
      margin-bottom: 16px;
    }

    .visit-btn {
      display: inline-block;
      padding: 10px 24px;
      border: 1px solid rgba(232,222,208,0.5);
      border-radius: 999px;
      font-size: 0.6rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: #e8ded0;
      text-decoration: none;
      transition: background 0.2s, color 0.2s;
    }
    .visit-btn:hover {
      background: #e8ded0;
      color: var(--borough-color);
    }

    .nav-link {
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(232,222,208,0.35);
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp 0.5s ease both; }

    @keyframes fadeLeft {
      from { opacity: 0; transform: translateY(-50%) translateX(-16px); }
      to   { opacity: 1; transform: translateY(-50%) translateX(0); }
    }
    .fade-left { animation: fadeLeft 0.5s ease both; }

    @keyframes spinIn {
      from { opacity: 0; transform: translateX(-50%) rotate(-8deg) scale(0.94); }
      to   { opacity: 1; transform: translateX(-50%) rotate(0deg) scale(1); }
    }
    .spin-in { animation: spinIn 0.6s cubic-bezier(.23,1,.32,1) both; }

    .borough-form {
      position: absolute;
      top: 50%; left: 50%;
      transform-origin: 0 0;
    }
  </style>
</head>

<body>

{% include '_nav.html.jinja' %}


<div class="absolute top-0 left-0 right-0 flex items-center px-8 py-6 z-10">
  <h1 class="fade-up">Borough Selector</h1>
</div>


<div class="borough-panel fade-left">
  <p class="name">{{ selected.name }}</p>
  <a href="/borough/{{ selected.name | replace(' ', '-') }}" class="visit-btn">
    Explore {{ selected.name }} &rarr;
  </a>
</div>


<div class="radial-container spin-in">
  <div class="arc-ring"></div>
  <div class="arc-ring"></div>
  <div class="arc-ring"></div>

  <div class="borough-img-wrap">
    <img src="{{ url_for('static', filename='images/' + selected.name + '.png') }}"
         onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
         style="width:100%; height:100%; object-fit:cover;">
    <div style="display:none; width:100%; height:100%; background:radial-gradient(circle at 40% 35%, {{ selected.accent }}, {{ selected.color }}, #0a0a1a);"></div>
  </div>

  {% for borough in boroughs %}
  <form method="POST" class="borough-form" data-index="{{ loop.index0 }}" data-total="{{ boroughs|length }}">
    <button type="submit" name="borough" value="{{ borough.name }}"
      class="borough-label {% if borough.name == selected.name %}active{% endif %}">
      <span class="dot"></span>{{ borough.name }}
    </button>
  </form>
  {% endfor %}
</div>

<div class="absolute bottom-6 left-8 right-8 flex justify-between z-10">
  <div class="flex gap-6">
    <a href="#" class="nav-link">About</a>
    <a href="#" class="nav-link">Contact</a>
  </div>
  <a href="#" class="nav-link">Privacy</a>
</div>

<script>
  document.querySelectorAll('.borough-form').forEach(form => {
    const idx   = parseInt(form.dataset.index);
    const total = parseInt(form.dataset.total);
    const radius = 290;
    const angleDeg = -155 + (idx / (total - 1)) * 130;
    const angleRad = angleDeg * Math.PI / 180;
    const x = 350 + radius * Math.cos(angleRad);
    const y = 350 + radius * Math.sin(angleRad);
    form.style.top  = y + 'px';
    form.style.left = x + 'px';
    form.style.transform = 'translate(-50%, -50%)';
  });

  document.body.style.backgroundColor = 'transparent';
  requestAnimationFrame(() => {
    document.body.style.backgroundColor = '{{ selected.color }}';
  });
</script>

<style>
  .pigeon {
    position: fixed;
    pointer-events: none;
    z-index: 9999;
  }
</style>

<script>
  function spawnPigeon() {
    const p = document.createElement('img');
    p.classList.add('pigeon');
    p.src = "{{ url_for('static', filename='images/pigeon.gif') }}";


    const startY = Math.random() * (window.innerHeight * 0.65) + 40;


    const size = 80 + Math.random() * 80;
    p.style.width  = size + 'px';
    p.style.height = 'auto';
    p.style.transform = 'scaleX(1)';
    p.style.top    = startY + 'px';

    // random speed
    const duration = 1800 + Math.random() * 1200;

    document.body.appendChild(p);

    let startTime = null;
    const startX  = window.innerWidth + 60;
    const endX    = -(size + 60);

    function step(ts) {
      if (!startTime) startTime = ts;
      const progress = (ts - startTime) / duration;
      if (progress >= 1) {
        p.remove();
        return;
      }
      const drift = Math.sin(progress * Math.PI * 5) * 10;
      p.style.left = (startX + (endX - startX) * progress) + 'px';
      p.style.top  = (startY + drift) + 'px';
      requestAnimationFrame(step);
    }

    requestAnimationFrame(step);
  }

  // Spawn on click
  document.addEventListener('click', spawnPigeon);
  
  function autoSpawn() {
    spawnPigeon();
    setTimeout(autoSpawn, 2000 + Math.random() * 6000);
  }
  autoSpawn();
</script>

<!-- ========================= -->
<!--  PIXEL HORROR GAME OVERLAY -->
<!-- ========================= -->
<div id="pixel-horror-overlay" 
     style="display:none; position:fixed; inset:0; background:black; z-index:999999;">

  <!-- Canvas -->
  <canvas id="horrorCanvas" width="480" height="270"
          style="position:absolute; top:50%; left:50%; transform:translate(-50%, -50%) scale(2); 
                 image-rendering:pixelated; background:black;">
  </canvas>

  <!-- Exit Button -->
  <button id="exitHorrorGame"
          style="position:absolute; top:20px; right:20px; padding:6px 12px; 
                 background:#111; color:#fff; border:1px solid #444; cursor:pointer;">
    Exit
  </button>
</div>

<script>
/* ============================
   EASTER EGG TRIGGER (10 CLICKS)
   ============================ */
let horrorClicks = 0;
const centerImg = document.querySelector(".borough-img-wrap");

if (centerImg) {
  centerImg.addEventListener("click", () => {
    horrorClicks++;
    if (horrorClicks >= 10) {
      horrorClicks = 0;
      startPixelHorrorGame();
    }
  });
}

/* ============================
   GAME VARIABLES
   ============================ */
let canvas, ctx;
let player = { x: 20, y: 200, dir: 1, speed: 1.2 };
let keys = {};
let currentFloor = 1;
let gameRunning = false;

let ghostActive = false;
let ghostTimer = 0;

let crawlerX = -40;
let crawlerSpeed = 0.4;

let crawlerFrame = 0;
let crawlerAnimTimer = 0;

let crawlerFlicker = false;
let crawlerFlickerTimer = 0;

let crawlerLunge = false;
let crawlerLungeTimer = 0;
let screenFlash = 0;


let doorScare = false;
let doorScareTimer = 0;

let hallwayShake = 0;

let ventJumpscare = false;
let ventJumpscareTimer = 0;


let whisperText = "";
let whisperOpacity = 0;


let ventCorrectStreak = 0;
let ventCorrectTimer = 0;
let ventWrongTimer = 0;









/* ============================
   CINEMATIC INTRO VARIABLES
   ============================ */
let introActive = false;
let introOpacity = 0;
let introTimer = 0;
let introTitle = "THE BUILDING THAT REMEMBERS";

/* ============================
   DEATH ANIMATION VARIABLES
   ============================ */
let deathActive = false;
let deathTimer = 0;
let deathShake = 0;

/* ============================
   GHOST MECHANIC VARIABLES
   ============================ */
let correctVent = 1;
let ventTimer = 0;

let flickerActive = false;
let flickerTimer = 0;

let scratching = false;
let scratchTimer = 0;

let loopTimer = 0;
let loopFreeze = false;

let survivalTimer = 0;

/* ============================
   ELEVATOR TRANSITION
   ============================ */
let transitionActive = false;
let transitionTimer = 0;

/* ============================
   START GAME
   ============================ */
function startPixelHorrorGame() {
  document.getElementById("pixel-horror-overlay").style.display = "block";

  canvas = document.getElementById("horrorCanvas");
  ctx = canvas.getContext("2d");

  currentFloor = 1;
  gameRunning = true;

  // Reset player
  player.x = 20;
  player.y = 200;
  player.dir = 1;

  // Reset states
  deathActive = false;
  transitionActive = false;
  ghostTimer = 0;
  survivalTimer = 0;

  // Start intro
  introActive = true;
  introOpacity = 0;
  introTimer = 0;

  requestAnimationFrame(gameLoop);
}

/* ============================
   EXIT GAME
   ============================ */
document.getElementById("exitHorrorGame").onclick = () => {
  document.getElementById("pixel-horror-overlay").style.display = "none";
  gameRunning = false;
  introActive = false;
  transitionActive = false;
  deathActive = false;
};

/* ============================
   KEYBOARD INPUT
   ============================ */
document.addEventListener("keydown", e => {
  keys[e.key.toLowerCase()] = true;
});

document.addEventListener("keyup", e => {
  keys[e.key.toLowerCase()] = false;
});


/* ============================
   FLOOR SETUP
   ============================ */
function setupFloor(floor) {
  ghostActive = false;
  ghostTimer = 0;
  player.x = 20;
  player.y = 200;

  ventTimer = 0;
  flickerActive = false;
  scratching = false;
  scratchTimer = 0;
  loopTimer = 0;
  loopFreeze = false;
  survivalTimer = 0;

  switch (floor) {
    case 1:
  // Hallway Crawler
  crawlerX = -40;
  crawlerSpeed = 0.4;
  crawlerFrame = 0;
  crawlerAnimTimer = 0;
  crawlerFlicker = false;
  crawlerFlickerTimer = 0;
  crawlerLunge = false;
  crawlerLungeTimer = 0;
  break;

    case 2:
      // Pipe Whisperer
      correctVent = Math.random() < 0.5 ? 1 : 2;
      break;
    case 3:
      // Lightkeeper
      break;
    case 4:
      // Door Scratcher
      break;
    case 5:
      // Memory Loop Twins
      break;
  }
}

/* ============================
   INTRO DRAW
   ============================ */
function drawIntro() {
  introTimer++;

  if (introTimer < 120) {
    introOpacity = introTimer / 120;
  } else if (introTimer < 240) {
    introOpacity = 1;
  } else if (introTimer < 360) {
    introOpacity = 1 - ((introTimer - 240) / 120);
  } else {
    introActive = false;
    gameRunning = true;

    setupFloor(currentFloor);
    return;
  }

  ctx.fillStyle = "black";
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  ctx.globalAlpha = introOpacity;
  ctx.fillStyle = "white";
  ctx.font = "20px serif";
  ctx.textAlign = "center";
  ctx.fillText(introTitle, canvas.width / 2, canvas.height / 2);

  if (Math.random() < 0.05) {
    ctx.fillStyle = "rgba(255,0,0,0.2)";
    ctx.fillRect(0, 0, canvas.width, canvas.height);
  }

  ctx.globalAlpha = 1;
}

/* ============================
   ELEVATOR TRANSITION
   ============================ */
function startTransition() {
  transitionActive = true;
  transitionTimer = 0;
}

function drawTransition() {
  transitionTimer++;

  let opacity = Math.min(1, transitionTimer / 60);
  ctx.fillStyle = `rgba(0,0,0,${opacity})`;
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  if (transitionTimer > 60 && transitionTimer < 120) {
    ctx.fillStyle = "rgba(255,255,255,0.4)";
    ctx.font = "12px serif";
    ctx.textAlign = "center";
    ctx.fillText("THE BUILDING REMEMBERS...", canvas.width / 2, canvas.height / 2);
  }

  if (transitionTimer >= 150) {
    transitionActive = false;
    setupFloor(currentFloor);
  }
}

/* ============================
   CINEMATIC DEATH ANIMATION
   ============================ */
function triggerDeath() {
  if (deathActive) return;
  deathActive = true;
  deathTimer = 0;
  gameRunning = false;
}

function drawDeath() {
  deathTimer++;

  deathShake = Math.sin(deathTimer * 0.5) * 4;

  ctx.fillStyle = "black";
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  if (deathTimer < 30 || (deathTimer % 20 < 10)) {
    ctx.fillStyle = "rgba(255,0,0,0.3)";
    ctx.fillRect(0, 0, canvas.width, canvas.height);
  }

  if (deathTimer < 40) {
    ctx.fillStyle = "white";
    ctx.fillRect(
      canvas.width / 2 - 20 + deathShake,
      canvas.height / 2 - 20,
      40,
      40
    );
  }

  if (deathTimer > 40) {
    ctx.fillStyle = deathTimer % 15 < 7 ? "white" : "red";
    ctx.font = "20px serif";
    ctx.textAlign = "center";

    let glitch = Math.random() < 0.2 ? (Math.random() * 10 - 5) : 0;

    ctx.fillText(
      "THE BUILDING THAT REMEMBERS",
      canvas.width / 2 + glitch,
      canvas.height / 2
    );
  }

  if (deathTimer > 180) {
    document.getElementById("pixel-horror-overlay").style.display = "none";
    deathActive = false;
  }
}

/* ============================
   END GAME (WIN)
   ============================ */
function endGameWin() {
  gameRunning = false;

  let t = 0;
  function finalSequence() {
    t++;

    ctx.fillStyle = "black";
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    ctx.fillStyle = t % 20 < 10 ? "white" : "red";
    ctx.font = "20px serif";
    ctx.textAlign = "center";

    let glitch = Math.random() < 0.1 ? (Math.random() * 10 - 5) : 0;
    ctx.fillText("THE BUILDING THAT REMEMBERS", canvas.width / 2 + glitch, canvas.height / 2);

    if (t < 240) {
      requestAnimationFrame(finalSequence);
    } else {
      document.getElementById("pixel-horror-overlay").style.display = "none";
    }
  }

  finalSequence();
}

/* ============================
   GAME LOOP
   ============================ */
function gameLoop() {
  if (introActive) {
    drawIntro();
  } else if (transitionActive) {
    drawTransition();
  } else if (deathActive) {
    drawDeath();
  } else if (gameRunning) {
    update();
    draw();
  }

  requestAnimationFrame(gameLoop);
}

/* ============================
   UPDATE LOGIC
   ============================ */
function update() {
  // Floor 5 freeze: still check for forbidden input, but no movement
  if (loopFreeze) {
    loopTimer++;
    if (keys["ArrowLeft"] || keys["ArrowRight"]) triggerDeath();
    if (loopTimer > 200) {
      loopTimer = 0;
      loopFreeze = false;
    }
    return;
  }

  // Movement
  if (keys["d"] || keys["D"]) {
  player.x += player.speed;
  player.dir = 1;
}

if (keys["a"] || keys["A"]) {
  player.x -= player.speed;
  player.dir = -1;
}


  // Clamp
  if (player.x < 10) player.x = 10;
  if (player.x > 440) player.x = 440;

  ghostTimer++;

/* FLOOR 1 — CRAWLER */
if (currentFloor === 1) {

  // Turning around kills you
  if (player.dir === -1) triggerDeath();


 // Crawler chases you (but not once it's lunging)
if (!doorScare && !crawlerLunge) {
  crawlerX += crawlerSpeed;
}



  // If crawler reaches player → death
if (!doorScare && !crawlerLunge && crawlerX + 12 >= player.x) {
  crawlerFrame = 2;
  crawlerLunge = true;
  crawlerLungeTimer = 0;
}



  // Animate crawler
  crawlerAnimTimer++;
  if (crawlerAnimTimer > 20) {
    crawlerAnimTimer = 0;
    crawlerFrame = (crawlerFrame + 1) % 2;
  }

  // D) Proximity panic (lights flicker when crawler is close)
  if (player.x - crawlerX < 80) {   // within 80px
    crawlerFlicker = true;
  } else {
    crawlerFlicker = false;
    crawlerFlickerTimer = 0;
  }

  if (crawlerFlicker) {
    crawlerFlickerTimer++;
  }
}

// Proximity camera shake (gets stronger as crawler gets closer)
let dist = player.x - crawlerX;
if (dist < 120) {
  hallwayShake = (120 - dist) * 0.05;  // smooth ramp
} else {
  hallwayShake = 0;
}


// Lunge attack sequence (Step 5)
if (crawlerLunge) {
  crawlerLungeTimer++;

  // Flash red for dramatic effect
  if (crawlerLungeTimer === 1) {
    screenFlash = 20; 
  }

  // After 15 frames, kill the player
  if (crawlerLungeTimer > 15) {
    triggerDeath();
  }
}

// ============================
// DOOR ESCAPE SCARE (Floor 1)
// ============================
if (doorScare) {
  doorScareTimer++;

  // Freeze player + crawler
  player.speed = 0;

  // Flash + shake when crawler hits door
  if (doorScareTimer === 20) {
    screenFlash = 15;
  }

  // Screen shake effect
  if (doorScareTimer > 20 && doorScareTimer < 50) {
    deathShake = Math.sin(doorScareTimer * 1.5) * 3;
  }

  // After scare finishes → start normal transition
  if (doorScareTimer > 60) {
    doorScare = false;
    player.speed = 1.2;

    currentFloor++;
    startTransition();
  }
}







/* FLOOR 2 — PIPE WHISPERER */
if (currentFloor === 2) {

  let ventX = correctVent === 1 ? 150 : 250;
  let wrongVentX = correctVent === 1 ? 250 : 150;

  // ============================
  // CORRECT VENT
  // ============================
  if (Math.abs(player.x - ventX) < 40) {
    ventCorrectTimer++;

    if (ventCorrectTimer === 60) {
      whisperText = "come closer";
      whisperOpacity = 1;
    }

    if (ventCorrectTimer > 120) {
      ventCorrectStreak++;
      ventCorrectTimer = 0;
      correctVent = Math.random() < 0.5 ? 1 : 2; // new random vent
    }

  } else {
    ventCorrectTimer = 0;
  }

  // ============================
  // WRONG VENT
  // ============================
  if (Math.abs(player.x - wrongVentX) < 40) {
    ventWrongTimer++;

    if (ventWrongTimer === 40) {
      whisperText = "not that one";
      whisperOpacity = 1;
    }

    if (ventWrongTimer > 90 && !ventJumpscare) {
      ventJumpscare = true;
      ventJumpscareTimer = 0;
      ventCorrectStreak = 0; // reset streak
    }

  } else {
    ventWrongTimer = 0;
  }

  // ============================
  // JUMPSCARE
  // ============================
  if (ventJumpscare) {
    ventJumpscareTimer++;

    if (ventJumpscareTimer < 20) screenFlash = 20;

    deathShake = Math.sin(ventJumpscareTimer * 2) * 6;

    if (ventJumpscareTimer > 40) {
      ventJumpscare = false;
      triggerDeath();
    }
  }

  // ============================
  // EXIT DOOR APPEARS AFTER 5 CORRECT GUESSES
  // ============================
  if (ventCorrectStreak >= 5) {
    startTransition();
  }
}




}




  /* FLOOR 3 — LIGHTKEEPER */
  if (currentFloor === 3) {
    if (ghostTimer % 120 === 0) {
      flickerActive = true;
      flickerTimer = 0;
    }

    if (flickerActive) {
      flickerTimer++;
      if (player.dir === -1) triggerDeath();
      if (flickerTimer > 40) flickerActive = false;
    }
  }

  /* FLOOR 4 — DOOR SCRATCHER */
  if (currentFloor === 4) {
    if (ghostTimer % 150 === 0) {
      scratching = true;
      scratchTimer = 0;
    }

    if (scratching) {
      scratchTimer++;
      if (keys["ArrowLeft"] || keys["ArrowRight"]) triggerDeath();
      if (scratchTimer > 60) scratching = false;
    }
  }

  /* FLOOR 5 — MEMORY LOOP TWINS */
  if (currentFloor === 5) {
    loopTimer++;
    if (loopTimer < 120) {
      loopFreeze = true;
    } else if (loopTimer > 200) {
      loopTimer = 0;
      loopFreeze = false;
    }
  }

  

 // Floor completion
if (player.x >= 440 && !transitionActive && !deathActive && !doorScare) {

  // Trigger door scare ONLY on Floor 1
  if (currentFloor === 1) {
    doorScare = true;
    doorScareTimer = 0;
    return; // pause normal transition, let doorScare block handle the rest
  }

  // Normal transition for other floors
  currentFloor++;
  if (currentFloor > 5) {
    endGameWin();
    return;
  }
  startTransition();
}


}

/* ============================
