<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Borough Selector</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Archivo:wght@300;400;500&display=swap" rel="stylesheet">

  <style>
    :root {
      --accent: {{ selected.accent }};
      --borough-color: {{ selected.color }};
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Archivo', sans-serif;
      background-color: {{ selected.color }};
      color: #e8ded0;
      min-height: 100vh;
      overflow: hidden;
      position: relative;
      transition: background-color 0.6s ease;
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 100;
      opacity: 0.3;
    }

    h1 {
      font-family: 'Archivo', sans-serif;
      font-weight: 500;
      letter-spacing: 0.3em;
      font-size: 0.75rem;
    }

    .radial-container {
      position: absolute;
      bottom: -10%;
      left: 50%;
      transform: translateX(-50%);
      width: 700px;
      height: 700px;
    }

    .arc-ring {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      border: 1px solid rgba(232, 222, 208, 0.1);
    }
    .arc-ring:nth-child(1) { inset: 10%; }
    .arc-ring:nth-child(2) { inset: 22%; }
    .arc-ring:nth-child(3) { inset: 34%; }

    .borough-img-wrap {
      position: absolute;
      inset: 30%;
      border-radius: 50%;
      overflow: hidden;
      box-shadow: 0 30px 80px rgba(0,0,0,0.6);
      transition: transform 0.6s cubic-bezier(.23,1,.32,1);
    }
    .borough-img-wrap:hover { transform: scale(1.03); }

    .borough-label {
      font-size: 0.6rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(232,222,208,0.45);
      transition: color 0.3s;
      white-space: nowrap;
      cursor: pointer;
      background: none;
      border: none;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .borough-label.active { color: #e8ded0; }

    .borough-label .dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: rgba(232,222,208,0.3);
      transition: background 0.3s;
      flex-shrink: 0;
    }
    .borough-label.active .dot {
      background: var(--accent);
      box-shadow: 0 0 8px var(--accent);
    }

    .borough-panel {
      position: absolute;
      left: 40px;
      top: 50%;
      transform: translateY(-50%);
      z-index: 10;
    }
    .borough-panel .name {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      font-size: 2.5rem;
      line-height: 1.1;
      text-transform: capitalize;
      margin-bottom: 16px;
    }

    .visit-btn {
      display: inline-block;
      padding: 10px 24px;
      border: 1px solid rgba(232,222,208,0.5);
      border-radius: 999px;
      font-size: 0.6rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: #e8ded0;
      text-decoration: none;
      transition: background 0.2s, color 0.2s;
    }
    .visit-btn:hover {
      background: #e8ded0;
      color: var(--borough-color);
    }

    .nav-link {
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(232,222,208,0.35);
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp 0.5s ease both; }

    @keyframes fadeLeft {
      from { opacity: 0; transform: translateY(-50%) translateX(-16px); }
      to   { opacity: 1; transform: translateY(-50%) translateX(0); }
    }
    .fade-left { animation: fadeLeft 0.5s ease both; }

    @keyframes spinIn {
      from { opacity: 0; transform: translateX(-50%) rotate(-8deg) scale(0.94); }
      to   { opacity: 1; transform: translateX(-50%) rotate(0deg) scale(1); }
    }
    .spin-in { animation: spinIn 0.6s cubic-bezier(.23,1,.32,1) both; }

    .borough-form {
      position: absolute;
      top: 50%; left: 50%;
      transform-origin: 0 0;
    }
  </style>
</head>

<body>


<div class="absolute top-0 left-0 right-0 flex items-center px-8 py-6 z-10">
  <h1 class="fade-up">Borough Selector</h1>
</div>


<div class="borough-panel fade-left">
  <p class="name">{{ selected.name }}</p>
  <a href="/borough/{{ selected.name | replace(' ', '-') }}" class="visit-btn">
    Explore {{ selected.name }} &rarr;
  </a>
</div>


<div class="radial-container spin-in">
  <div class="arc-ring"></div>
  <div class="arc-ring"></div>
  <div class="arc-ring"></div>

  <div class="borough-img-wrap">
    <img src="{{ url_for('static', filename='images/' + selected.name + '.png') }}"
         onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
         style="width:100%; height:100%; object-fit:cover;">
    <div style="display:none; width:100%; height:100%; background:radial-gradient(circle at 40% 35%, {{ selected.accent }}, {{ selected.color }}, #0a0a1a);"></div>
  </div>

  {% for borough in boroughs %}
  <form method="POST" class="borough-form" data-index="{{ loop.index0 }}" data-total="{{ boroughs|length }}">
    <button type="submit" name="borough" value="{{ borough.name }}"
      class="borough-label {% if borough.name == selected.name %}active{% endif %}">
      <span class="dot"></span>{{ borough.name }}
    </button>
  </form>
  {% endfor %}
</div>


<div class="absolute bottom-6 left-8 right-8 flex justify-between z-10">
  <div class="flex gap-6">
    <a href="#" class="nav-link">About</a>
    <a href="#" class="nav-link">Contact</a>
  </div>
  <a href="#" class="nav-link">Privacy</a>
</div>

<script>
  document.querySelectorAll('.borough-form').forEach(form => {
    const idx   = parseInt(form.dataset.index);
    const total = parseInt(form.dataset.total);
    const radius = 290;
    const angleDeg = -155 + (idx / (total - 1)) * 130;
    const angleRad = angleDeg * Math.PI / 180;
    const x = 350 + radius * Math.cos(angleRad);
    const y = 350 + radius * Math.sin(angleRad);
    form.style.top  = y + 'px';
    form.style.left = x + 'px';
    form.style.transform = 'translate(-50%, -50%)';
  });

  document.body.style.backgroundColor = 'transparent';
  requestAnimationFrame(() => {
    document.body.style.backgroundColor = '{{ selected.color }}';
  });
</script>

<style>
  .pigeon {
    position: fixed;
    pointer-events: none;
    z-index: 9999;
  }
</style>

<script>
  function spawnPigeon() {
    const p = document.createElement('img');
    p.classList.add('pigeon');
    p.src = "{{ url_for('static', filename='images/pigeon.gif') }}";

    const startY = Math.random() * (window.innerHeight * 0.65) + 40;

    const size = 80 + Math.random() * 80;
    p.style.width  = size + 'px';
    p.style.height = 'auto';
    p.style.transform = 'scaleX(-1)';
    p.style.top    = startY + 'px';

    const duration = 1800 + Math.random() * 1200;

    document.body.appendChild(p);

    let startTime = null;
    const startX  = -(size + 60);
    const endX    = window.innerWidth + 60;

    function step(ts) {
      if (!startTime) startTime = ts;
      const progress = (ts - startTime) / duration;
      if (progress >= 1) {
        p.remove();
        return;
      }
      const drift = Math.sin(progress * Math.PI * 5) * 10;
      p.style.left = (startX + (endX - startX) * progress) + 'px';
      p.style.top  = (startY + drift) + 'px';
      requestAnimationFrame(step);
    }

    requestAnimationFrame(step);
  }

  let pigeonSpawningPaused = false;

  document.addEventListener('click', spawnPigeon);

  function autoSpawn() {
    if (!pigeonSpawningPaused) {
      spawnPigeon();
    }
    setTimeout(autoSpawn, 2000 + Math.random() * 6000);
  }

  autoSpawn();
</script>


<!-- NOIR OVERLAY -->
<div id="noirOverlay"
     class="fixed inset-0 hidden opacity-0 transition-opacity duration-700
            bg-black/90 backdrop-blur-sm z-[9998] pointer-events-none">

  <!-- Noir Intro -->
  <div id="noirIntro"
       class="absolute inset-0 flex items-center justify-center text-center
              text-[#e8ded0] text-4xl font-light opacity-0 transition-opacity duration-700"
       style="font-family:'Cormorant Garamond', serif; letter-spacing:0.05em;">
    <div>
      <div>THE NIGHT BELONGS TO THE BIRDS</div>
      <div class="text-lg mt-2 opacity-70 tracking-widest">NYC — After Hours</div>
    </div>
  </div>

  <!-- Noir Game Canvas -->
  <canvas id="noirCanvas"
          class="absolute inset-0 w-full h-full opacity-0 transition-opacity duration-700">
  </canvas>
</div>

<style>
  #noirOverlay.active {
    pointer-events: auto;
  }
  .pigeon {
    position: fixed;
    pointer-events: none;
    z-index: 9999;
  }
</style>



<script>
document.addEventListener("DOMContentLoaded", () => {
  const trigger = document.querySelector(".borough-img-wrap");
  const overlay = document.getElementById("noirOverlay");
  const intro   = document.getElementById("noirIntro");
  const canvas  = document.getElementById("noirCanvas");
  const ctx     = canvas.getContext("2d");

  let noirClicks = 0;
  let noirActive = false;

  let skyline = [];
  let fogLayers = [];
  let rooftops = [];
  let rain = [];
  let steam = [];
  let taxiBeams = [];
  let ambientBirds = [];
  let lightningFlash = 0;

  let pigeon = {
    x: 200,
    y: 300,
    vx: 0,
    vy: 0,
    size: 40
  };

  let gravity = 0.4;
  let flapStrength = -8;

  /* INPUT STATE (W, A, D only) */
  let keys = {
    left: false,
    right: false,
    flap: false
  };

  document.addEventListener("keydown", (e) => {
    if (e.key === "w" || e.key === "W") keys.flap = true;
    if (e.key === "a" || e.key === "A") keys.left = true;
    if (e.key === "d" || e.key === "D") keys.right = true;
  });

  document.addEventListener("keyup", (e) => {
    if (e.key === "w" || e.key === "W") keys.flap = false;
    if (e.key === "a" || e.key === "A") keys.left = false;
    if (e.key === "d" || e.key === "D") keys.right = false;
  });

  function resizeCanvas() {
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resizeCanvas();
  window.addEventListener("resize", resizeCanvas);

  /* OPEN OVERLAY */
  function openNoirOverlay() {
    overlay.classList.remove("hidden");
    overlay.classList.add("active");

    pigeonSpawningPaused = true;
    document.removeEventListener('click', spawnPigeon);

    requestAnimationFrame(() => {
      overlay.style.opacity = 1;
    });

    setTimeout(() => intro.style.opacity = 1, 300);
    setTimeout(() => intro.style.opacity = 0, 2000);
    setTimeout(() => {
      canvas.style.opacity = 1;
      initWorld();
      startLoop();
    }, 2600);
  }

  /* INIT WORLD */
  function initWorld() {
    skyline = [];
    fogLayers = [];
    rooftops = [];
    rain = [];
    steam = [];
    taxiBeams = [];
    ambientBirds = [];
    lightningFlash = 0;

    initRain();
    initSteam();
    initTaxiBeams();
    initAmbientBirds();

    // Skyline
    let skylineCount = Math.ceil(canvas.width / 400) + 2;
    for (let i = 0; i < skylineCount; i++) {
      skyline.push({
        x: i * 400,
        y: canvas.height - (250 + Math.random() * 150),
        w: 400,
        h: 300 + Math.random() * 200
      });
    }

    // Fog
    for (let i = 0; i < 3; i++) {
      fogLayers.push({
        x: Math.random() * canvas.width,
        y: canvas.height * (0.3 + Math.random() * 0.3),
        w: 350 + Math.random() * 200,
        h: 120 + Math.random() * 80,
        opacity: 0.02 + Math.random() * 0.03,
        speed: 0.1 + Math.random() * 0.15,
        drift: (Math.random() - 0.5) * 0.05
      });
    }

    // Rooftops
    let count = Math.ceil(canvas.width / 300) + 3;
    for (let i = 0; i < count; i++) {
      rooftops.push({
        x: i * 300,
        y: canvas.height - (80 + Math.random() * 120),
        w: 300,
        h: 200
      });
    }
  }

  function initRain() {
    rain = [];
    for (let i = 0; i < 120; i++) {
      rain.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        len: 10 + Math.random() * 15,
        speed: 6 + Math.random() * 4
      });
    }
  }

  function initSteam() {
    steam = [];
    for (let i = 0; i < 6; i++) {
      steam.push({
        x: Math.random() * canvas.width,
        y: canvas.height - (120 + Math.random() * 200),
        w: 80 + Math.random() * 40,
        h: 120 + Math.random() * 60,
        opacity: 0.05 + Math.random() * 0.05,
        speed: 0.3 + Math.random() * 0.2
      });
    }
  }

  function initTaxiBeams() {
    taxiBeams = [];
    for (let i = 0; i < 3; i++) {
      taxiBeams.push({
        x: Math.random() * canvas.width,
        y: canvas.height - (60 + Math.random() * 80),
        w: 200 + Math.random() * 150,
        h: 40,
        opacity: 0.05 + Math.random() * 0.05,
        speed: 1 + Math.random() * 1.5
      });
    }
  }

  function initAmbientBirds() {
    ambientBirds = [];
    for (let i = 0; i < 5; i++) {
      ambientBirds.push({
        x: Math.random() * canvas.width,
        y: 80 + Math.random() * 200,
        speed: 0.5 + Math.random() * 0.5
      });
    }
  }

  function updateLightning() {
    if (Math.random() < 0.002) {
      lightningFlash = 1;
    }
    if (lightningFlash > 0) {
      lightningFlash -= 0.05;
      if (lightningFlash < 0) lightningFlash = 0;
    }
  }

  /* UPDATE WORLD */
  function updateWorld() {
    // Skyline scroll
    skyline.forEach(b => {
      b.x -= 0.4;
      if (b.x + b.w < 0) {
        b.x = canvas.width + Math.random() * 200;
        b.h = 300 + Math.random() * 200;
        b.y = canvas.height - (250 + Math.random() * 150);
      }
    });

    // Fog drift
    fogLayers.forEach(layer => {
      layer.x -= layer.speed;
      layer.y += layer.drift;
      if (layer.x + layer.w < 0) {
        layer.x = canvas.width + Math.random() * 200;
        layer.y = canvas.height * (0.3 + Math.random() * 0.3);
      }
    });

    // Rain
    rain.forEach(r => {
      r.y += r.speed;
      r.x += 1.5;
      if (r.y > canvas.height) {
        r.y = -20;
        r.x = Math.random() * canvas.width;
      }
    });

    // Steam
    steam.forEach(s => {
      s.y -= s.speed;
      if (s.y + s.h < 0) {
        s.y = canvas.height - (120 + Math.random() * 200);
        s.x = Math.random() * canvas.width;
      }
    });

    // Taxi beams
    taxiBeams.forEach(b => {
      b.x -= b.speed;
      if (b.x + b.w < 0) {
        b.x = canvas.width + Math.random() * 300;
      }
    });

    // Ambient birds
    ambientBirds.forEach(b => {
      b.x -= b.speed;
      if (b.x < -50) {
        b.x = canvas.width + 50;
        b.y = 80 + Math.random() * 200;
      }
    });
  }

  function updatePigeon() {
    if (keys.flap) {
      pigeon.vy += flapStrength * 0.2;
    }

    pigeon.vy += gravity;
    pigeon.y += pigeon.vy;

    if (keys.left)  pigeon.vx -= 0.4;
    if (keys.right) pigeon.vx += 0.4;

    pigeon.vx *= 0.92;
    pigeon.x += pigeon.vx;

    if (pigeon.y > canvas.height - 80) {
      pigeon.y = canvas.height - 80;
      pigeon.vy = 0;
    }
    if (pigeon.y < 40) {
      pigeon.y = 40;
      pigeon.vy = 0;
    }
    if (pigeon.x < 40) pigeon.x = 40;
    if (pigeon.x > canvas.width - 40) pigeon.x = canvas.width - 40;
  }

  /* DRAW WORLD */
  function drawWorld() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // Skyline
    ctx.fillStyle = "#0f0f12";
    skyline.forEach(b => {
      ctx.fillRect(b.x, b.y, b.w, b.h);
    });

    // Fog
    fogLayers.forEach(layer => {
      ctx.fillStyle = `rgba(200,200,200,${layer.opacity})`;
      ctx.beginPath();
      ctx.ellipse(layer.x, layer.y, layer.w, layer.h, 0, 0, Math.PI * 2);
      ctx.fill();
    });

    // Rooftops
    ctx.fillStyle = "#1a1a1d";
    rooftops.forEach(r => {
      ctx.fillRect(r.x, r.y, r.w, r.h);
    });

    // Steam
    steam.forEach(s => {
      ctx.fillStyle = `rgba(200,200,200,${s.opacity})`;
      ctx.beginPath();
      ctx.ellipse(s.x, s.y, s.w, s.h, 0, 0, Math.PI * 2);
      ctx.fill();
    });

    // Taxi beams
    taxiBeams.forEach(b => {
      ctx.fillStyle = `rgba(255,255,200,${b.opacity})`;
      ctx.fillRect(b.x, b.y, b.w, b.h);
    });

    // Rain
    ctx.strokeStyle = "rgba(220,220,255,0.25)";
    ctx.lineWidth = 1;
    rain.forEach(r => {
      ctx.beginPath();
      ctx.moveTo(r.x, r.y);
      ctx.lineTo(r.x - 3, r.y - r.len);
      ctx.stroke();
    });

    // Ambient birds
    ctx.fillStyle = "rgba(200,200,200,0.3)";
    ambientBirds.forEach(b => {
      ctx.beginPath();
      ctx.arc(b.x, b.y, 6, 0, Math.PI * 2);
      ctx.fill();
    });

    // Lightning
    if (lightningFlash > 0) {
      ctx.fillStyle = `rgba(255,255,255,${lightningFlash * 0.8})`;
      ctx.fillRect(0, 0, canvas.width, canvas.height);
    }
  }

  function drawPigeon() {
    const tilt = pigeon.vx * 0.03;

    ctx.save();
    ctx.translate(pigeon.x, pigeon.y);
    ctx.rotate(tilt);

    ctx.fillStyle = "#e8ded0";
    ctx.beginPath();
    ctx.ellipse(0, 0, pigeon.size, pigeon.size * 0.6, 0, 0, Math.PI * 2);
    ctx.fill();

    ctx.fillStyle = "#000";
    ctx.beginPath();
    ctx.arc(pigeon.size * 0.4, -pigeon.size * 0.1, 4, 0, Math.PI * 2);
    ctx.fill();

    ctx.restore();
  }

  /* GAME LOOP */
  function gameLoop() {
    if (!noirActive) return;

    updateWorld();
    updatePigeon();
    updateLightning();

    drawWorld();
    drawPigeon();

    requestAnimationFrame(gameLoop);
  }

  function startLoop() {
    noirActive = true;
    requestAnimationFrame(gameLoop);
  }

  /* TRIGGER */
  trigger.addEventListener("click", () => {
    noirClicks++;
    if (noirClicks >= 10 && !noirActive) {
      openNoirOverlay();
    }
  });
});
</script>




</body>
</html>
