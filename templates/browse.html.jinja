/* ============================
   DRAW HALLWAY (noir style)
   ============================ */
function drawHallway() {
  // Background darkness
  ctx.fillStyle = "black";
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  // Subtle wall gradient
  let grd = ctx.createLinearGradient(0, 0, 0, canvas.height);
  grd.addColorStop(0, "#0a0a0a");
  grd.addColorStop(1, "#000000");
  ctx.fillStyle = grd;
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  // Ceiling lights (dim, flickering)
  ctx.fillStyle = crawlerFlicker ? "rgba(255,0,0,0.2)" : "rgba(255,255,255,0.05)";
  ctx.fillRect(60, 20, 40, 6);
  ctx.fillRect(200, 20, 40, 6);
  ctx.fillRect(340, 20, 40, 6);

  // Perspective floor lines
  ctx.strokeStyle = "rgba(255,255,255,0.05)";
  ctx.beginPath();
  ctx.moveTo(0, 212);
  ctx.lineTo(480, 212);
  ctx.stroke();

  ctx.beginPath();
  ctx.moveTo(0, 212);
  ctx.lineTo(240, 260);
  ctx.stroke();

  ctx.beginPath();
  ctx.moveTo(480, 212);
  ctx.lineTo(240, 260);
  ctx.stroke();

  // Wall grime / texture
  for (let i = 0; i < 40; i++) {
    ctx.fillStyle = "rgba(255,255,255,0.03)";
    let x = Math.random() * 480;
    let y = Math.random() * 200;
    ctx.fillRect(x, y, 2, 2);
  }

  // EXIT DOOR (glowing + window)
ctx.strokeStyle = "rgba(255,255,255,0.9)";
ctx.lineWidth = 2;
ctx.strokeRect(440, 150, 30, 60);

// Door glow pulse
let glow = Math.sin(ghostTimer * 0.1) * 0.1 + 0.2;
ctx.fillStyle = `rgba(255,0,0,${glow})`;
ctx.fillRect(440, 150, 30, 60);

// Window slit
ctx.fillStyle = "rgba(255,255,255,0.2)";
ctx.fillRect(448, 160, 14, 8);

// EXIT SIGN (flickering red)
let exitFlicker = (ghostTimer % 20 < 10) ? 1 : 0.4;
if (crawlerFlicker) exitFlicker = Math.random() * 0.6 + 0.2; // panic flicker

ctx.fillStyle = `rgba(255,0,0,${exitFlicker})`;
ctx.font = "10px serif";
ctx.textAlign = "center";
ctx.fillText("EXIT", 455, 145);
ctx.fillStyle = "rgba(255,0,0,0.1)";
ctx.fillRect(440, 150, 30, 10);


}

/* ============================
   DRAW HALLWAY — FLOOR 2
   ============================ */
function drawHallwayFloor2() {
  // Background
  ctx.fillStyle = "#050505";
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  // Vertical pipes
  for (let i = 0; i < 6; i++) {
    ctx.fillStyle = "rgba(255,255,255,0.03)";
    ctx.fillRect(60 + i * 70, 0, 6, 270);
  }

  // Floor line
  ctx.strokeStyle = "#222";
  ctx.lineWidth = 2;
  ctx.beginPath();
  ctx.moveTo(0, 212);
  ctx.lineTo(480, 212);
  ctx.stroke();

  ctx.strokeStyle = "white";
ctx.strokeRect(150, 180, 20, 20);
ctx.strokeRect(250, 180, 20, 20);


  // Glow on correct vent

  // Steam bursts from pipes
// Exit door
ctx.strokeStyle = "white";
ctx.strokeRect(440, 150, 30, 60);

ctx.fillStyle = "rgba(255,255,255,0.05)";
ctx.fillRect(440, 150, 30, 60);


}





/* ============================
   DRAW GHOST
   ============================ */
function drawGhost() {
  if (currentFloor === 1) {
    drawCrawler(crawlerX, player.y - 12);
  }

  if (currentFloor === 3 && flickerActive) {
    ctx.fillStyle = "white";
    ctx.fillRect(400, 100, 20, 40);
  }

  if (currentFloor === 4) {
    ctx.strokeStyle = scratching ? "red" : "white";
    ctx.strokeRect(300, 150, 40, 60);
  }

  if (currentFloor === 5) {
    ctx.fillStyle = loopFreeze ? "white" : "rgba(255,255,255,0.3)";
    ctx.fillRect(200, 180, 10, 20);
    ctx.fillRect(230, 180, 10, 20);
  }
}

