<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Hidden Gems — Borough Directory</title>
  {% include 'icon.html.jinja' %}
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Archivo:wght@300;400;500&display=swap" rel="stylesheet">

  <style>
    :root {
      --accent: {{ selected.accent }};
      --borough-color: {{ selected.color }};
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Archivo', sans-serif;
      background-color: {{ selected.color }};
      color: #e8ded0;
      min-height: 100vh;
      overflow: hidden;
      position: relative;
    }

    
    #bg-overlay {
      position: fixed; inset: 0;
      pointer-events: none;
      z-index: 1;
      opacity: 0;
      transition: opacity 0.5s ease;
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 100;
      opacity: 0.3;
    }

    h1 {
      font-family: 'Archivo', sans-serif;
      font-weight: 500;
      letter-spacing: 0.3em;
      font-size: 0.75rem;
    }

    .radial-container {
      position: absolute;
      bottom: -10%;
      left: 50%;
      transform: translateX(-50%);
      width: 700px;
      height: 700px;
    }

    .arc-ring {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      border: 1px solid rgba(232, 222, 208, 0.1);
      transition: border-color 0.6s ease;
    }
    .arc-ring:nth-child(1) { inset: 10%; }
    .arc-ring:nth-child(2) { inset: 22%; }
    .arc-ring:nth-child(3) { inset: 34%; }

    .borough-img-wrap {
      position: absolute;
      inset: 30%;
      border-radius: 50%;
      overflow: hidden;
      box-shadow: 0 30px 80px rgba(0,0,0,0.6);
      transition: transform 0.6s cubic-bezier(.23,1,.32,1);
    }
    .borough-img-wrap:hover { transform: scale(1.03); }

    
    .borough-img-wrap img {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transition: opacity 0.5s ease;
    }
    .borough-img-wrap .img-current { opacity: 1; }
    .borough-img-wrap .img-next    { opacity: 0; }

    .borough-label {
      font-size: 0.6rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(232,222,208,0.45);
      transition: color 0.3s, transform 0.2s;
      white-space: nowrap;
      cursor: pointer;
      background: none;
      border: none;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .borough-label:hover { transform: scale(1.05); }
    .borough-label.active { color: #e8ded0; }

    .borough-label .dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: rgba(232,222,208,0.3);
      transition: background 0.4s, box-shadow 0.4s;
      flex-shrink: 0;
    }
    .borough-label.active .dot {
      background: var(--accent);
      box-shadow: 0 0 8px var(--accent);
    }

    .borough-panel {
      position: absolute;
      left: 40px;
      top: 50%;
      transform: translateY(-50%);
      z-index: 10;
    }
    .borough-panel .name {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      font-size: 2.5rem;
      line-height: 1.1;
      text-transform: capitalize;
      margin-bottom: 16px;
      transition: opacity 0.3s ease, transform 0.4s cubic-bezier(.23,1,.32,1);
    }

    .visit-btn {
      display: inline-block;
      padding: 10px 24px;
      border: 1px solid rgba(232,222,208,0.5);
      border-radius: 999px;
      font-size: 0.6rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: #e8ded0;
      text-decoration: none;
      transition: background 0.2s, color 0.2s, transform 0.2s;
    }
    .visit-btn:hover {
      background: #e8ded0;
      color: var(--borough-color);
      transform: translateY(-1px);
    }

    .nav-link {
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(232,222,208,0.35);
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp 0.5s ease both; }

    @keyframes fadeLeft {
      from { opacity: 0; transform: translateY(-50%) translateX(-16px); }
      to   { opacity: 1; transform: translateY(-50%) translateX(0); }
    }
    .fade-left { animation: fadeLeft 0.5s ease both; }

    @keyframes spinIn {
      from { opacity: 0; transform: translateX(-50%) rotate(-8deg) scale(0.94); }
      to   { opacity: 1; transform: translateX(-50%) rotate(0deg) scale(1); }
    }
    .spin-in { animation: spinIn 0.6s cubic-bezier(.23,1,.32,1) both; }

    .borough-form {
      position: absolute;
      top: 50%; left: 50%;
      transform-origin: 0 0;
    }

    .pigeon {
      position: fixed;
      pointer-events: none;
      z-index: 9999;
    }
  </style>
</head>

<body>

{% include '_nav.html.jinja' %}


<div id="bg-overlay"></div>

<div class="absolute top-0 left-0 right-0 flex items-center px-8 py-6 z-10">
  <h1 class="fade-up">Borough Directory</h1>
</div>


<div class="borough-panel fade-left" id="borough-panel">
  <p class="name" id="borough-name">{{ selected.name }}</p>
  <a href="/borough/{{ selected.name | replace(' ', '-') }}" class="visit-btn" id="visit-btn">
    Explore {{ selected.name }} &rarr;
  </a>
</div>

<div class="radial-container spin-in">
  <div class="arc-ring"></div>
  <div class="arc-ring"></div>
  <div class="arc-ring"></div>

  <div class="borough-img-wrap" id="centerImage">
    <img class="img-current" id="img-current"
         src="{{ url_for('static', filename='images/' + selected.name + '.png') }}"
         onerror="this.style.display='none'">
    <img class="img-next" id="img-next" src="">
    <div id="img-fallback" style="display:none;width:100%;height:100%;background:radial-gradient(circle at 40% 35%, {{ selected.accent }}, {{ selected.color }}, #0a0a1a);"></div>
  </div>

  {% for borough in boroughs %}
  <form method="POST" class="borough-form" data-index="{{ loop.index0 }}" data-total="{{ boroughs|length }}"
        data-name="{{ borough.name }}"
        data-color="{{ borough.color }}"
        data-accent="{{ borough.accent }}"
        data-image="{{ url_for('static', filename='images/' + borough.name + '.png') }}">
    <button type="button"
      class="borough-label {% if borough.name == selected.name %}active{% endif %}"
      onclick="selectBorough(this)">
      <span class="dot"></span>{{ borough.name }}
    </button>
  </form>
  {% endfor %}
</div>

<div class="absolute bottom-6 left-8 right-8 flex justify-between z-10">
  <div class="flex gap-6">
    <a href="#" class="nav-link">About</a>
    <a href="#" class="nav-link">Contact</a>
  </div>
  <a href="#" class="nav-link">Privacy</a>
</div>

<script>
  
  document.querySelectorAll('.borough-form').forEach(form => {
    const idx    = parseInt(form.dataset.index);
    const total  = parseInt(form.dataset.total);
    const radius = 290;
    const angleDeg = -155 + (idx / (total - 1)) * 130;
    const angleRad = angleDeg * Math.PI / 180;
    const x = 350 + radius * Math.cos(angleRad);
    const y = 350 + radius * Math.sin(angleRad);
    form.style.top       = y + 'px';
    form.style.left      = x + 'px';
    form.style.transform = 'translate(-50%, -50%)';
  });

 
  let currentBorough = '{{ selected.name }}';
  let isTransitioning = false;

  function selectBorough(btn) {
    if (isTransitioning) return;
    const form    = btn.closest('.borough-form');
    const name    = form.dataset.name;
    const color   = form.dataset.color;
    const accent  = form.dataset.accent;
    const imgSrc  = form.dataset.image;

    if (name === currentBorough) return;
    isTransitioning = true;
    currentBorough  = name;

   
    document.querySelectorAll('.borough-label').forEach(l => l.classList.remove('active'));
    btn.classList.add('active');

    // Crossfade image
    const imgCurrent = document.getElementById('img-current');
    const imgNext    = document.getElementById('img-next');
    imgNext.src      = imgSrc;
    imgNext.onload   = () => {
      imgNext.style.opacity    = '1';
      imgCurrent.style.opacity = '0';
      setTimeout(() => {
        imgCurrent.src           = imgSrc;
        imgCurrent.style.opacity = '1';
        imgNext.style.opacity    = '0';
      }, 500);
    };
    imgNext.onerror = () => {
      imgNext.style.opacity = '0';
    };

    // Fade background color
    const overlay = document.getElementById('bg-overlay');
    overlay.style.background = color;
    overlay.style.opacity    = '0';
    requestAnimationFrame(() => {
      overlay.style.opacity = '1';
      setTimeout(() => {
        document.body.style.backgroundColor = color;
        overlay.style.opacity = '0';
      }, 500);
    });

    // Update CSS accent var smoothly
    document.documentElement.style.setProperty('--accent', accent);
    document.documentElement.style.setProperty('--borough-color', color);

    
    const nameEl    = document.getElementById('borough-name');
    const visitBtn  = document.getElementById('visit-btn');
    nameEl.style.opacity   = '0';
    nameEl.style.transform = 'translateY(8px)';

    setTimeout(() => {
      nameEl.textContent    = name;
      visitBtn.href         = `/borough/${name.replace(/ /g, '-')}`;
      visitBtn.innerHTML    = `Explore ${name} &rarr;`;
      nameEl.style.transform = 'translateY(-4px)';
      requestAnimationFrame(() => {
        nameEl.style.transition  = 'opacity 0.35s ease, transform 0.35s cubic-bezier(.23,1,.32,1)';
        nameEl.style.opacity     = '1';
        nameEl.style.transform   = 'translateY(0)';
      });
    }, 200);

    // Update server state silently via fetch (no page reload)
    fetch('/browse', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: `borough=${encodeURIComponent(name)}`
    }).then(() => {
      isTransitioning = false;
    });
  }
</script>

<script>
  function spawnPigeon() {
    const p = document.createElement('img');
    p.classList.add('pigeon');
    p.src = "{{ url_for('static', filename='images/pigeon.gif') }}";
    const startY   = Math.random() * (window.innerHeight * 0.65) + 40;
    const size     = 80 + Math.random() * 80;
    const duration = 1800 + Math.random() * 1200;
    p.style.width     = size + 'px';
    p.style.height    = 'auto';
    p.style.transform = 'scaleX(1)';
    p.style.top       = startY + 'px';
    document.body.appendChild(p);
    let startTime = null;
    const startX  = window.innerWidth + 60;
    const endX    = -(size + 60);
    function step(ts) {
      if (!startTime) startTime = ts;
      const progress = (ts - startTime) / duration;
      if (progress >= 1) { p.remove(); return; }
      const drift = Math.sin(progress * Math.PI * 5) * 10;
      p.style.left = (startX + (endX - startX) * progress) + 'px';
      p.style.top  = (startY + drift) + 'px';
      requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  document.addEventListener('click', spawnPigeon);
  function autoSpawn() {
    spawnPigeon();
    setTimeout(autoSpawn, 2000 + Math.random() * 6000);
  }
  autoSpawn();
</script>


<div id="pixel-horror-overlay"
     style="display:none; position:fixed; inset:0; background:black; z-index:999999;">
  <canvas id="horrorCanvas" width="480" height="270"
          style="position:absolute; top:50%; left:50%; transform:translate(-50%, -50%) scale(2);
                 image-rendering:pixelated; background:black;"></canvas>
  <button id="exitHorrorGame"
          style="position:absolute; top:20px; right:20px; padding:6px 12px;
                 background:#111; color:#fff; border:1px solid #444; cursor:pointer; z-index:10;">
    Exit
  </button>
  <div id="horrorControls"
       style="position:absolute; bottom:20px; left:50%; transform:translateX(-50%);
              color:rgba(255,255,255,0.4); font-size:11px; letter-spacing:0.15em; text-transform:uppercase;">
    A / D to move
  </div>
</div>

<script>
let horrorClicks = 0;
window.addEventListener("load", () => {
  const centerImg = document.getElementById("centerImage");
  if (!centerImg) return;
  centerImg.addEventListener("mousedown", (e) => {
    e.stopPropagation();
    horrorClicks++;
    if (horrorClicks >= 10) {
      horrorClicks = 0;
      startPixelHorrorGame();
    }
  });
});

let canvas, ctx;
let player = { x: 20, y: 200, dir: 1, speed: 1.2 };
let keys = {};
let currentFloor = 1;
let gameRunning = false;
let ghostTimer = 0;
let crawlerX = -40, crawlerSpeed = 0.4, crawlerFrame = 0, crawlerAnimTimer = 0;
let crawlerFlicker = false, crawlerFlickerTimer = 0;
let crawlerLunge = false, crawlerLungeTimer = 0;
let screenFlash = 0, doorScare = false, doorScareTimer = 0, hallwayShake = 0;
let ventCorrectStreak = 0, ventCorrectTimer = 0, ventWrongTimer = 0;
let ventJumpscare = false, ventJumpscareTimer = 0;
let whisperText = "", whisperOpacity = 0, correctVent = 1;
let flickerActive = false, flickerTimer = 0;
let scratching = false, scratchTimer = 0;
let loopTimer = 0, loopFreeze = false, survivalTimer = 0;
let introActive = false, introOpacity = 0, introTimer = 0;
let introTitle = "THE BUILDING THAT REMEMBERS";
let deathActive = false, deathTimer = 0, deathShake = 0;
let transitionActive = false, transitionTimer = 0;

function startPixelHorrorGame() {
  document.getElementById("pixel-horror-overlay").style.display = "block";
  canvas = document.getElementById("horrorCanvas");
  ctx = canvas.getContext("2d");
  currentFloor = 1; gameRunning = false;
  player.x = 20; player.y = 200; player.dir = 1; player.speed = 1.2;
  deathActive = false; transitionActive = false;
  ghostTimer = 0; survivalTimer = 0; screenFlash = 0; deathShake = 0; hallwayShake = 0;
  introActive = true; introOpacity = 0; introTimer = 0;
  requestAnimationFrame(gameLoop);
}

document.getElementById("exitHorrorGame").onclick = () => {
  document.getElementById("pixel-horror-overlay").style.display = "none";
  gameRunning = false; introActive = false; transitionActive = false; deathActive = false;
};

document.addEventListener("keydown", e => { keys[e.key] = true; });
document.addEventListener("keyup",   e => { keys[e.key] = false; });

function setupFloor(floor) {
  ghostTimer = 0; survivalTimer = 0;
  player.x = 20; player.y = 200; player.speed = 1.2; player.dir = 1;
  screenFlash = 0; deathShake = 0; hallwayShake = 0;
  whisperText = ""; whisperOpacity = 0;
  crawlerX = -40; crawlerSpeed = 0.4; crawlerFrame = 0; crawlerAnimTimer = 0;
  crawlerFlicker = false; crawlerFlickerTimer = 0;
  crawlerLunge = false; crawlerLungeTimer = 0;
  doorScare = false; doorScareTimer = 0;
  ventCorrectStreak = 0; ventCorrectTimer = 0; ventWrongTimer = 0;
  ventJumpscare = false; ventJumpscareTimer = 0;
  correctVent = Math.random() < 0.5 ? 1 : 2;
  flickerActive = false; flickerTimer = 0;
  scratching = false; scratchTimer = 0;
  loopTimer = 0; loopFreeze = false;
}

function drawIntro() {
  introTimer++;
  if (introTimer < 120)      introOpacity = introTimer / 120;
  else if (introTimer < 240) introOpacity = 1;
  else if (introTimer < 360) introOpacity = 1 - ((introTimer - 240) / 120);
  else { introActive = false; gameRunning = true; setupFloor(currentFloor); return; }
  ctx.fillStyle = "black"; ctx.fillRect(0, 0, canvas.width, canvas.height);
  ctx.globalAlpha = introOpacity;
  ctx.fillStyle = "white"; ctx.font = "20px serif"; ctx.textAlign = "center";
  ctx.fillText(introTitle, canvas.width / 2, canvas.height / 2);
  if (Math.random() < 0.05) { ctx.fillStyle = "rgba(255,0,0,0.2)"; ctx.fillRect(0, 0, canvas.width, canvas.height); }
  ctx.globalAlpha = 1;
}

function startTransition() { transitionActive = true; transitionTimer = 0; gameRunning = false; }
function drawTransition() {
  transitionTimer++;
  let opacity = Math.min(1, transitionTimer / 60);
  ctx.fillStyle = `rgba(0,0,0,${opacity})`; ctx.fillRect(0, 0, canvas.width, canvas.height);
  if (transitionTimer > 60 && transitionTimer < 120) {
    ctx.fillStyle = "rgba(255,255,255,0.4)"; ctx.font = "12px serif"; ctx.textAlign = "center";
    ctx.fillText("THE BUILDING REMEMBERS...", canvas.width / 2, canvas.height / 2);
  }
  if (transitionTimer >= 150) { transitionActive = false; gameRunning = true; setupFloor(currentFloor); }
}

function triggerDeath() {
  if (deathActive) return;
  deathActive = true; deathTimer = 0; gameRunning = false;
}

function drawDeath() {
  deathTimer++;
  ctx.fillStyle = "black"; ctx.fillRect(0, 0, canvas.width, canvas.height);
  if (deathTimer < 20) {
    let alpha = 1 - (deathTimer / 20);
    ctx.fillStyle = `rgba(255,255,255,${alpha})`; ctx.fillRect(0, 0, canvas.width, canvas.height); return;
  }
  if (deathTimer < 80) {
    let prog = (deathTimer - 20) / 60;
    let grad = ctx.createRadialGradient(canvas.width/2,canvas.height/2,20,canvas.width/2,canvas.height/2,240);
    grad.addColorStop(0,"rgba(0,0,0,0)");
    grad.addColorStop(1,`rgba(180,0,0,${0.2+prog*0.5})`);
    ctx.fillStyle = grad; ctx.fillRect(0,0,canvas.width,canvas.height);
    for (let i=0;i<300;i++){ctx.fillStyle=`rgba(255,255,255,${Math.random()*0.3})`;ctx.fillRect(Math.random()*canvas.width,Math.random()*canvas.height,1,1);}
    if (deathTimer > 50) {
      ctx.globalAlpha = Math.min(1,(deathTimer-50)/30);
      ctx.fillStyle="white";ctx.font="bold 28px serif";ctx.textAlign="center";
      ctx.fillText("YOU DIED",canvas.width/2+(Math.random()<0.3?Math.random()*8-4:0),canvas.height/2);
      ctx.globalAlpha=1;
    }
    return;
  }
  if (deathTimer < 230) {
    ctx.fillStyle="rgba(30,0,0,1)";ctx.fillRect(0,0,canvas.width,canvas.height);
    ctx.font="bold 28px serif";ctx.textAlign="center";
    ctx.globalAlpha=0.6;ctx.fillStyle="red";ctx.fillText("YOU DIED",canvas.width/2+4,canvas.height/2);
    ctx.fillStyle="cyan";ctx.fillText("YOU DIED",canvas.width/2-4,canvas.height/2);
    ctx.globalAlpha=1;ctx.fillStyle="white";ctx.fillText("YOU DIED",canvas.width/2,canvas.height/2);
    ctx.fillStyle="rgba(200,50,50,0.9)";ctx.font="10px serif";
    ctx.fillText("THE BUILDING REMEMBERS",canvas.width/2,canvas.height/2+25);
    for(let y=0;y<canvas.height;y+=2){ctx.fillStyle="rgba(0,0,0,0.25)";ctx.fillRect(0,y,canvas.width,1);}
    if(deathTimer>140&&Math.random()<0.3){ctx.fillStyle="rgba(255,0,0,0.15)";ctx.fillRect(0,0,canvas.width,canvas.height);}
    return;
  }
  currentFloor=1;deathActive=false;introActive=true;introOpacity=0;introTimer=0;
}

function endGameWin() {
  gameRunning=false;let t=0;
  function finalSequence(){
    t++;ctx.fillStyle="black";ctx.fillRect(0,0,canvas.width,canvas.height);
    ctx.fillStyle=t%20<10?"white":"red";ctx.font="20px serif";ctx.textAlign="center";
    ctx.fillText("THE BUILDING THAT REMEMBERS",canvas.width/2+(Math.random()<0.1?Math.random()*10-5:0),canvas.height/2);
    if(t===80){ctx.fillStyle="rgba(255,255,255,0.6)";ctx.font="12px serif";ctx.fillText("you escaped",canvas.width/2,canvas.height/2+30);}
    if(t<240)requestAnimationFrame(finalSequence);
    else document.getElementById("pixel-horror-overlay").style.display="none";
  }
  finalSequence();
}

function gameLoop() {
  if (!document.getElementById("pixel-horror-overlay")||document.getElementById("pixel-horror-overlay").style.display==="none") return;
  if (introActive) drawIntro();
  else if (transitionActive) drawTransition();
  else if (deathActive) drawDeath();
  else if (gameRunning) { update(); draw(); }
  requestAnimationFrame(gameLoop);
}

function update() {
  ghostTimer++;
  if (loopFreeze&&currentFloor===5) {
    loopTimer++;
    if(keys["ArrowLeft"]||keys["ArrowRight"]||keys["a"]||keys["d"]){triggerDeath();return;}
    if(loopTimer>200){loopTimer=0;loopFreeze=false;}
    return;
  }
  if(keys["d"]||keys["D"]){player.x+=player.speed;player.dir=1;}
  if(keys["a"]||keys["A"]){player.x-=player.speed;player.dir=-1;}
  if(player.x<10)player.x=10;
  if(player.x>440)player.x=440;
  if(currentFloor===1){
    if((keys["a"]||keys["A"])&&player.dir===-1){triggerDeath();return;}
    if(!doorScare&&!crawlerLunge)crawlerX+=crawlerSpeed;
    crawlerAnimTimer++;
    if(crawlerAnimTimer>20){crawlerAnimTimer=0;crawlerFrame=(crawlerFrame+1)%2;}
    crawlerFlicker=(player.x-crawlerX)<80;
    if(crawlerFlicker)crawlerFlickerTimer++;else crawlerFlickerTimer=0;
    let dist=player.x-crawlerX;
    hallwayShake=dist<120?(120-dist)*0.05:0;
    if(!doorScare&&!crawlerLunge&&crawlerX+12>=player.x){crawlerFrame=2;crawlerLunge=true;crawlerLungeTimer=0;}
    if(crawlerLunge){crawlerLungeTimer++;if(crawlerLungeTimer===1)screenFlash=20;if(crawlerLungeTimer>15){triggerDeath();return;}}
    if(doorScare){
      doorScareTimer++;player.speed=0;
      if(doorScareTimer===20)screenFlash=15;
      if(doorScareTimer>20&&doorScareTimer<50)deathShake=Math.sin(doorScareTimer*1.5)*3;
      if(doorScareTimer>60){doorScare=false;deathShake=0;currentFloor++;startTransition();return;}
    }
  }
  if(currentFloor===2){
    let ventX=correctVent===1?150:250;let wrongVentX=correctVent===1?250:150;
    if(Math.abs(player.x-ventX)<40){
      ventCorrectTimer++;
      if(ventCorrectTimer===60){whisperText="come closer";whisperOpacity=1;}
      if(ventCorrectTimer>120){ventCorrectStreak++;ventCorrectTimer=0;correctVent=Math.random()<0.5?1:2;}
    }else ventCorrectTimer=0;
    if(Math.abs(player.x-wrongVentX)<40){
      ventWrongTimer++;
      if(ventWrongTimer===40){whisperText="not that one";whisperOpacity=1;}
      if(ventWrongTimer>90&&!ventJumpscare){ventJumpscare=true;ventJumpscareTimer=0;ventCorrectStreak=0;}
    }else ventWrongTimer=0;
    if(ventJumpscare){
      ventJumpscareTimer++;
      if(ventJumpscareTimer<20)screenFlash=20;
      deathShake=Math.sin(ventJumpscareTimer*2)*6;
      if(ventJumpscareTimer>40){ventJumpscare=false;triggerDeath();return;}
    }
    if(ventCorrectStreak>=5&&!transitionActive){currentFloor++;startTransition();return;}
  }
  if(currentFloor===3){
    if(ghostTimer%120===0){flickerActive=true;flickerTimer=0;}
    if(flickerActive){
      flickerTimer++;
      if((keys["a"]||keys["A"])&&player.dir===-1){triggerDeath();return;}
      if(flickerTimer>40)flickerActive=false;
    }
  }
  if(currentFloor===4){
    if(ghostTimer%150===0){scratching=true;scratchTimer=0;}
    if(scratching){
      scratchTimer++;
      if(keys["ArrowLeft"]||keys["ArrowRight"]||keys["a"]||keys["d"]){triggerDeath();return;}
      if(scratchTimer>60)scratching=false;
    }
  }
  if(currentFloor===5){
    loopTimer++;
    if(loopTimer<120)loopFreeze=true;
    else if(loopTimer>200){loopTimer=0;loopFreeze=false;}
  }
  if(player.x>=440&&!transitionActive&&!deathActive&&!doorScare){
    if(currentFloor===1){doorScare=true;doorScareTimer=0;return;}
    if(currentFloor>=4){endGameWin();return;}
    currentFloor++;startTransition();
  }
}

function drawPlayerRight(x,y){const p=["....###.....","...#####....","..##R###....","..#####.....","..###.#.....","...##.#.....","....###.....","....###.....","....###.....","....###.....","....###.....","...#####....","...#####....","...#####...."];for(let py=0;py<p.length;py++)for(let px=0;px<p[py].length;px++){if(p[py][px]==="#"){ctx.fillStyle="white";ctx.fillRect(x+px,y+py,1,1);}if(p[py][px]==="R"){ctx.fillStyle="red";ctx.fillRect(x+px,y+py,1,1);}}}
function drawPlayerLeft(x,y){const p=[".....###....","....#####...","....###R##..","....#####...","....#.###...","....#.##....","....###.....","....###.....","....###.....","....###.....","....###.....","....#####...","....#####...","....#####..."];for(let py=0;py<p.length;py++)for(let px=0;px<p[py].length;px++){if(p[py][px]==="#"){ctx.fillStyle="white";ctx.fillRect(x+px,y+py,1,1);}if(p[py][px]==="R"){ctx.fillStyle="red";ctx.fillRect(x+px,y+py,1,1);}}}
function drawPlayer(){if(player.dir===1)drawPlayerRight(player.x,player.y-14);else drawPlayerLeft(player.x,player.y-14);}

function drawCrawler(x,y){const frames=[[["....####...."],["...######..."],["..###R###..."],["..######...."],["..###.###..."],["..##...##..."],["..##...##..."],["..##...##..."],["..###.###..."],["..######...."],["...####....."],["....##......"]],[["....####...."],["...######..."],["..###R###..."],["..######...."],["..###.###..."],["..##...##..."],["..##...##..."],["..###.###..."],["..######...."],["...####....."],["....####...."],["....##......"]]];const f=frames[Math.min(crawlerFrame,1)];for(let py=0;py<f.length;py++)for(let px=0;px<f[py][0].length;px++){if(f[py][0][px]==="#"){ctx.fillStyle="white";ctx.fillRect(x+px,y+py,1,1);}if(f[py][0][px]==="R"){ctx.fillStyle="red";ctx.fillRect(x+px,y+py,1,1);}}}

function drawHallway(){ctx.fillStyle="black";ctx.fillRect(0,0,canvas.width,canvas.height);ctx.fillStyle=crawlerFlicker?"rgba(255,0,0,0.2)":"rgba(255,255,255,0.05)";ctx.fillRect(60,20,40,6);ctx.fillRect(200,20,40,6);ctx.fillRect(340,20,40,6);ctx.strokeStyle="rgba(255,255,255,0.05)";ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(0,212);ctx.lineTo(480,212);ctx.stroke();ctx.beginPath();ctx.moveTo(0,212);ctx.lineTo(240,260);ctx.stroke();ctx.beginPath();ctx.moveTo(480,212);ctx.lineTo(240,260);ctx.stroke();ctx.strokeStyle="rgba(255,255,255,0.9)";ctx.lineWidth=2;ctx.strokeRect(440,150,30,60);let glow=Math.sin(ghostTimer*0.1)*0.1+0.2;ctx.fillStyle=`rgba(255,0,0,${glow})`;ctx.fillRect(440,150,30,60);ctx.fillStyle="rgba(255,255,255,0.2)";ctx.fillRect(448,160,14,8);let ef=(ghostTimer%20<10)?1:0.4;ctx.fillStyle=`rgba(255,0,0,${ef})`;ctx.font="10px serif";ctx.textAlign="center";ctx.fillText("EXIT",455,145);ctx.fillStyle="rgba(255,255,255,0.15)";ctx.font="8px serif";ctx.textAlign="left";ctx.fillText("FLOOR 1",10,15);}
function drawHallwayFloor2(){ctx.fillStyle="#050505";ctx.fillRect(0,0,canvas.width,canvas.height);ctx.strokeStyle="#222";ctx.lineWidth=2;ctx.beginPath();ctx.moveTo(0,212);ctx.lineTo(480,212);ctx.stroke();let ventX=correctVent===1?150:250;let wrongVentX=correctVent===1?250:150;ctx.strokeStyle="rgba(0,255,100,0.3)";ctx.lineWidth=1;ctx.strokeRect(ventX-10,180,20,20);ctx.strokeStyle="rgba(255,255,255,0.5)";ctx.lineWidth=1;ctx.strokeRect(wrongVentX-10,180,20,20);ctx.fillStyle="rgba(255,255,255,0.2)";ctx.font="7px serif";ctx.textAlign="center";ctx.fillText("vent",ventX,176);ctx.fillText("vent",wrongVentX,176);ctx.fillStyle="rgba(255,255,255,0.3)";ctx.font="8px serif";ctx.textAlign="left";ctx.fillText(`FLOOR 2 — correct: ${ventCorrectStreak}/5`,10,15);if(ventCorrectStreak>=5){ctx.strokeStyle="white";ctx.lineWidth=2;ctx.strokeRect(440,150,30,60);ctx.fillStyle="rgba(255,255,255,0.05)";ctx.fillRect(440,150,30,60);}}
function drawHallwayGeneric(n){ctx.fillStyle="black";ctx.fillRect(0,0,canvas.width,canvas.height);ctx.strokeStyle="rgba(255,255,255,0.04)";ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(0,212);ctx.lineTo(480,212);ctx.stroke();if(n===3){ctx.fillStyle=flickerActive?"rgba(255,0,0,0.15)":"rgba(255,255,255,0.04)";ctx.fillRect(60,20,40,6);ctx.fillRect(200,20,40,6);ctx.fillRect(340,20,40,6);}if(n===4){ctx.strokeStyle=scratching?"rgba(255,0,0,0.8)":"rgba(255,255,255,0.3)";ctx.lineWidth=2;ctx.strokeRect(20,150,30,60);if(scratching){ctx.fillStyle="rgba(255,0,0,0.1)";ctx.fillRect(20,150,30,60);}}if(n===5){ctx.fillStyle=loopFreeze?"white":"rgba(255,255,255,0.3)";ctx.fillRect(200,180,10,20);ctx.fillRect(230,180,10,20);}ctx.strokeStyle="rgba(255,255,255,0.9)";ctx.lineWidth=2;ctx.strokeRect(440,150,30,60);let glow=Math.sin(ghostTimer*0.1)*0.1+0.2;ctx.fillStyle=`rgba(255,0,0,${glow})`;ctx.fillRect(440,150,30,60);ctx.fillStyle="rgba(255,255,255,0.2)";ctx.fillRect(448,160,14,8);let ef=(ghostTimer%20<10)?1:0.4;ctx.fillStyle=`rgba(255,0,0,${ef})`;ctx.font="10px serif";ctx.textAlign="center";ctx.fillText("EXIT",455,145);ctx.fillStyle="rgba(255,255,255,0.15)";ctx.font="8px serif";ctx.textAlign="left";ctx.fillText(`FLOOR ${n}`,10,15);}

function drawGhost(){if(currentFloor===1)drawCrawler(crawlerX,player.y-12);else if(currentFloor===3&&flickerActive){ctx.fillStyle="white";ctx.fillRect(400,100,20,40);}else if(currentFloor===4){ctx.strokeStyle=scratching?"red":"rgba(255,255,255,0.4)";ctx.lineWidth=1;ctx.strokeRect(300,150,40,60);}else if(currentFloor===5){ctx.fillStyle=loopFreeze?"white":"rgba(255,255,255,0.3)";ctx.fillRect(200,180,10,20);ctx.fillRect(230,180,10,20);}}

function draw(){ctx.fillStyle="black";ctx.fillRect(0,0,canvas.width,canvas.height);ctx.save();ctx.translate(deathShake+hallwayShake,deathShake);if(currentFloor===1)drawHallway();else if(currentFloor===2)drawHallwayFloor2();else drawHallwayGeneric(currentFloor);drawPlayer();drawGhost();if(screenFlash>0){ctx.fillStyle="rgba(255,0,0,0.4)";ctx.fillRect(0,0,canvas.width,canvas.height);screenFlash--;}if(whisperOpacity>0){ctx.globalAlpha=whisperOpacity;ctx.fillStyle="rgba(255,255,255,0.8)";ctx.font="10px serif";ctx.textAlign="center";ctx.fillText(whisperText,canvas.width/2,40);whisperOpacity=Math.max(0,whisperOpacity-0.01);ctx.globalAlpha=1;}ctx.restore();}
</script>

