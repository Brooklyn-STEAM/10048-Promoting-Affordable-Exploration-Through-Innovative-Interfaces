    eggClicks++;

    if (eggClicks === 10) {
      eggClicks = 0;
      launchEasterEgg();
    }
  });

  function launchEasterEgg() {
    alert("🎉 You unlocked the Hidden Gems Easter Egg!");
    // Replace alert with your secret feature later
  }
</script>

