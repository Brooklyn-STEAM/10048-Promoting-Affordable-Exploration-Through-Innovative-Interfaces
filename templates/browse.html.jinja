/* ============================
   DRAW EVERYTHING
   ============================ */
function draw() {
  // 1. Clear screen
  ctx.fillStyle = "black";
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  // 2. Apply shake
 let shakeX = (deathShake + hallwayShake) || 0;
 let shakeY = (deathShake + hallwayShake) || 0;


  ctx.save();
  ctx.translate(shakeX, shakeY);

  // 3. Draw hallway (per floor)
if (currentFloor === 1) {
  drawHallway();            // Floor 1 hallway
} else if (currentFloor === 2) {
  drawHallwayFloor2();      // Floor 2 hallway
} else {
  drawHallway();            // fallback for floors 3–6 until we upgrade them
}


  // 4. Draw player
  drawPlayer();

  // 5. Draw crawler / ghost
  drawGhost();

  // 6. Flash overlay LAST (on top of everything)
  if (screenFlash > 0) {
    ctx.fillStyle = "rgba(255,0,0,0.4)";
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    screenFlash--;
  }

  // ============================
// WHISPER TEXT OVERLAY
// ============================
if (whisperOpacity > 0) {
  ctx.globalAlpha = whisperOpacity;
  ctx.fillStyle = "rgba(255,255,255,0.8)";
  ctx.font = "10px serif";
  ctx.textAlign = "center";
  ctx.fillText(whisperText, canvas.width / 2, 40);

  whisperOpacity -= 0.01; // fade out
  if (whisperOpacity < 0) whisperOpacity = 0;

  ctx.globalAlpha = 1;
}


  // 7. Restore ALWAYS (outside the flash block)
  ctx.restore();
}



