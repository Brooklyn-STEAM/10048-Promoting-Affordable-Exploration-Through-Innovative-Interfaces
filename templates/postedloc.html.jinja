<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Locations — Hidden Gems</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Archivo:wght@300;400;500&display=swap" rel="stylesheet">
  {% include 'icon.html.jinja' %}

  <style>
    :root {
      --bg:     #120e0a;
      --bg2:    #1a1410;
      --cream:  #e8ded0;
      --accent: #a4642e;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Archivo', sans-serif;
      background: var(--bg);
      color: var(--cream);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* subtle noise texture overlay */
    body::before {
      content: '';
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      opacity: 0.025;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size: 200px 200px;
    }

    .serif { font-family: 'Cormorant Garamond', serif; }
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-thumb { background: rgba(232,222,208,0.12); border-radius: 2px; }

    /* ── Warm radial glow behind header ── */
    .header-glow {
      position: absolute; top: -120px; left: 50%; transform: translateX(-50%);
      width: 600px; height: 400px; border-radius: 50%;
      background: radial-gradient(ellipse, rgba(164,100,46,0.12) 0%, transparent 70%);
      pointer-events: none;
    }

    /* ── Stat cards ── */
    .stat-card {
      border-radius: 14px; padding: 18px 20px;
      background: rgba(232,222,208,0.04);
      border: 1px solid rgba(232,222,208,0.08);
      position: relative; overflow: hidden;
      transition: border-color 0.25s;
    }
    .stat-card:hover { border-color: rgba(232,222,208,0.18); }
    .stat-card::after {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, var(--accent), transparent);
      opacity: 0.6;
    }
    .stat-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.4rem; font-weight: 300; line-height: 1;
      color: var(--cream); margin-bottom: 4px;
    }
    .stat-label {
      font-size: 0.5rem; letter-spacing: 0.28em; text-transform: uppercase;
      color: rgba(232,222,208,0.3);
    }

    /* ── Filter pills ── */
    .filter-pill {
      padding: 6px 16px; border-radius: 999px; font-size: 0.55rem;
      letter-spacing: 0.18em; text-transform: uppercase; cursor: pointer;
      background: transparent; border: 1px solid rgba(232,222,208,0.12);
      color: rgba(232,222,208,0.35); transition: all 0.2s; font-family: inherit;
      -webkit-tap-highlight-color: transparent;
    }
    .filter-pill:hover { border-color: rgba(232,222,208,0.28); color: rgba(232,222,208,0.7); }
    .filter-pill.active {
      background: rgba(232,222,208,0.08); border-color: rgba(232,222,208,0.35); color: var(--cream);
    }

    /* ── Gem cards ── */
    .gem-card {
      border-radius: 16px; overflow: hidden;
      background: rgba(232,222,208,0.03);
      border: 1px solid rgba(232,222,208,0.08);
      transition: all 0.28s cubic-bezier(0.23,1,0.32,1); cursor: pointer;
      position: relative;
    }
    .gem-card:hover {
      border-color: rgba(232,222,208,0.22);
      transform: translateY(-4px);
      box-shadow: 0 16px 40px rgba(0,0,0,0.45);
    }
    .gem-card img { width: 100%; height: 160px; object-fit: cover; display: block; }
    .no-img {
      height: 160px; display: flex; align-items: center; justify-content: center;
      font-size: 0.55rem; letter-spacing: 0.2em; text-transform: uppercase;
      opacity: 0.15; background: rgba(0,0,0,0.25);
    }

    /* shimmer on hover over image */
    .gem-card .img-wrap { position: relative; overflow: hidden; }
    .gem-card .img-wrap::after {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(105deg, transparent 40%, rgba(232,222,208,0.06) 50%, transparent 60%);
      transform: translateX(-100%); transition: transform 0.55s ease;
    }
    .gem-card:hover .img-wrap::after { transform: translateX(100%); }

    .gem-info { padding: 13px 15px 14px; }
    .gem-title { font-size: 0.88rem; font-weight: 500; line-height: 1.3; }
    .gem-meta  { font-size: 0.58rem; opacity: 0.35; margin-top: 3px; letter-spacing: 0.08em; }

    .borough-pill {
      display: inline-block; font-size: 0.48rem; letter-spacing: 0.18em;
      text-transform: uppercase; padding: 3px 9px; border-radius: 999px;
      background: rgba(232,222,208,0.06); border: 1px solid rgba(232,222,208,0.12);
      margin-top: 7px; color: rgba(232,222,208,0.55);
    }

    /* owner badge top-right */
    .owner-badge {
      position: absolute; top: 10px; right: 10px;
      font-size: 0.42rem; letter-spacing: 0.18em; text-transform: uppercase;
      padding: 3px 8px; border-radius: 999px;
      background: rgba(164,100,46,0.18); border: 1px solid rgba(164,100,46,0.4);
      color: rgba(232,222,208,0.7); pointer-events: none;
    }

    /* like count chip */
    .like-chip {
      display: inline-flex; align-items: center; gap: 4px;
      font-size: 0.6rem; color: rgba(232,222,208,0.35);
      padding: 0; background: none; border: none; cursor: default;
      font-family: inherit;
    }
    .like-chip.has-likes { color: var(--accent); }

    /* ── Lightbox ── */
    #lightbox {
      position: fixed; inset: 0; z-index: 400;
      background: rgba(0,0,0,0.75); backdrop-filter: blur(18px);
      display: none; align-items: center; justify-content: center; padding: 20px;
    }
    #lightbox.open { display: flex; }

    #lb-card {
      background: linear-gradient(155deg, #1e1812 0%, #140f0b 100%);
      border-radius: 22px; border: 1px solid rgba(232,222,208,0.12);
      width: 100%; max-width: 500px; overflow: hidden;
      box-shadow: 0 32px 80px rgba(0,0,0,0.6);
      max-height: 90vh; overflow-y: auto;
    }

    #lb-img-area {
      position: relative; height: 220px; overflow: hidden; background: #0a0806;
    }
    #lb-img-area img { width: 100%; height: 100%; object-fit: cover; display: block; }
    #lb-img-area .lb-img-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 55%);
    }
    #lb-img-area .lb-img-grid {
      position: absolute; inset: 0; opacity: 0.05;
      background-image: linear-gradient(rgba(232,222,208,0.8) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(232,222,208,0.8) 1px, transparent 1px);
      background-size: 36px 36px;
    }
    #lb-img-area .no-img-lb {
      height: 100%; display: flex; align-items: center; justify-content: center;
      font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.15;
    }

    .lb-accent-bar { height: 2px; background: linear-gradient(90deg, var(--accent), transparent); }

    .lb-body { padding: 20px 24px 24px; }

    #lb-hours-grid {
      display: grid; grid-template-columns: repeat(7,1fr); gap: 3px; text-align: center;
    }
    .lb-hour-cell {
      background: rgba(232,222,208,0.04); border-radius: 8px; padding: 6px 3px;
    }
    .lb-hour-cell.today { background: rgba(164,100,46,0.12); border: 1px solid rgba(164,100,46,0.25); }

    /* action buttons */
    .lb-btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 9px 18px; border-radius: 10px; font-size: 0.65rem;
      letter-spacing: 0.14em; text-transform: uppercase; font-family: inherit;
      cursor: pointer; transition: all 0.2s; border: 1px solid;
      -webkit-tap-highlight-color: transparent;
    }
    .lb-btn-edit {
      background: rgba(232,222,208,0.06); border-color: rgba(232,222,208,0.18);
      color: rgba(232,222,208,0.7);
    }
    .lb-btn-edit:hover { background: rgba(232,222,208,0.1); color: var(--cream); }
    .lb-btn-delete {
      background: rgba(239,68,68,0.07); border-color: rgba(239,68,68,0.2);
      color: rgba(239,68,68,0.7);
    }
    .lb-btn-delete:hover { background: rgba(239,68,68,0.14); color: rgb(239,68,68); }

    /* ── Delete confirm modal ── */
    #delete-modal {
      display: none; position: fixed; inset: 0; z-index: 500;
      background: rgba(0,0,0,0.65); backdrop-filter: blur(8px);
      align-items: center; justify-content: center; padding: 24px;
    }
    #delete-modal.open { display: flex; }

    /* ── Animations ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(14px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp 0.45s ease both; }
    .d1 { animation-delay: 0.06s; }
    .d2 { animation-delay: 0.13s; }
    .d3 { animation-delay: 0.2s; }

    @keyframes cardIn {
      from { opacity: 0; transform: translateY(18px) scale(0.97); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* ── Empty state ── */
    .empty-wrap {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 80px 0; text-align: center;
    }
    .empty-icon {
      width: 72px; height: 72px; border-radius: 50%;
      background: rgba(232,222,208,0.04); border: 1px solid rgba(232,222,208,0.1);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.6rem; margin-bottom: 24px;
    }

    @media (max-width: 639px) {
      #lb-card { border-radius: 20px 20px 0 0; max-height: 88vh; }
      #lightbox { align-items: flex-end; padding: 0; }
      #lb-hours-grid { grid-template-columns: repeat(4,1fr); }
    }
  </style>
</head>

<body>

{% include '_nav.html.jinja' %}

<div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 md:px-8 py-10 sm:py-14">

  <!-- ── Header ── -->
  <div class="relative fade-up mb-10 sm:mb-14">
    <div class="header-glow"></div>
    <a href="/browse" class="text-xs tracking-widest uppercase opacity-30 hover:opacity-60 transition-opacity">← Back</a>
    <div class="flex items-end justify-between mt-3 gap-4 flex-wrap">
      <div>
        <h1 class="serif text-5xl sm:text-6xl font-light leading-none">My Locations</h1>
        <div class="w-10 h-px mt-4 opacity-50" style="background:var(--accent);"></div>
        <p class="text-xs opacity-30 tracking-widest uppercase mt-3">{{ current_user.name }}</p>
      </div>
      <a href="/browse" class="flex-shrink-0 inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-[rgba(232,222,208,0.15)] text-[rgba(232,222,208,0.5)] text-[0.55rem] tracking-[0.2em] uppercase hover:border-[rgba(232,222,208,0.3)] hover:text-[#e8ded0] transition-all no-underline">
        <span style="width:5px;height:5px;border-radius:50%;background:var(--accent);flex-shrink:0;"></span>
        Add more
      </a>
    </div>
  </div>

  {% if locations %}

  <!-- ── Stats row ── -->
  {% set total_likes = locations | sum(attribute='LikeCount') %}
  {% set boroughs_set = locations | map(attribute='Borough') | list | unique | list %}
  <div class="grid grid-cols-3 gap-3 sm:gap-4 mb-10 fade-up d1">
    <div class="stat-card">
      <p class="stat-num">{{ locations | length }}</p>
      <p class="stat-label">Locations posted</p>
    </div>
    <div class="stat-card">
      <p class="stat-num">{{ total_likes }}</p>
      <p class="stat-label">Total likes received</p>
    </div>
    <div class="stat-card">
      <p class="stat-num">{{ boroughs_set | length }}</p>
      <p class="stat-label">Boroughs explored</p>
    </div>
  </div>

  <!-- ── Borough filter ── -->
  <div class="flex flex-wrap gap-2 mb-8 fade-up d2" id="filter-bar">
    <button class="filter-pill active" data-borough="all" onclick="filterBy('all', this)">All</button>
    {% set seen = [] %}
    {% for loc in locations %}
      {% if loc.Borough not in seen %}
        {% set _ = seen.append(loc.Borough) %}
        <button class="filter-pill" data-borough="{{ loc.Borough }}" onclick="filterBy('{{ loc.Borough }}', this)">
          {{ loc.Borough | capitalize }}
        </button>
      {% endif %}
    {% endfor %}
  </div>

  <!-- ── Grid ── -->
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 sm:gap-4 fade-up d3" id="locations-grid">
    {% for loc in locations %}
    <div class="gem-card" data-borough="{{ loc.Borough }}" onclick="openDetail({{ loop.index0 }})"
         style="animation: cardIn 0.4s ease {{ (loop.index0 * 0.05) | round(2) }}s both;">
      <div class="img-wrap">
        {% if loc.Image %}
          {% if loc.Image.startswith('http') %}
            <img src="{{ loc.Image }}" alt="{{ loc.Name }}">
          {% else %}
            <img src="{{ url_for('static', filename='uploads/' + loc.Image) }}" alt="{{ loc.Name }}">
          {% endif %}
        {% else %}
          <div class="no-img">No image</div>
        {% endif %}
      </div>
      <span class="owner-badge">Yours</span>
      <div class="gem-info">
        <p class="gem-title">{{ loc.Name }}</p>
        <p class="gem-meta">{{ loc.DatePosted.strftime('%b %d, %Y') if loc.DatePosted else '' }}</p>
        <div class="flex items-center justify-between mt-2">
          <span class="borough-pill">{{ loc.Borough | capitalize }}</span>
          <span class="like-chip {{ 'has-likes' if (loc.LikeCount or 0) > 0 else '' }}">
            {{ '♥' if (loc.LikeCount or 0) > 0 else '♡' }} {{ loc.LikeCount or 0 }}
          </span>
        </div>
        {% if loc.PriceTier %}
        <p class="gem-meta" style="margin-top:5px;">
          {% if loc.PriceTier == 'free' %}○ Free
          {% elif loc.PriceTier == '$' %}$ Budget
          {% elif loc.PriceTier == '$$' %}$$ Mid-range
          {% elif loc.PriceTier == '$$$' %}$$$ Upscale
          {% endif %}
        </p>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>

  {% else %}

  <!-- ── Empty state ── -->
  <div class="empty-wrap fade-up d1">
    <div class="empty-icon">✦</div>
    <p class="serif text-4xl font-light mb-3 opacity-30">No gems posted yet</p>
    <p class="text-xs tracking-widest uppercase opacity-20 mb-8">Share the hidden corners of NYC you love</p>
    <a href="/browse" style="
      display:inline-flex;align-items:center;gap:8px;
      padding:11px 26px;border-radius:999px;
      border:1px solid rgba(232,222,208,0.2);
      color:rgba(232,222,208,0.6);font-size:0.6rem;
      letter-spacing:0.2em;text-transform:uppercase;text-decoration:none;
      transition:all 0.2s;
    " onmouseover="this.style.color='#e8ded0';this.style.borderColor='rgba(232,222,208,0.4)'"
       onmouseout="this.style.color='rgba(232,222,208,0.6)';this.style.borderColor='rgba(232,222,208,0.2)'">
      <span style="width:5px;height:5px;border-radius:50%;background:var(--accent);"></span>
      Explore & add a location
    </a>
  </div>

  {% endif %}
</div>

<!-- ── LIGHTBOX ── -->
<div id="lightbox" onclick="if(event.target===this)closeLightbox()">
  <div id="lb-card">

    <!-- image / map area -->
    <div id="lb-img-area">
      <div class="lb-img-grid"></div>
      <div id="lb-img-inner"></div>
      <div class="lb-img-overlay"></div>
      <!-- badge overlaid on image -->
      <div style="position:absolute;top:14px;left:14px;z-index:2;">
        <span id="lb-borough-badge" style="
          font-size:0.48rem;letter-spacing:0.2em;text-transform:uppercase;
          padding:3px 10px;border-radius:999px;
          background:var(--accent);color:#fff;opacity:0.9;
        "></span>
      </div>
      <div style="position:absolute;bottom:14px;right:14px;z-index:2;">
        <a id="lb-map-link" href="#" target="_blank" style="
          display:inline-flex;align-items:center;gap:5px;
          padding:6px 14px;border-radius:999px;
          background:rgba(0,0,0,0.45);border:1px solid rgba(232,222,208,0.2);
          color:rgba(232,222,208,0.8);font-size:0.55rem;letter-spacing:0.18em;
          text-transform:uppercase;text-decoration:none;transition:all 0.2s;
        ">Maps ↗</a>
      </div>
    </div>

    <div class="lb-accent-bar"></div>

    <div class="lb-body">
      <!-- status row -->
      <div class="flex items-center gap-2 flex-wrap mb-3">
        <span id="lb-open-status" style="
          display:inline-flex;align-items:center;gap:4px;
          font-size:0.5rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;
          padding:3px 9px;border-radius:4px;
        "></span>
        <span id="lb-price-badge" style="display:none;
          font-size:0.5rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;
          padding:3px 9px;border-radius:4px;
          background:rgba(232,222,208,0.06);border:1px solid rgba(232,222,208,0.12);
          color:rgba(232,222,208,0.5);
        "></span>
      </div>

      <h2 id="lb-title" class="serif" style="font-size:1.9rem;font-weight:300;color:var(--cream);line-height:1.1;margin-bottom:5px;"></h2>
      <p id="lb-meta" style="font-size:0.58rem;letter-spacing:0.16em;text-transform:uppercase;color:rgba(232,222,208,0.3);margin-bottom:12px;"></p>
      <p id="lb-desc" style="font-size:0.84rem;color:rgba(232,222,208,0.6);line-height:1.75;margin-bottom:16px;"></p>

      <!-- price note -->
      <div id="lb-price-note-wrap" style="display:none;margin-bottom:16px;padding:10px 14px;border-radius:10px;background:rgba(232,222,208,0.04);border:1px solid rgba(232,222,208,0.08);">
        <p style="font-size:0.5rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(232,222,208,0.3);margin-bottom:4px;">Pricing note</p>
        <p id="lb-price-note" style="font-size:0.8rem;color:rgba(232,222,208,0.5);line-height:1.5;"></p>
      </div>

      <!-- address -->
      <div id="lb-addr-wrap" style="margin-bottom:16px;display:none;">
        <p style="font-size:0.5rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(232,222,208,0.3);margin-bottom:4px;">Address</p>
        <p id="lb-addr-text" style="font-size:0.8rem;color:rgba(232,222,208,0.5);line-height:1.5;"></p>
      </div>

      <!-- hours -->
      <div id="lb-hours-wrap" style="margin-bottom:20px;display:none;">
        <p style="font-size:0.5rem;letter-spacing:0.24em;text-transform:uppercase;color:rgba(232,222,208,0.3);margin-bottom:8px;">Hours</p>
        <div id="lb-hours-grid"></div>
      </div>

      <!-- likes -->
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:16px;padding:12px 14px;border-radius:12px;background:rgba(232,222,208,0.03);border:1px solid rgba(232,222,208,0.08);">
        <span style="font-size:1rem;" id="lb-heart">♡</span>
        <span>
          <p style="font-size:0.85rem;color:var(--cream);font-weight:500;" id="lb-like-count">0</p>
          <p style="font-size:0.5rem;letter-spacing:0.18em;text-transform:uppercase;color:rgba(232,222,208,0.25);">Likes received</p>
        </span>
      </div>

      <!-- owner actions -->
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <button id="lb-edit-btn" class="lb-btn lb-btn-edit" onclick="goEdit()">✎ Edit</button>
        <button id="lb-delete-btn" class="lb-btn lb-btn-delete" onclick="openDeleteModal()">Remove</button>
        <button class="lb-btn" onclick="closeLightbox()" style="background:rgba(232,222,208,0.04);border-color:rgba(232,222,208,0.1);color:rgba(232,222,208,0.4);">Close</button>
      </div>
    </div>
  </div>
</div>

<!-- ── Delete confirm ── -->
<div id="delete-modal" onclick="if(event.target===this)closeDeleteModal()">
  <div style="background:#111;border:1px solid rgba(232,222,208,0.12);border-radius:20px;padding:28px 24px;width:100%;max-width:360px;display:flex;flex-direction:column;align-items:center;">
    <div style="width:48px;height:48px;border-radius:50%;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);display:flex;align-items:center;justify-content:center;margin-bottom:20px;">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M8 4h4M3 6h14M5 6l1 10a2 2 0 002 2h4a2 2 0 002-2l1-10" stroke="rgba(239,68,68,0.9)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <p class="serif" style="font-size:1.4rem;font-weight:300;color:#e8ded0;margin-bottom:8px;text-align:center;">Remove this location?</p>
    <p style="font-size:0.75rem;color:rgba(232,222,208,0.4);text-align:center;line-height:1.6;margin-bottom:24px;">This can't be undone. The location and all its data will be permanently deleted.</p>
    <div style="display:flex;flex-direction:column;gap:8px;width:100%;">
      <button id="delete-confirm-btn" style="width:100%;padding:13px;border-radius:10px;background:rgba(239,68,68,0.15);border:1px solid rgba(239,68,68,0.3);color:rgb(239,68,68);font-size:0.7rem;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;cursor:pointer;font-family:inherit;">Yes, remove it</button>
      <button onclick="closeDeleteModal()" style="width:100%;padding:13px;border-radius:10px;background:rgba(232,222,208,0.05);border:1px solid rgba(232,222,208,0.12);color:rgba(232,222,208,0.5);font-size:0.7rem;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;cursor:pointer;font-family:inherit;">Cancel</button>
    </div>
  </div>
</div>

<script>
  const locations = {{ locations_json | safe }};
  const BOROUGH_SLUG = loc => (loc.Borough || '').replace(/ /g, '-');
  let lbIndex = 0;

  // ── Filter ──
  function filterBy(borough, btn) {
    document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.gem-card').forEach(card => {
      card.style.display = (borough === 'all' || card.dataset.borough === borough) ? '' : 'none';
    });
  }

  // ── Lightbox ──
  function openDetail(index) {
    lbIndex = index;
    const loc = locations[index]; if (!loc) return;

    // Image
    const imgInner = document.getElementById('lb-img-inner');
    if (loc.Image) {
      const src = loc.Image.startsWith('http') ? loc.Image : `/static/uploads/${loc.Image}`;
      imgInner.innerHTML = `<img src="${src}" alt="${loc.Name}" style="width:100%;height:220px;object-fit:cover;">`;
    } else {
      imgInner.innerHTML = `<div class="no-img-lb">No image</div>`;
    }

    // Borough badge & map link
    document.getElementById('lb-borough-badge').textContent = (loc.Borough || '').toUpperCase();
    const mapLink = document.getElementById('lb-map-link');
    if (loc.Address) {
      mapLink.href = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(loc.Address + ', New York City')}`;
      mapLink.style.display = 'inline-flex';
    } else { mapLink.style.display = 'none'; }

    // Open status
    const openStatus = document.getElementById('lb-open-status');
    let isOpen = false;
    if (loc.Hours && Array.isArray(loc.Hours)) {
      const today = loc.Hours[[6,0,1,2,3,4,5][new Date().getDay()]];
      if (today && today.hours && today.hours !== 'Closed') {
        const [os, cs] = today.hours.split(' – ');
        const now = new Date(), ot = new Date(), ct = new Date();
        ot.setHours(...os.split(':').map(Number), 0);
        ct.setHours(...cs.split(':').map(Number), 0);
        if (now >= ot && now <= ct) isOpen = true;
      }
    }
    openStatus.textContent = isOpen ? '● Open now' : '● Closed';
    openStatus.style.cssText += isOpen
      ? ';color:rgb(74,222,128);background:rgba(74,222,128,0.1);border:1px solid rgba(74,222,128,0.25);border-radius:4px;padding:3px 9px;font-size:0.5rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;'
      : ';color:rgb(239,68,68);background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.25);border-radius:4px;padding:3px 9px;font-size:0.5rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;';

    // Price badge
    const priceBadge = document.getElementById('lb-price-badge');
    if (loc.PriceTier) {
      const labels = { free: '○ Free', '$': '$ Budget', '$$': '$$ Mid-range', '$$$': '$$$ Upscale' };
      priceBadge.textContent = labels[loc.PriceTier] || loc.PriceTier;
      priceBadge.style.display = 'inline-flex';
    } else { priceBadge.style.display = 'none'; }

    // Price note
    const priceNoteWrap = document.getElementById('lb-price-note-wrap');
    if (loc.PriceNote) {
      document.getElementById('lb-price-note').textContent = loc.PriceNote;
      priceNoteWrap.style.display = 'block';
    } else { priceNoteWrap.style.display = 'none'; }

    // Core text
    document.getElementById('lb-title').textContent = loc.Name;
    document.getElementById('lb-meta').textContent  = `${loc.Borough || ''} · ${loc.DatePosted || ''}`;
    document.getElementById('lb-desc').textContent  = loc.Description || 'No description provided.';

    // Address
    const addrWrap = document.getElementById('lb-addr-wrap');
    if (loc.Address) {
      document.getElementById('lb-addr-text').textContent = loc.Address;
      addrWrap.style.display = 'block';
    } else { addrWrap.style.display = 'none'; }

    // Hours
    const hoursWrap = document.getElementById('lb-hours-wrap');
    const hoursGrid = document.getElementById('lb-hours-grid');
    if (loc.Hours && loc.Hours.length) {
      hoursWrap.style.display = 'block';
      const todayIdx = [6,0,1,2,3,4,5][new Date().getDay()];
      hoursGrid.innerHTML = loc.Hours.map((h, i) => `
        <div class="lb-hour-cell ${i === todayIdx ? 'today' : ''}">
          <div style="font-size:0.42rem;letter-spacing:0.1em;text-transform:uppercase;opacity:0.35;margin-bottom:3px;">${h.name}</div>
          <div style="font-size:0.48rem;color:${h.hours === 'Closed' ? 'rgba(232,222,208,0.22)' : 'rgba(232,222,208,0.7)'};">${formatHours(h.hours)}</div>
        </div>`).join('');
    } else { hoursWrap.style.display = 'none'; }

    // Likes
    document.getElementById('lb-like-count').textContent = loc.LikeCount || 0;
    document.getElementById('lb-heart').textContent = (loc.LikeCount || 0) > 0 ? '♥' : '♡';
    document.getElementById('lb-heart').style.color = (loc.LikeCount || 0) > 0 ? 'var(--accent)' : 'rgba(232,222,208,0.3)';

    document.getElementById('lightbox').classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    document.getElementById('lightbox').classList.remove('open');
    document.body.style.overflow = '';
  }

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeLightbox();
  });

  function formatHours(s) {
    if (!s || s === 'Closed') return 'Closed';
    const p = s.split(' – ');
    return p.length !== 2 ? s : `${to12h(p[0])}–${to12h(p[1])}`;
  }
  function to12h(t) {
    if (!t || !t.includes(':')) return t;
    let [h, m] = t.split(':').map(Number);
    const suf = h >= 12 ? 'p' : 'a'; h = (h % 12) || 12;
    return `${h}:${m.toString().padStart(2,'0')}${suf}`;
  }

  // ── Edit: navigate to borough page with edit open ──
  function goEdit() {
    const loc = locations[lbIndex]; if (!loc) return;
    // Open the borough page; the edit modal requires being on that page
    window.location.href = `/borough/${BOROUGH_SLUG(loc)}`;
  }

  // ── Delete ──
  function openDeleteModal() {
    document.getElementById('delete-modal').classList.add('open');
    document.getElementById('delete-confirm-btn').onclick = confirmDelete;
  }
  function closeDeleteModal() {
    document.getElementById('delete-modal').classList.remove('open');
  }
  async function confirmDelete() {
    const loc = locations[lbIndex]; if (!loc) return;
    closeDeleteModal();
    const res  = await fetch(`/borough/${BOROUGH_SLUG(loc)}/delete/${loc.ID}`, { method: 'POST' });
    const data = await res.json();
    if (data.success) {
      locations.splice(lbIndex, 1);
      closeLightbox();
      // Remove card from grid
      const cards = document.querySelectorAll('.gem-card');
      if (cards[lbIndex]) {
        cards[lbIndex].style.transition = 'opacity 0.3s, transform 0.3s';
        cards[lbIndex].style.opacity = '0';
        cards[lbIndex].style.transform = 'scale(0.94)';
        setTimeout(() => { cards[lbIndex].remove(); updateStats(); }, 300);
      } else { location.reload(); }
    } else {
      alert('Failed to delete location.');
    }
  }

  function updateStats() {
    // Recalculate stats after deletion without full reload
    const remaining = document.querySelectorAll('.gem-card').length;
    const statNums = document.querySelectorAll('.stat-num');
    if (statNums[0]) statNums[0].textContent = remaining;
  }
</script>

</body>
</html>
