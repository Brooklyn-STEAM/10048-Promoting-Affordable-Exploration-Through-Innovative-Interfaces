{% if current_user.is_authenticated %}
<a href="/profile"
   title="{{ current_user.name }}"
   class="fixed top-5 right-6 z-50 w-10 h-10 rounded-full bg-[#5c6b5c] border-2 border-[#1f1f1f] shadow-[3px_3px_0px_#1f1f1f] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all duration-150 overflow-hidden flex items-center justify-center">
  {% if current_user.profile_picture %}
    <img src="{{ current_user.profile_picture }}"
         class="w-full h-full object-cover"
         onerror="this.style.display='none'; this.nextElementSibling.style.display='block';">
    <span class="text-white text-sm font-bold" style="display:none;">
      {{ current_user.name[0] | upper }}
    </span>
  {% else %}
    <span class="text-white text-sm font-bold">
      {{ current_user.name[0] | upper }}
    </span>
  {% endif %}
</a>
{% endif %}


<audio id="bg-music" style="display:none;">

  <source src="{{ url_for('static', filename='audio/newyork2008.mp3') }}" type="audio/mpeg">
</audio>

<script>
  const tracks = [
    "{{ url_for('static', filename='audio/akinh.mp3') }}",
    "{{ url_for('static', filename='audio/newyork2008.mp3') }}",
    "{{ url_for('static', filename='audio/theglorylove.mp3') }}",
    "{{ url_for('static', filename='audio/changepartners.mp3') }}",
    "{{ url_for('static', filename='audio/tcttafm.mp3') }}",
    "{{ url_for('static', filename='audio/daynight.mp3') }}",
    "{{ url_for('static', filename='audio/10kbed.mp3') }}",
    "{{ url_for('static', filename='audio/flywithme2008.mp3') }}",
    "{{ url_for('static', filename='audio/money.mp3') }}",
    "{{ url_for('static', filename='audio/ragstoriches.mp3') }}",
    "{{ url_for('static', filename='audio/thatslife.mp3') }}",
    "{{ url_for('static', filename='audio/thebrooklynbridge.mp3') }}",
    "{{ url_for('static', filename='audio/.mp3') }}",
    "{{ url_for('static', filename='audio/.mp3') }}",
  ];

  let trackIndex = parseInt(sessionStorage.getItem('trackIndex') || '0');
  let trackTime  = parseFloat(sessionStorage.getItem('trackTime') || '0');

  const audio = document.getElementById('bg-music');

  // START SILENT
  audio.volume = 0;
  audio.src = tracks[trackIndex];

  const MAX_VOLUME = 0.2;     // your original level
  const FADE_DURATION = 4000; // 4 seconds

  function fadeInAudio() {
    const steps = 50;
    const stepTime = FADE_DURATION / steps;
    const volumeStep = MAX_VOLUME / steps;

    let currentStep = 0;

    const fade = setInterval(() => {
      currentStep++;
      audio.volume = Math.min(volumeStep * currentStep, MAX_VOLUME);

      if (currentStep >= steps) {
        clearInterval(fade);
      }
    }, stepTime);
  }

  // When ready to play
  audio.addEventListener('canplay', () => {
  if (trackTime > 0) {
    audio.currentTime = trackTime;
    trackTime = 0;
  }

  audio.play().then(() => {
    // Only fade if starting fresh
    if (audio.currentTime < 1) {
      fadeInAudio();
    } else {
      audio.volume = MAX_VOLUME;
    }
  }).catch(() => {
    document.addEventListener('click', () => {
      audio.play().then(() => {
        if (audio.currentTime < 1) {
          fadeInAudio();
        } else {
          audio.volume = MAX_VOLUME;
        }
      });
    }, { once: true });
  });

}, { once: true });

  // Save playback state
  window.addEventListener('beforeunload', () => {
    sessionStorage.setItem('trackIndex', trackIndex);
    sessionStorage.setItem('trackTime', audio.currentTime);
  });

  // Next track (NO fade reset so it stays smooth)
 audio.addEventListener('ended', () => {
  trackIndex = (trackIndex + 1) % tracks.length;

  audio.src = tracks[trackIndex];
  audio.load(); //force reload of new track

  audio.addEventListener('canplay', function handleNext() {
    audio.volume = MAX_VOLUME;
    audio.play();

    audio.removeEventListener('canplay', handleNext);
  });

  sessionStorage.setItem('trackIndex', trackIndex);
});
</script>
